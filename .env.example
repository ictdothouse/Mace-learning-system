# ==========================================
# CONTOH KONFIGURASI .ENV - JANGAN GUNAKAN VALUES INI!
# ==========================================
# Copy file ini ke .env dan GANTIKAN semua values dengan credentials anda
# cp .env.example .env
# Kemudian edit .env dengan credentials sebenar

PORT=3000

# MongoDB Atlas
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/<database>
MONGO_URI=mongodb+srv://your_user:your_password@cluster0.xxxxx.mongodb.net/your_database?retryWrites=true&w=majority

# Session Secret - Generate dengan command ini:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=paste_random_string_dari_command_di_atas

# Admin Credentials
ADMIN_USER=admin_yourusername
ADMIN_PASS=StrongPassword123!

# WordPress API (optional)
WP_API_URL=

# Cloudflare R2
R2_ACCOUNT_ID=your_account_id
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_URL=https://media.yourdomain.com # Optional: Custom domain connected to R2 bucket

NODE_ENV=production

# WordPress Integration & Embed Origins (comma-separated origins)
ALLOWED_EMBED_ORIGINS=https://www.nsc.gov.my,https://modulatlitmace.com
