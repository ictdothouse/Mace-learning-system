# ==========================================
# KONFIGURASI PRODUCTION - HOSTINGER
# ==========================================
# ⚠️ GANTIKAN SEMUA NILAI DI BAWAH SEBELUM DEPLOY!
# ⚠️ JANGAN COMMIT FAIL INI KE GITHUB!

PORT=3000

# MongoDB Atlas - GUNA CONNECTION STRING ANDA SENDIRI
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/sukma_db?retryWrites=true&w=majority

# Session Secret - GUNAKAN RANDOM STRING PANJANG (min 32 karakter)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=CHANGE_THIS_TO_A_RANDOM_SECURE_STRING_MIN_32_CHARS

# Admin Credentials - TUKAR DEFAULT INI!
ADMIN_USER=admin_msn_2026
ADMIN_PASS=GantiDenganPasswordKuat123!

# WordPress API (jika guna)
WP_API_URL=https://your-wordpress-site.com/wp-json/wp/v2

# ==========================================
# CLOUDFLARE R2 CONFIGURATION
# ==========================================
# ⚠️ DAPATKAN CREDENTIALS BARU DARI CLOUDFLARE DASHBOARD
# ⚠️ REVOKE KUNCI LAMA YANG SUDAH TERDEDAH!

R2_ACCOUNT_ID=GANTI_DENGAN_ACCOUNT_ID_ANDA
R2_ENDPOINT=https://GANTI_DENGAN_ACCOUNT_ID_ANDA.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=GANTI_DENGAN_ACCESS_KEY_BARU
R2_SECRET_ACCESS_KEY=GANTI_DENGAN_SECRET_KEY_BARU
R2_BUCKET_NAME=modulmace

# ==========================================
# PRODUCTION SETTINGS
# ==========================================
NODE_ENV=production
