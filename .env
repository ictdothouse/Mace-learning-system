# ==========================================
# KONFIGURASI PRODUCTION - HOSTINGER
# ==========================================
# ⚠️ ARAHAN PENTING:
# 1. GANTIKAN SEMUA NILAI "GANTI_DENGAN_..." DENGAN CREDENTIALS ANDA
# 2. JANGAN COMMIT FAIL INI KE GITHUB!
# 3. Simpan fail ini sebagai .env di server Hostinger sahaja

PORT=3000

# MongoDB Atlas - MASUKKAN CONNECTION STRING ANDA
# Contoh format sebenar: mongodb+srv://myuser:mypassword123@cluster0.abc123.mongodb.net/sukma_db?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://GANTI_DENGAN_USER:GANTI_DENGAN_PASSWORD@cluster0.xxxxx.mongodb.net/sukma_db?retryWrites=true&w=majority

# Session Secret - WAJIB TUKAR! Generate random string panjang
# Cara mudah: Buka https://generate-secret.vercel.app/32 copy result paste kat bawah
SESSION_SECRET=GANTI_DENGAN_RANDOM_STRING_PANJANG_MIN_32_HURUF

# Admin Credentials - TUKAR DEFAULT INI SEBELUM DEPLOY!
ADMIN_USER=admin_msn_2026
ADMIN_PASS=GantiDenganPasswordKuat123!

# WordPress API (jika guna, kalau tak biarkan kosong)
WP_API_URL=

# ==========================================
# CLOUDFLARE R2 CONFIGURATION
# ==========================================
# Kalau TAK GUNA Cloudflare R2, biarkan kosong je. System akan auto save ke local storage.

R2_ACCOUNT_ID=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=modulmace

# ==========================================
# PRODUCTION SETTINGS
# ==========================================
NODE_ENV=production
