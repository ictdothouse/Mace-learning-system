<!DOCTYPE html>
<html lang="ms">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sijil - <%= athlete.fullName %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Poppins:wght@300;400;600&display=swap');
        
        .certificate-container {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #fef9f3 0%, #fff8e7 100%);
            border: 20px solid #1a365d;
            padding: 40px;
            position: relative;
            max-width: 900px;
            margin: 0 auto;
        }
        
        .inner-border {
            border: 3px solid #c9a227;
            padding: 30px;
            position: relative;
        }
        
        .corner-decoration {
            position: absolute;
            width: 80px;
            height: 80px;
            border: 3px solid #c9a227;
        }
        
        .top-left { top: 10px; left: 10px; border-right: none; border-bottom: none; }
        .top-right { top: 10px; right: 10px; border-left: none; border-bottom: none; }
        .bottom-left { bottom: 10px; left: 10px; border-right: none; border-top: none; }
        .bottom-right { bottom: 10px; right: 10px; border-left: none; border-top: none; }
        
        .header-text {
            font-family: 'Playfair Display', serif;
            color: #1a365d;
        }
        
        .athlete-name {
            font-family: 'Playfair Display', serif;
            font-size: 48px;
            font-weight: 700;
            color: #004aad;
            text-decoration: underline;
            text-underline-offset: 8px;
        }
    </style>
</head>
<body class="bg-gray-100 min-h-screen py-8 px-4">
    <div class="mb-6 text-center">
        <button onclick="window.print()" class="bg-blue-600 text-white px-6 py-3 rounded-lg font-bold hover:bg-blue-700 transition mr-4">
            🖨️ Cetak / Simpan PDF
        </button>
        <a href="/dashboard" class="bg-gray-600 text-white px-6 py-3 rounded-lg font-bold hover:bg-gray-700 transition inline-block">
            ← Kembali ke Dashboard
        </a>
    </div>

    <div class="certificate-container shadow-2xl">
        <div class="inner-border">
            <!-- Corner Decorations -->
            <div class="corner-decoration top-left"></div>
            <div class="corner-decoration top-right"></div>
            <div class="corner-decoration bottom-left"></div>
            <div class="corner-decoration bottom-right"></div>
            
            <!-- Header -->
            <div class="text-center mb-8">
                <h1 class="header-text text-5xl font-bold mb-2">SIJIL PENYERTAAN</h1>
                <p class="text-gray-600 text-lg">MyAthleteModule Learning Program</p>
            </div>
            
            <!-- Content -->
            <div class="text-center my-12">
                <p class="text-gray-700 text-lg mb-4">Dengan ini disahkan bahawa</p>
                <div class="athlete-name mb-6"><%= athlete.fullName %></div>
                <p class="text-gray-700 text-lg mb-2">telah berjaya menyelesaikan semua modul pembelajaran</p>
                <p class="text-gray-600 text-md italic">"Mewakili Negeri: <strong><%= athlete.negeriWakil %></strong>"</p>
            </div>
            
            <!-- Date Section -->
            <div class="flex justify-between items-end mt-16 px-8">
                <div class="text-center">
                    <div class="border-t-2 border-gray-400 w-48 pt-2">
                        <p class="text-sm text-gray-600">Tarikh</p>
                        <p class="font-semibold"><%= new Date().toLocaleDateString('ms-MY', { day: 'numeric', month: 'long', year: 'numeric' }) %></p>
                    </div>
                </div>
                
                <div class="text-center">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/9/9c/Seal_of_Malaysia.svg/1200px-Seal_of_Malaysia.svg.png" alt="Logo" class="w-20 h-20 mx-auto mb-2 opacity-80">
                    <div class="border-t-2 border-gray-400 w-48 pt-2">
                        <p class="text-sm text-gray-600">Pengarah Program</p>
                        <p class="font-semibold">MyAthleteModule</p>
                    </div>
                </div>
            </div>
            
            <!-- Certificate ID -->
            <div class="text-center mt-12 pt-6 border-t border-gray-300">
                <p class="text-xs text-gray-500">ID Sijil: CERT-<%= athlete._id.toString().slice(-8).toUpperCase() %></p>
            </div>
        </div>
    </div>
    
    <div class="text-center mt-6 text-gray-500 text-sm">
        <p>© 2024 MyAthleteModule. Hak cipta terpelihara.</p>
    </div>

    <script>
        // Auto-print dialog on load (optional)
        // window.onload = () => window.print();
    </script>
</body>
</html>
