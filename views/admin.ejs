                                                <option value="Great Vibes">
                                                <option value="Dancing Script">
                                                <option value="Alex Brush">
                                                <option value="Sacramento">
                                                <option value="Parisienne">
                                                <option value="Playfair Display">
                                                <option value="Poppins">
                                                <option value="Montserrat">
                                                <option value="Inter">
                                                <option value="Pacifico">
                                                <option value="Caveat">
                                                <option value="Satisfy">
                                                <option value="Allura">
                                            </datalist>
                                        </div>
                                    </div>
                                </div>

                                <!-- Background -->
                                <div>
                                    <h4 class="font-bold text-gray-700 border-b pb-2 mb-3">Background Sijil</h4>
                                    <div class="space-y-3">
                                        <div>
                                            <label class="block text-sm font-medium text-gray-700 mb-1">Jenis Background</label>
                                            <select name="backgroundImageType" id="bgType" onchange="toggleBgInputs()" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 outline-none">
                                                <option value="none">Tiada (Solid Color)</option>
                                                <option value="url">URL Image</option>
                                                <option value="r2">Muat Naik Fail Gambar</option>
                                            </select>
                                        </div>
                                        <div id="bgUrlInput" class="hidden">
                                            <label class="block text-sm font-medium text-gray-700 mb-1">Background Image URL</label>
