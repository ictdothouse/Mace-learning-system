                                        </div>
                                        <div id="bgR2Input" class="hidden">
                                            <label class="block text-sm font-medium text-gray-700 mb-1">Muat Naik Gambar Background (PNG/JPG)</label>
                                            <input type="file" name="backgroundImage" accept="image/*" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 outline-none bg-white">
                                            <input type="hidden" name="backgroundR2Key" value="">
