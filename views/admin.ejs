                                                <form action="/admin-mace/students/delete/<%= s._id %>" method="POST" class="inline" onsubmit="return confirm('PADAM akaun pelajar ini? Tindakan tidak boleh undur.')">
                                                    <button type="submit" class="text-red-600 hover:text-red-800 text-xs font-medium px-3 py-1.5 rounded hover:bg-red-50 transition">Padam</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" class="px-6 py-12 text-center text-gray-400 italic">Tiada pelajar berdaftar lagi.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        <% } %>

