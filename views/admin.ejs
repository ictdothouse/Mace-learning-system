                                <% students.forEach(s => { %>
                                    <tr class="hover:bg-blue-50/30 transition">
                                        <td class="px-6 py-4 font-medium text-gray-900">
                                            <%= s.fullName %>
                                            <% if (s.athleteData) { %>
                                                <span class="text-gray-400 text-xs ml-2">(Atlit)</span>
                                            <% } %>
