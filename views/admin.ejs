                                                <a href="/admin-mace/teachers/edit/<%= t._id %>" class="text-blue-600 hover:text-blue-800 text-xs font-medium px-3 py-1.5 rounded hover:bg-blue-50 transition">Edit</a>
                                                <form action="/admin-mace/teachers/reset-password/<%= t._id %>" method="POST" class="inline" onsubmit="return confirm('Reset password untuk guru ini?')">
                                                    <button type="submit" class="text-orange-600 hover:text-orange-800 text-xs font-medium px-3 py-1.5 rounded hover:bg-orange-50 transition">Reset PW</button>
                                                </form>
                                                <form action="/admin-mace/teachers/delete/<%= t._id %>" method="POST" class="inline" onsubmit="return confirm('PADAM akaun guru ini? Tindakan tidak boleh undur.')">
                                                    <button type="submit" class="text-red-600 hover:text-red-800 text-xs font-medium px-3 py-1.5 rounded hover:bg-red-50 transition">Padam</button>
                                                </form>
