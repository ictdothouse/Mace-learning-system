                <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6">❌ <%= lang === 'en' ? 'Email is already in use by another user.' : 'E-mel tersebut telah digunakan oleh pengguna lain.' %></div>
