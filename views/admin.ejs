            <% } else if (msg === 'athlete_converted') { %>
                <div class="bg-blue-50 border border-blue-200 text-blue-700 px-4 py-3 rounded-lg mb-6"><%= lang === 'en' ? getTerm('student') + ' account created! New password:' : 'Akaun ' + getTerm('student').toLowerCase() + ' dicipta! Password baru:' %> <strong><%= newPassword %></strong></div>
            <% } else if (msg === 'already_converted') { %>
