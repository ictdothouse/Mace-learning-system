            <%- (locals.branding && branding.footerText) ? branding.footerText : '&copy; 2026 Majlis Sukan Negara Malaysia. Sistem eLearning Atlet MACE v2.0' %>
        </div>
    </main>

    <script>
        // Certificate Live Preview & Drag-Drop Logic
        
        let templateData = {
            elements: {
                title: { positionX: 50, positionY: 10, fontSize: 36, color: '#004aad', align: 'center', lineHeight: 1.2, letterSpacing: 0, show: true, text: 'SIJIL PENGHARGAAN' },
                subtitle: { positionX: 50, positionY: 18, fontSize: 18, color: '#333333', align: 'center', lineHeight: 1.3, letterSpacing: 1, show: true, text: 'KURSUS eLEARNING ATLET MACE' },
                description: { positionX: 50, positionY: 28, fontSize: 16, color: '#000000', align: 'center', lineHeight: 1.4, letterSpacing: 0, show: true, text: 'Adalah dengan ini diperakui bahawa' },
                athleteName: { positionX: 50, positionY: 38, fontSize: 42, color: '#004aad', align: 'center', lineHeight: 1.2, letterSpacing: 2, show: true, text: 'NAMA ATLET' },
                icNumber: { positionX: 50, positionY: 48, fontSize: 14, color: '#666666', align: 'center', lineHeight: 1.3, letterSpacing: 1, show: false, text: '900101-01-1234' },
                negeri: { positionX: 50, positionY: 52, fontSize: 16, color: '#000000', align: 'center', lineHeight: 1.3, letterSpacing: 0, show: true, text: 'JOHOR' },
                sukan: { positionX: 50, positionY: 56, fontSize: 16, color: '#004aad', align: 'center', lineHeight: 1.3, letterSpacing: 0, show: false, text: 'OLAHRAGA' },
                courseName: { positionX: 50, positionY: 60, fontSize: 20, color: '#004aad', align: 'center', lineHeight: 1.3, letterSpacing: 0, show: true, text: 'KURSUS eLEARNING ATLET MACE' },
                date: { positionX: 50, positionY: 68, fontSize: 14, color: '#000000', align: 'center', lineHeight: 1.3, letterSpacing: 0, show: true, text: '28 Jun 2026' },
                signatory: { positionX: 20, positionY: 80, fontSize: 14, color: '#000000', align: 'left', lineHeight: 1.3, letterSpacing: 0, show: true, text: 'PENGARAH' },
                signatoryTitle: { positionX: 20, positionY: 85, fontSize: 12, color: '#666666', align: 'left', lineHeight: 1.3, letterSpacing: 0, show: true, text: 'Majlis Sukan Negara' }
            }
        };

        let selectedElement = 'title';
        let isDragging = false;
        let draggedElement = null;
        let startX, startY;

        function initPreview() {
            const form = document.getElementById('createTemplateForm');
            if (!form) return;
            
            form.addEventListener('input', () => { updateDataFromForm(); updatePreview(); });
            form.addEventListener('change', () => { updateDataFromForm(); updatePreview(); });
            
            updateDataFromForm();
            updatePreview();
            loadElementControls();
            
            const preview = document.getElementById('certificatePreview');
            if(preview) {
                preview.addEventListener('mousedown', startDrag);
                preview.addEventListener('mousemove', drag);
                window.addEventListener('mouseup', endDrag);
                
                preview.addEventListener('touchstart', startDrag, {passive: false});
                preview.addEventListener('touchmove', drag, {passive: false});
                window.addEventListener('touchend', endDrag);
            }
            
            form.addEventListener('submit', prepareFormForSubmit);
        }
        
        function updateDataFromForm() {
            const form = document.getElementById('createTemplateForm');
            if(!form) return;
            
            if(form.querySelector('[name="title"]')) templateData.elements.title.text = form.querySelector('[name="title"]').value;
            if(form.querySelector('[name="subtitle"]')) templateData.elements.subtitle.text = form.querySelector('[name="subtitle"]').value;
            if(form.querySelector('[name="description"]')) templateData.elements.description.text = form.querySelector('[name="description"]').value;
            if(form.querySelector('[name="courseName"]')) templateData.elements.courseName.text = form.querySelector('[name="courseName"]').value;
            if(form.querySelector('[name="signatoryName"]')) templateData.elements.signatory.text = form.querySelector('[name="signatoryName"]').value;
            if(form.querySelector('[name="signatoryTitle"]')) templateData.elements.signatoryTitle.text = form.querySelector('[name="signatoryTitle"]').value;
            
            const testNameInput = document.getElementById('previewTestName');
            templateData.elements.athleteName.text = (testNameInput && testNameInput.value.trim() !== '') ? testNameInput.value.trim() : 'NAMA ATLET';
            
            if(form.querySelector('[name="showTitle"]')) templateData.elements.title.show = form.querySelector('[name="showTitle"]').checked;
            if(form.querySelector('[name="showSubtitle"]')) templateData.elements.subtitle.show = form.querySelector('[name="showSubtitle"]').checked;
            if(form.querySelector('[name="showDescription"]')) templateData.elements.description.show = form.querySelector('[name="showDescription"]').checked;
            if(form.querySelector('[name="showCourseName"]')) templateData.elements.courseName.show = form.querySelector('[name="showCourseName"]').checked;
            if(form.querySelector('[name="showAthleteName"]')) templateData.elements.athleteName.show = form.querySelector('[name="showAthleteName"]').checked;
            if(form.querySelector('[name="showIcNumber"]')) templateData.elements.icNumber.show = form.querySelector('[name="showIcNumber"]').checked;
            if(form.querySelector('[name="showNegeri"]')) templateData.elements.negeri.show = form.querySelector('[name="showNegeri"]').checked;
            if(form.querySelector('[name="showSukan"]')) templateData.elements.sukan.show = form.querySelector('[name="showSukan"]').checked;
            if(form.querySelector('[name="showDate"]')) templateData.elements.date.show = form.querySelector('[name="showDate"]').checked;
            if(form.querySelector('[name="showSignatory"]')) {
                templateData.elements.signatory.show = form.querySelector('[name="showSignatory"]').checked;
                templateData.elements.signatoryTitle.show = form.querySelector('[name="showSignatory"]').checked;
            }
        }

        function updatePreview() {
            const preview = document.getElementById('certificatePreview');
            if (!preview) return;
            const form = document.getElementById('createTemplateForm');
            if (!form) return;
            
            const orientation = form.querySelector('[name="orientation"]') ? form.querySelector('[name="orientation"]').value : 'landscape';
            
            // Adjust preview aspect ratio class & max-width style
            if (orientation === 'portrait') {
                preview.classList.remove('aspect-[1.414]');
                preview.classList.add('aspect-[0.707]');
                preview.style.maxWidth = '450px';
            } else {
                preview.classList.remove('aspect-[0.707]');
                preview.classList.add('aspect-[1.414]');
                preview.style.maxWidth = '';
            }
            
            const bgType = form.querySelector('[name="backgroundImageType"]') ? form.querySelector('[name="backgroundImageType"]').value : 'none';
            const opacity = form.querySelector('[name="backgroundOpacity"]') ? form.querySelector('[name="backgroundOpacity"]').value : 1;
            const fontFamily = form.querySelector('[name="fontFamily"]') ? form.querySelector('[name="fontFamily"]').value : 'Helvetica';
            const athleteNameFont = form.querySelector('[name="athleteNameFont"]') ? form.querySelector('[name="athleteNameFont"]').value : 'Great Vibes';
            
            // Dynamically load Google Font for preview on-the-fly
            if (athleteNameFont && !['Helvetica', 'Times-Roman', 'Courier', 'Arial', 'Georgia', 'Times New Roman'].includes(athleteNameFont)) {
                const fontKey = athleteNameFont.trim().replace(/\s+/g, '+');
                const linkId = `gfont-preview-${fontKey.toLowerCase()}`;
                if (!document.getElementById(linkId)) {
                    const link = document.createElement('link');
                    link.id = linkId;
                    link.rel = 'stylesheet';
                    link.href = `https://fonts.googleapis.com/css2?family=${fontKey}&display=swap`;
                    document.head.appendChild(link);
                }
            }
            
            preview.style.fontFamily = fontFamily;
            preview.innerHTML = '';
            
            let bgImg = '';
            if (bgType === 'url') bgImg = form.querySelector('[name="backgroundImageUrl"]').value;
            
            if (bgImg) {
                const bgDiv = document.createElement('div');
                bgDiv.style.position = 'absolute';
                bgDiv.style.inset = '0';
                bgDiv.style.backgroundImage = `url('${bgImg}')`;
                bgDiv.style.backgroundSize = 'cover';
                bgDiv.style.backgroundPosition = 'center';
                bgDiv.style.opacity = opacity;
                bgDiv.style.zIndex = '0';
                preview.appendChild(bgDiv);
            }
            
            Object.keys(templateData.elements).forEach(key => {
                const el = templateData.elements[key];
                if (!el.show) return;
                
                const div = document.createElement('div');
                div.className = 'absolute cursor-move whitespace-pre-wrap max-w-[95%] break-words px-2 py-1 border-2 border-transparent hover:border-blue-400 select-none';
                if (selectedElement === key) {
                    div.classList.add('border-blue-500', 'border-dashed');
                }
                
                div.dataset.key = key;
                div.innerText = el.text;
                
                // Set position using transform to center around the point
                div.style.left = `${el.positionX}%`;
                div.style.top = `${el.positionY}%`;
                
                let transformStr = 'translate(-50%, -50%)';
                if (el.align === 'left') {
                    transformStr = 'translate(0, -50%)';
                } else if (el.align === 'right') {
                    transformStr = 'translate(-100%, -50%)';
                }
                div.style.transform = transformStr;
                
                div.style.fontSize = `${el.fontSize / 2}px`;
                div.style.color = el.color;
                div.style.textAlign = el.align;
                div.style.lineHeight = el.lineHeight;
                div.style.letterSpacing = `${el.letterSpacing}px`;
                div.style.zIndex = '10';
                
                if (key === 'athleteName') {
                    div.style.fontFamily = `'${athleteNameFont}', cursive`;
                }
                
                const handleStart = (e) => {
                    e.stopPropagation();
                    selectElement(key);
                    startDrag(e, key);
                };
                
                div.addEventListener('mousedown', handleStart);
                div.addEventListener('touchstart', handleStart);
                
                preview.appendChild(div);
            });
            
            // Footer Live Preview
            const showFooter = form.querySelector('[name="showFooter"]') ? form.querySelector('[name="showFooter"]').checked : true;
            if (showFooter) {
                const footerLine1 = form.querySelector('[name="footerLine1"]') ? form.querySelector('[name="footerLine1"]').value : '';
                const footerLine2 = form.querySelector('[name="footerLine2"]') ? form.querySelector('[name="footerLine2"]').value : '';
                
                const fDiv = document.createElement('div');
                fDiv.className = 'absolute whitespace-pre-wrap max-w-[95%] break-words px-2 py-1 select-none text-center';
                fDiv.style.left = '50%';
                fDiv.style.top = '95%';
                fDiv.style.transform = 'translate(-50%, -50%)';
                fDiv.style.fontSize = '5px'; // Scaled down similar to print template
                fDiv.style.color = '#999999';
                fDiv.style.lineHeight = '1.3';
                fDiv.innerHTML = `${footerLine1}<br>${footerLine2}`;
                preview.appendChild(fDiv);
            }
        }

        function selectElement(key) {
            selectedElement = key;
            const selector = document.getElementById('elementSelector');
            if(selector) selector.value = key;
            loadElementControls();
            updatePreview();
        }

        function loadElementControls() {
            const selector = document.getElementById('elementSelector');
            if(!selector) return;
            const key = selector.value;
            selectedElement = key;
            const el = templateData.elements[key];
            
            if(el) {
                if(document.getElementById('elemPosX')) document.getElementById('elemPosX').value = el.positionX;
                if(document.getElementById('elemPosY')) document.getElementById('elemPosY').value = el.positionY;
                if(document.getElementById('elemFontSize')) document.getElementById('elemFontSize').value = el.fontSize;
                if(document.getElementById('elemAlign')) document.getElementById('elemAlign').value = el.align;
                if(document.getElementById('elemColor')) document.getElementById('elemColor').value = el.color;
                if(document.getElementById('elemLineHeight')) document.getElementById('elemLineHeight').value = el.lineHeight;
                if(document.getElementById('elemLetterSpacing')) document.getElementById('elemLetterSpacing').value = el.letterSpacing;
            }
            updatePreview();
        }

        function updateElementPosition() {
            const key = selectedElement;
            const el = templateData.elements[key];
            if(!el) return;
            el.positionX = parseFloat(document.getElementById('elemPosX').value);
            el.positionY = parseFloat(document.getElementById('elemPosY').value);
            updatePreview();
        }

        function updateElementStyle() {
            const key = selectedElement;
            const el = templateData.elements[key];
            if(!el) return;
            el.fontSize = parseFloat(document.getElementById('elemFontSize').value);
            el.align = document.getElementById('elemAlign').value;
            el.color = document.getElementById('elemColor').value;
            el.lineHeight = parseFloat(document.getElementById('elemLineHeight').value);
            el.letterSpacing = parseFloat(document.getElementById('elemLetterSpacing').value);
            updatePreview();
        }
        
        function prepareFormForSubmit(e) {
            const form = document.getElementById('createTemplateForm');
            form.querySelectorAll('.dyn-hidden').forEach(el => el.remove());
            
            Object.keys(templateData.elements).forEach(key => {
                const el = templateData.elements[key];
                const props = ['positionX', 'positionY', 'fontSize', 'color', 'align', 'lineHeight', 'letterSpacing'];
                props.forEach(p => {
                    const input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = `elements[${key}][${p}]`;
                    input.value = el[p];
                    input.className = 'dyn-hidden';
                    form.appendChild(input);
                });
            });
        }
        
        function startDrag(e, key) {
            if (!key) return; 
            isDragging = true;
            draggedElement = key;
            
            const clientX = e.touches ? e.touches[0].clientX : e.clientX;
            const clientY = e.touches ? e.touches[0].clientY : e.clientY;
            
            startX = clientX;
            startY = clientY;
        }

        function drag(e) {
            if (!isDragging || !draggedElement) return;
            e.preventDefault();
            
            const clientX = e.touches ? e.touches[0].clientX : e.clientX;
            const clientY = e.touches ? e.touches[0].clientY : e.clientY;
            
            const dx = clientX - startX;
            const dy = clientY - startY;
            
            const preview = document.getElementById('certificatePreview');
            const rect = preview.getBoundingClientRect();
            
            const dxPct = (dx / rect.width) * 100;
            const dyPct = (dy / rect.height) * 100;
            
            const el = templateData.elements[draggedElement];
            el.positionX = Math.max(0, Math.min(100, el.positionX + dxPct));
            el.positionY = Math.max(0, Math.min(100, el.positionY + dyPct));
            
            startX = clientX;
            startY = clientY;
            
            if(document.getElementById('elemPosX')) document.getElementById('elemPosX').value = Math.round(el.positionX);
            if(document.getElementById('elemPosY')) document.getElementById('elemPosY').value = Math.round(el.positionY);
            
            updatePreview();
        }

        function endDrag() {
            isDragging = false;
            draggedElement = null;
        }
        
        function toggleBgInputs() {
            const type = document.getElementById('bgType').value;
            if(document.getElementById('bgUrlInput')) document.getElementById('bgUrlInput').classList.toggle('hidden', type !== 'url');
            if(document.getElementById('bgR2Input')) document.getElementById('bgR2Input').classList.toggle('hidden', type !== 'r2');
            updatePreview();
        }

        function openCreateModal() {
            const form = document.getElementById('createTemplateForm');
            form.reset();
            form.action = '/admin-mace/templates/create';
            document.querySelector('#createTemplateModal h3').innerText = 'Cipta Template Baharu - Live Preview & Drag-Drop';
            
            // Reset elements position to default
            templateData.elements = {
                title: { positionX: 50, positionY: 15, fontSize: 32, align: 'center', color: '#004aad' },
                subtitle: { positionX: 50, positionY: 25, fontSize: 18, align: 'center', color: '#333333' },
                description: { positionX: 50, positionY: 35, fontSize: 14, align: 'center', color: '#333333' },
                athleteName: { positionX: 50, positionY: 45, fontSize: 36, align: 'center', color: '#004aad' },
                icNumber: { positionX: 50, positionY: 53, fontSize: 14, align: 'center', color: '#333333' },
                negeri: { positionX: 50, positionY: 60, fontSize: 16, align: 'center', color: '#fbbf24' },
                sukan: { positionX: 50, positionY: 65, fontSize: 16, align: 'center', color: '#fbbf24' },
                courseName: { positionX: 50, positionY: 72, fontSize: 20, align: 'center', color: '#004aad' },
                date: { positionX: 20, positionY: 85, fontSize: 12, align: 'left', color: '#333333' },
                signatory: { positionX: 80, positionY: 85, fontSize: 14, align: 'right', color: '#333333' }
            };
            
            document.getElementById('createTemplateModal').classList.remove('hidden');
            updatePreview();
        }

        function editTemplate(id, jsonStr) {
            const data = JSON.parse(decodeURIComponent(jsonStr.replace(/&quot;/g, '"')));
            const form = document.getElementById('createTemplateForm');
            form.action = '/admin-mace/templates/update/' + id;
            document.querySelector('#createTemplateModal h3').innerText = 'Edit Template Sijil';
            
            // Populate text inputs
            const fields = ['name', 'title', 'subtitle', 'courseName', 'description', 'signatoryName', 'signatoryTitle', 'primaryColor', 'secondaryColor', 'accentColor', 'fontFamily', 'athleteNameFont', 'logoUrl', 'backgroundImageType', 'backgroundImageUrl', 'backgroundR2Key', 'backgroundOpacity', 'orientation', 'footerLine1', 'footerLine2'];
            fields.forEach(f => {
                const input = form.querySelector(`[name="${f}"]`);
                if (input && data[f] !== undefined) input.value = data[f];
            });
            
            // Populate checkboxes
            const checkboxes = ['showTitle', 'showSubtitle', 'showCourseName', 'showDescription', 'showAthleteName', 'showIcNumber', 'showNegeri', 'showSukan', 'showDate', 'showSignatory', 'showBorder', 'showLogo', 'showFooter'];
            checkboxes.forEach(f => {
                const input = form.querySelector(`[name="${f}"]`);
                if (input) {
                    if (['showBorder', 'showLogo', 'showIcNumber', 'showSukan', 'showFooter'].includes(f)) {
                        input.checked = data[f] === true;
                    } else {
                        input.checked = data[f] !== false;
                    }
                }
            });
            
            const setActive = form.querySelector('[name="setAsActive"]');
            if (setActive) setActive.checked = data.isActive === true;
            
            // Reset elements position to default first to avoid cross-contamination
            templateData.elements = {
                title: { positionX: 50, positionY: 15, fontSize: 32, align: 'center', color: '#004aad' },
                subtitle: { positionX: 50, positionY: 25, fontSize: 18, align: 'center', color: '#333333' },
                description: { positionX: 50, positionY: 35, fontSize: 14, align: 'center', color: '#333333' },
                athleteName: { positionX: 50, positionY: 45, fontSize: 36, align: 'center', color: '#004aad' },
                icNumber: { positionX: 50, positionY: 53, fontSize: 14, align: 'center', color: '#333333' },
                negeri: { positionX: 50, positionY: 60, fontSize: 16, align: 'center', color: '#fbbf24' },
                sukan: { positionX: 50, positionY: 65, fontSize: 16, align: 'center', color: '#fbbf24' },
                courseName: { positionX: 50, positionY: 72, fontSize: 20, align: 'center', color: '#004aad' },
                date: { positionX: 20, positionY: 85, fontSize: 12, align: 'left', color: '#333333' },
                signatory: { positionX: 80, positionY: 85, fontSize: 14, align: 'right', color: '#333333' },
                signatoryTitle: { positionX: 20, positionY: 85, fontSize: 12, color: '#666666', align: 'left', lineHeight: 1.3, letterSpacing: 0 }
            };

            // Load saved positions
            if (data.elements) {
                for (const key in templateData.elements) {
                    if (data.elements[key]) {
                        templateData.elements[key] = { ...templateData.elements[key], ...data.elements[key] };
                    }
                }
            } else if (data.elementsJson) {
                try {
                    const savedElements = JSON.parse(data.elementsJson);
                    for (const key in templateData.elements) {
                        if (savedElements[key]) {
                            templateData.elements[key] = { ...templateData.elements[key], ...savedElements[key] };
                        }
                    }
                } catch(e) { console.error('Error parsing elements JSON', e); }
            }
            
            toggleBgInputs();
            document.getElementById('createTemplateModal').classList.remove('hidden');
            updatePreview();
        }

        document.addEventListener('DOMContentLoaded', () => {
            initPreview();
        });

        // Toggle lessons list accordion collapse
        function toggleLessons(cardEl) {
            const collapse = cardEl.querySelector('.lessons-collapse');
            const chevron = cardEl.querySelector('.lessons-chevron');
            if (collapse) {
                collapse.classList.toggle('hidden');
                if (chevron) {
                    chevron.classList.toggle('rotate-180');
                }
            }
        }

        // Toggle mobile sidebar
        function toggleSidebar() {
            const sidebar = document.getElementById('adminSidebar');
            const overlay = document.getElementById('sidebarOverlay');
            
            if (sidebar.classList.contains('-translate-x-full')) {
                sidebar.classList.remove('-translate-x-full');
                overlay.classList.remove('hidden');
                setTimeout(() => {
                    overlay.classList.remove('opacity-0');
                }, 50);
                document.body.style.overflow = 'hidden';
            } else {
                sidebar.classList.add('-translate-x-full');
                overlay.classList.add('opacity-0');
                setTimeout(() => {
                    overlay.classList.add('hidden');
                }, 300);
                document.body.style.overflow = '';
            }
        }
    </script>
</body>
</html>