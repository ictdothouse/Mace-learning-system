            <script>
                function editTemplate(id, dataStr) {
                    const data = JSON.parse(decodeURIComponent(dataStr.replace(/&quot;/g, '"')));
                    document.getElementById('editTemplateForm').action = '/admin-mace/templates/update/' + id;
                    document.getElementById('edit_name').value = data.name || '';
                    document.getElementById('edit_title').value = data.title || '';
                    document.getElementById('edit_subtitle').value = data.subtitle || '';
                    document.getElementById('edit_courseName').value = data.courseName || '';
                    document.getElementById('edit_description').value = data.description || '';
                    document.getElementById('edit_signatoryName').value = data.signatoryName || '';
                    document.getElementById('edit_signatoryTitle').value = data.signatoryTitle || '';
                    document.getElementById('edit_primaryColor').value = data.primaryColor || '#004aad';
                    document.getElementById('edit_secondaryColor').value = data.secondaryColor || '#333333';
                    document.getElementById('edit_accentColor').value = data.accentColor || '#fbbf24';
                    document.getElementById('edit_fontFamily').value = data.fontFamily || 'Helvetica';
                    document.getElementById('edit_athleteNameFont').value = data.athleteNameFont || 'Great Vibes';
                    document.getElementById('edit_showBorder').checked = data.showBorder || false;
                    document.getElementById('edit_showLogo').checked = data.showLogo || false;
                    document.getElementById('edit_logoUrl').value = data.logoUrl || '';
                    document.getElementById('edit_setAsActive').checked = data.isActive || false;
                    document.getElementById('edit_orientation').value = data.orientation || 'landscape';
                    
                    // Toggle options
                    document.getElementById('edit_showTitle').checked = data.showTitle !== false;
                    document.getElementById('edit_showSubtitle').checked = data.showSubtitle !== false;
                    document.getElementById('edit_showDescription').checked = data.showDescription !== false;
                    document.getElementById('edit_showAthleteName').checked = data.showAthleteName !== false;
                    document.getElementById('edit_showIcNumber').checked = data.showIcNumber || false;
                    document.getElementById('edit_showNegeri').checked = data.showNegeri !== false;
                    document.getElementById('edit_showSukan').checked = data.showSukan || false;
                    document.getElementById('edit_showCourseName').checked = data.showCourseName !== false;
                    document.getElementById('edit_showDate').checked = data.showDate !== false;
                    document.getElementById('edit_showSignatory').checked = data.showSignatory !== false;
                    
                    // Background options
                    document.getElementById('edit_backgroundImageType').value = data.backgroundImageType || 'none';
                    document.getElementById('edit_backgroundImageUrl').value = data.backgroundImageUrl || '';
                    document.getElementById('edit_backgroundR2Key').value = data.backgroundR2Key || '';
                    document.getElementById('edit_backgroundOpacity').value = data.backgroundOpacity || 1;
                    toggleBgInputs();
                    
                    document.getElementById('editTemplateModal').classList.remove('hidden');
                }
                
                function toggleBgInputs() {
                    // For create modal
                    const createBgTypeEl = document.getElementById('bgType');
                    if (createBgTypeEl) {
                        const bgType = createBgTypeEl.value;
                        const urlInput = document.getElementById('bgUrlInput');
                        const r2Input = document.getElementById('bgR2Input');
                        if (urlInput) urlInput.classList.toggle('hidden', bgType !== 'url');
                        if (r2Input) r2Input.classList.toggle('hidden', bgType !== 'r2');
                    }
                    
                    // For edit modal
                    const editBgTypeEl = document.getElementById('edit_backgroundImageType');
                    if (editBgTypeEl) {
                        const editBgType = editBgTypeEl.value;
                        const editUrlInput = document.getElementById('edit_bgUrlInput');
                        const editR2Input = document.getElementById('edit_bgR2Input');
                        if (editUrlInput) editUrlInput.classList.toggle('hidden', editBgType !== 'url');
                        if (editR2Input) editR2Input.classList.toggle('hidden', editBgType !== 'r2');
                    }
                }
            </script>
