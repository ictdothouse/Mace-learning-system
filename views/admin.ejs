                                <th class="px-6 py-4">Email</th>
                                <th class="px-6 py-4">Kumpulan</th>
                                <th class="px-6 py-4">Tarikh Daftar</th>
                                <th class="px-6 py-4 text-right">Tindakan</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
