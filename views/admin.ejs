                                        <td class="px-6 py-4 text-gray-600"><%= s.email %></td>
                                        <td class="px-6 py-4">
                                            <% if (s.enrolledGroups && s.enrolledGroups.length > 0) { %>
                                                <% s.enrolledGroups.forEach(g => { %>
                                                    <span class="bg-blue-100 text-blue-700 px-2 py-1 rounded text-xs font-bold mr-1"><%= g.name %></span>
                                                <% }); %>
                                            <% } else { %>
                                                <span class="text-gray-400 text-xs">Tiada</span>
                                            <% } %>
                                        </td>
                                        <td class="px-6 py-4 text-gray-500"><%= new Date(s.createdAt).toLocaleDateString('ms-MY') %></td>
                                        <td class="px-6 py-4 text-right">
                                            <div class="flex items-center justify-end gap-2">
                                                <a href="/admin-mace/students/edit/<%= s._id %>" class="text-blue-600 hover:text-blue-800 text-xs font-medium px-3 py-1.5 rounded hover:bg-blue-50 transition">Edit</a>
                                                <% if (s.isUserAccount) { %>
                                                <form action="/admin-mace/students/reset-password/<%= s._id %>" method="POST" class="inline" onsubmit="return confirm('Reset password untuk pelajar ini?')">
                                                    <button type="submit" class="text-orange-600 hover:text-orange-800 text-xs font-medium px-3 py-1.5 rounded hover:bg-orange-50 transition">Reset PW</button>
                                                </form>
