                        <form action="/admin-mace/upload-data" method="POST" enctype="multipart/form-data" class="flex flex-col sm:flex-row gap-4 items-end" onsubmit="return confirm('AMARAN: Ini akan memadamkan (overwrite) keseluruhan database semasa dan menggantikannya dengan data dari fail JSON ini. Pastikan anda mahu meneruskan.')">
