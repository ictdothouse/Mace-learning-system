                <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6">✓ <%= lang === 'en' ? 'Successfully added selected ' + getTerm('student', true).toLowerCase() + ' to group!' : '✓ ' + getTerm('student', true) + ' terpilih berjaya ditambah ke kumpulan!' %></div>
            <% } else if (msg === 'bulk_enrolled') { %>
                <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6">✓ <%= lang === 'en' ? 'Successfully enrolled selected ' + getTerm('student', true).toLowerCase() + ' to group!' : '✓ ' + getTerm('student', true) + ' terpilih berjaya di-enroll ke kumpulan!' %></div>
            <% } else if (msg === 'bulk_removed_from_group') { %>
                <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6">✓ <%= lang === 'en' ? 'Successfully removed selected ' + getTerm('student', true).toLowerCase() + ' from group!' : '✓ ' + getTerm('student', true) + ' terpilih berjaya dikeluarkan dari kumpulan!' %></div>
            <% } else if (msg === 'bulk_deleted') { %>
                <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6">✓ <%= lang === 'en' ? 'Successfully deleted selected ' + getTerm('student', true).toLowerCase() + '!' : '✓ ' + getTerm('student', true) + ' terpilih berjaya dipadam!' %></div>
