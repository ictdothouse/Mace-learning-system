                                    <div>
                                        <label class="block text-xs font-semibold text-gray-600 mb-2 uppercase tracking-wide">EN - Butang Setuju</label>
                                        <input type="text" name="pdpaBtnAgree_en" value="<%= branding.pdpaBtnAgree_en || 'Agree & Continue' %>" class="w-full border border-gray-200 rounded-lg p-2.5 text-sm focus:ring-2 focus:ring-indigo-500 outline-none mb-4">
                                        <label class="block text-xs font-semibold text-gray-600 mb-2 uppercase tracking-wide">EN - Butang Batal</label>
                                        <input type="text" name="pdpaBtnCancel_en" value="<%= branding.pdpaBtnCancel_en || 'Cancel' %>" class="w-full border border-gray-200 rounded-lg p-2.5 text-sm focus:ring-2 focus:ring-indigo-500 outline-none">
                                    </div>
                                </div>
