                <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6"><%= lang === 'en' ? '✗ Error performing bulk action.' : '✗ Ralat semasa menjalankan tindakan pukal.' %></div>
