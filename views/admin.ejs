                    <div class="flex items-center gap-2 text-sm font-bold text-blue-800 whitespace-nowrap">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
                        <span id="selectedCount">0</span> <%= lang === 'en' ? 'students selected' : 'pelajar dipilih' %>
                    </div>

                    <div class="flex flex-wrap gap-2 flex-1">
                        <!-- Add to Group -->
                        <form id="bulkAddGroupForm" action="/admin-mace/students/bulk/add-to-group?lang=<%= lang %>" method="POST" class="flex items-center gap-1">
                            <div id="bulkAddGroupHiddenInputs"></div>
                            <select name="groupId" required class="text-xs border border-gray-300 rounded-lg px-2 py-1.5 bg-white focus:ring-2 focus:ring-blue-500 outline-none text-gray-700">
                                <option value=""><%= lang === 'en' ? 'Select Group...' : 'Pilih Kumpulan...' %></option>
                                <% groups.forEach(g => { %>
                                    <option value="<%= g._id %>"><%= g.name %></option>
                                 <% }) %>
                            </select>
                            <button type="submit" class="bg-green-600 hover:bg-green-700 text-white text-xs px-3 py-1.5 rounded-lg font-medium transition whitespace-nowrap"><%= lang === 'en' ? '+ Add' : '+ Tambah' %></button>
                        </form>

                        <!-- Enroll by Key -->
                        <form id="bulkEnrollKeyForm" action="/admin-mace/students/bulk/enroll-by-key?lang=<%= lang %>" method="POST" class="flex items-center gap-1">
                            <div id="bulkEnrollKeyHiddenInputs"></div>
                            <input type="text" name="enrollmentKey" placeholder="<%= lang === 'en' ? 'Enrollment Key...' : 'Enrollment Key...' %>" required class="text-xs border border-gray-300 rounded-lg px-2 py-1.5 w-32 bg-white focus:ring-2 focus:ring-blue-500 outline-none text-gray-700">
                            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white text-xs px-3 py-1.5 rounded-lg font-medium transition whitespace-nowrap">🔑 Enroll</button>
                        </form>

                        <!-- Remove from Group -->
                        <form id="bulkRemoveGroupForm" action="/admin-mace/students/bulk/remove-from-group?lang=<%= lang %>" method="POST" class="flex items-center gap-1">
                            <div id="bulkRemoveGroupHiddenInputs"></div>
                            <select name="groupId" required class="text-xs border border-gray-300 rounded-lg px-2 py-1.5 bg-white focus:ring-2 focus:ring-blue-500 outline-none text-gray-700">
                                <option value=""><%= lang === 'en' ? 'Select Group...' : 'Pilih Kumpulan...' %></option>
                                <% groups.forEach(g => { %>
                                    <option value="<%= g._id %>"><%= g.name %></option>
                                 <% }) %>
                            </select>
                            <button type="submit" class="bg-orange-500 hover:bg-orange-600 text-white text-xs px-3 py-1.5 rounded-lg font-medium transition whitespace-nowrap"><%= lang === 'en' ? '− Remove' : '− Keluarkan' %></button>
                        </form>

                        <!-- Bulk Delete -->
                        <form id="bulkDeleteForm" action="/admin-mace/students/bulk/delete?lang=<%= lang %>" method="POST" class="flex items-center" onsubmit="return confirm('<%= lang === 'en' ? 'DELETE all selected students? This action CANNOT BE UNDONE!' : 'PADAM semua pelajar terpilih? Tindakan ini TIDAK BOLEH DIUNDUR!' %>')">
                            <div id="bulkDeleteHiddenInputs"></div>
                            <button type="submit" class="bg-red-600 hover:bg-red-700 text-white text-xs px-3 py-1.5 rounded-lg font-medium transition whitespace-nowrap"><%= lang === 'en' ? '🗑 Delete Selected' : '🗑 Padam Terpilih' %></button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-sm text-left">
                        <thead class="text-xs text-gray-500 uppercase bg-gray-50 border-b border-gray-100">
                            <tr>
                                <th class="px-4 py-4 w-10">
                                    <input type="checkbox" id="selectAllStudents" class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500 cursor-pointer">
                                </th>
                                <th class="px-6 py-4"><%= lang === 'en' ? 'Name' : 'Nama' %></th>
                                <th class="px-6 py-4">Email</th>
                                <th class="px-6 py-4"><%= lang === 'en' ? 'Group' : 'Kumpulan' %></th>
                                <th class="px-6 py-4"><%= lang === 'en' ? 'Registration Date' : 'Tarikh Daftar' %></th>
                                <th class="px-6 py-4 text-right"><%= lang === 'en' ? 'Actions' : 'Tindakan' %></th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            <% if (students && students.length > 0) { %>
                                <% students.forEach(s => { %>
                                    <tr class="hover:bg-blue-50/30 transition student-row">
                                        <td class="px-4 py-4">
                                            <input type="checkbox" class="student-checkbox w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500 cursor-pointer" value="<%= s._id %>" data-name="<%= s.fullName %>">
                                        </td>
                                        <td class="px-6 py-4 font-medium text-gray-900">
                                            <%= s.fullName %>
                                            <% if (s.athleteData) { %>
                                                <span class="text-gray-400 text-xs ml-2">(<%= lang === 'en' ? 'Athlete' : 'Atlet' %>)</span>
                                            <% } %>
                                        </td>
                                        <td class="px-6 py-4 text-gray-600"><%= s.email %></td>
                                        <td class="px-6 py-4">
                                            <% if (s.enrolledGroups && s.enrolledGroups.length > 0) { %>
                                                <% s.enrolledGroups.forEach(g => { %>
                                                    <span class="bg-blue-100 text-blue-700 px-2 py-1 rounded text-xs font-bold mr-1"><%= g.name %></span>
                                                <% }); %>
                                            <% } else { %>
                                                <span class="text-gray-400 text-xs"><%= lang === 'en' ? 'None' : 'Tiada' %></span>
                                            <% } %>
                                        </td>
                                        <td class="px-6 py-4 text-gray-500"><%= new Date(s.createdAt).toLocaleDateString(lang === 'en' ? 'en-US' : 'ms-MY') %></td>
                                        <td class="px-6 py-4 text-right">
                                            <div class="flex items-center justify-end gap-2">
                                                <a href="/admin-mace/students/edit/<%= s._id %>?lang=<%= lang %>" class="text-blue-600 hover:text-blue-800 text-xs font-medium px-3 py-1.5 rounded hover:bg-blue-50 transition">Edit</a>
                                                <% if (s.isUserAccount) { %>
                                                <form action="/admin-mace/students/reset-password/<%= s._id %>?lang=<%= lang %>" method="POST" class="inline" onsubmit="return confirm('<%= lang === 'en' ? 'Reset password for this student?' : 'Reset password untuk pelajar ini?' %>')">
                                                    <button type="submit" class="text-orange-600 hover:text-orange-800 text-xs font-medium px-3 py-1.5 rounded hover:bg-orange-50 transition">Reset PW</button>
                                                </form>
                                                <% } %>
                                                <form action="/admin-mace/students/delete/<%= s._id %>?lang=<%= lang %>" method="POST" class="inline" onsubmit="return confirm('<%= lang === 'en' ? 'DELETE this student\'s account? This action cannot be undone.' : 'PADAM akaun pelajar ini? Tindakan tidak boleh undur.' %>')">
                                                    <button type="submit" class="text-red-600 hover:text-red-800 text-xs font-medium px-3 py-1.5 rounded hover:bg-red-50 transition"><%= lang === 'en' ? 'Delete' : 'Padam' %></button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="6" class="px-6 py-12 text-center text-gray-400 italic"><%= lang === 'en' ? 'No students registered yet.' : 'Tiada pelajar berdaftar lagi.' %></td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Bulk Actions JavaScript -->
            <script>
            (function() {
                const selectAll = document.getElementById('selectAllStudents');
                const checkboxes = document.querySelectorAll('.student-checkbox');
                const toolbar = document.getElementById('bulkActionsToolbar');
                const countEl = document.getElementById('selectedCount');

                function getSelectedIds() {
                    return Array.from(checkboxes).filter(cb => cb.checked).map(cb => cb.value);
                }

                function updateToolbar() {
                    const selected = getSelectedIds();
                    const count = selected.length;
                    countEl.textContent = count;

                    if (count > 0) {
                        toolbar.classList.remove('hidden');
                    } else {
                        toolbar.classList.add('hidden');
                    }

                    // Update hidden inputs in all bulk forms
                    ['bulkAddGroupHiddenInputs', 'bulkEnrollKeyHiddenInputs', 'bulkRemoveGroupHiddenInputs', 'bulkDeleteHiddenInputs'].forEach(containerId => {
                        const container = document.getElementById(containerId);
                        container.innerHTML = '';
                        selected.forEach(id => {
                            const input = document.createElement('input');
                            input.type = 'hidden';
                            input.name = 'studentIds';
                            input.value = id;
                            container.appendChild(input);
                        });
                    });

                    // Update selectAll state
                    if (checkboxes.length > 0) {
                        selectAll.checked = count === checkboxes.length;
                        selectAll.indeterminate = count > 0 && count < checkboxes.length;
                    }
                }

                selectAll.addEventListener('change', function() {
                    checkboxes.forEach(cb => { cb.checked = this.checked; });
                    updateToolbar();
                });

                checkboxes.forEach(cb => {
                    cb.addEventListener('change', updateToolbar);
                });
            })();
            </script>
        <% } %>

