                                <tr>
                                    <td colspan="4" class="px-6 py-12 text-center text-gray-400 italic">Tiada guru berdaftar lagi.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        <% } %>

