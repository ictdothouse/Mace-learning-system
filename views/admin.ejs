                            plugins: 'link lists emoticons charmap table code wordcount',
                            toolbar: 'undo redo | blocks fontsize | bold italic underline forecolor | alignleft aligncenter alignright | numlist bullist | table link emoticons | code',
                            menubar: false,
                            promotion: false,
                            branding: false,
                            content_style: 'body { font-family: "Plus Jakarta Sans", sans-serif; font-size: 14px; }'
                        });

                        let menuLinks = <%- JSON.stringify(branding.menuLinks || [
                            { label: 'Home', label_en: 'Home', url: '/' },
                            { label: 'Modul', label_en: 'Modules', url: '/#modul' },
                            { label: 'Hubungi Kami', label_en: 'Contact Us', url: '/#kontak' },
                            { label: 'Akaun', label_en: 'Account', url: '/dashboard' }
                        ]) %>;

                        function renderMenuLinks() {
                            const container = document.getElementById('menu-links-container');
                            container.innerHTML = '';
                            menuLinks.forEach((link, idx) => {
                                container.innerHTML += `
                                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-2 bg-white p-3 rounded-lg border border-gray-200 shadow-sm mb-2">
                                        <div>
                                            <label class="block text-[10px] text-gray-500 font-semibold mb-1">Label (BM)</label>
                                            <input type="text" value="${link.label || ''}" onchange="updateMenu(${idx}, 'label', this.value)" class="w-full text-xs border border-gray-200 rounded p-1.5 focus:border-purple-500 outline-none" placeholder="cth: Modul">
                                        </div>
                                        <div>
                                            <label class="block text-[10px] text-gray-500 font-semibold mb-1">Label (EN)</label>
                                            <input type="text" value="${link.label_en || ''}" onchange="updateMenu(${idx}, 'label_en', this.value)" class="w-full text-xs border border-gray-200 rounded p-1.5 focus:border-purple-500 outline-none" placeholder="cth: Modules">
                                        </div>
                                        <div class="flex items-end gap-2">
                                            <div class="flex-1">
                                                <label class="block text-[10px] text-gray-500 font-semibold mb-1">Pautan URL</label>
                                                <input type="text" value="${link.url || ''}" onchange="updateMenu(${idx}, 'url', this.value)" class="w-full text-xs border border-gray-200 rounded p-1.5 text-blue-600 font-mono focus:border-purple-500 outline-none" placeholder="cth: /#modul">
                                            </div>
                                            <button type="button" onclick="removeMenu(${idx})" class="bg-red-50 hover:bg-red-100 text-red-500 rounded p-2 mb-[2px]">✕</button>
                                        </div>
                                    </div>
                                `;
                            });
                        }
                        
                        function updateMenu(idx, field, val) { menuLinks[idx][field] = val; }
                        function addMenuLink() { menuLinks.push({ label: 'Menu Baru', label_en: 'New Menu', url: '#' }); renderMenuLinks(); }
                        function removeMenu(idx) { menuLinks.splice(idx, 1); renderMenuLinks(); }
                        function saveMenuLinks() { document.getElementById('menuLinksJson').value = JSON.stringify(menuLinks); }
                        
                        let footerLinks = <%- JSON.stringify(branding.footerLinks || []) %>;
                        function renderFooterLinks() {
                            const container = document.getElementById('footer-links-container');
                            container.innerHTML = '';
                            footerLinks.forEach((link, idx) => {
                                container.innerHTML += `
                                    <div class="flex items-center gap-3 bg-white p-2 rounded border border-gray-200">
                                        <input type="text" value="${link.label}" onchange="updateFooter(${idx}, 'label', this.value)" class="flex-1 text-sm border-none bg-transparent outline-none p-1" placeholder="Label Menu">
                                        <input type="text" value="${link.url}" onchange="updateFooter(${idx}, 'url', this.value)" class="flex-2 text-sm border-none bg-transparent outline-none p-1 text-blue-600" placeholder="URL Pautan (cth: https://...)">
                                        <button type="button" onclick="removeFooter(${idx})" class="text-red-500 hover:text-red-700 p-1">✕</button>
                                    </div>
                                `;
                            });
                        }
                        function updateFooter(idx, field, val) { footerLinks[idx][field] = val; }
                        function addFooterLink() { footerLinks.push({ label: 'Link Baru', url: '#' }); renderFooterLinks(); }
                        function removeFooter(idx) { footerLinks.splice(idx, 1); renderFooterLinks(); }
                        function saveFooterLinks() { document.getElementById('footerLinksJson').value = JSON.stringify(footerLinks); }
                        
                        async function migrateMedia(type) {
                            const isOnload = type === 'onload';
                            const title = isOnload ? "Muat Turun ke Pelayan Tempatan (Onload)" : "Muat Naik ke Cloud (Offload)";
                            const warning = isOnload 
                                ? "Amaran: Proses ini akan memuat turun semua media dari Cloud ke VPS anda. Pastikan ruang SSD mencukupi (>50GB). Sistem mungkin mengambil masa beberapa minit."
                                : "Amaran: Proses ini akan memuat naik semua media tempatan ke Cloudflare R2 (R2 Credentials MESTI dikonfigurasi di fail .env).";

                            if (!confirm(title + "\\n\\n" + warning + "\\n\\nTeruskan?")) return;

                            try {
                                alert("Proses migrasi sedang berjalan. Sila tunggu dan biarkan tab ini terbuka. Jangan refresh!");
                                const response = await fetch('/admin-mace/settings/media/' + type, { method: 'POST' });
                                const result = await response.json();
                                if (result.success) {
                                    alert("✅ SELESAI: " + result.message + "\\nSemua tetapan telah berjaya diselaraskan.");
                                } else {
                                    alert("❌ RALAT: " + (result.error || 'Ralat pelayan.'));
                                }
                            } catch (e) {
                                alert("❌ RALAT RANGKAIAN: Sila semak sambungan Internet atau cuba lagi. Proses mungkin tamat masa (timeout).");
                            }
                        }
                        
                        document.addEventListener('DOMContentLoaded', () => { renderMenuLinks(); renderFooterLinks(); });
                    </script>
                    
                    <!-- Script for R2 direct upload -->
                    <script>
                    async function uploadBrandingImage(fileInput, targetInputId, progressId) {
                        const file = fileInput.files[0];
                        if (!file) return;
                        
                        const progressEl = document.getElementById(progressId);
                        progressEl.classList.remove('hidden');
                        progressEl.classList.replace('text-red-600', 'text-blue-600');
                        progressEl.innerHTML = 'Memuat naik... <span class="pct">0%</span>';
                        
                        try {
                            const res = await fetch(`/admin-mace/api/presigned-url?filename=${encodeURIComponent(file.name)}&contentType=${encodeURIComponent(file.type)}`);
                            const data = await res.json();
                            
                            if (data.isR2) {
                                const xhr = new XMLHttpRequest();
                                xhr.open('PUT', data.uploadUrl, true);
                                xhr.setRequestHeader('Content-Type', file.type);
                                
                                xhr.upload.onprogress = (e) => {
                                    if (e.lengthComputable) {
                                        const pct = Math.round((e.loaded / e.total) * 100);
                                        progressEl.querySelector('.pct').textContent = pct + '%';
                                    }
                                };
                                
                                xhr.onload = () => {
                                    if (xhr.status === 200) {
                                        document.getElementById(targetInputId).value = data.publicUrl;
                                        progressEl.textContent = '✅ Berjaya!';
                                    } else {
                                        progressEl.textContent = '❌ Ralat upload R2';
                                        progressEl.classList.replace('text-blue-600', 'text-red-600');
                                    }
                                };
                                
                                xhr.send(file);
                            } else {
                                const formData = new FormData();
                                formData.append('file', file);
                                formData.append('fileKey', data.fileKey);
                                
                                const xhr = new XMLHttpRequest();
                                xhr.open('POST', data.uploadUrl, true);
                                
                                xhr.upload.onprogress = (e) => {
                                    if (e.lengthComputable) {
                                        const pct = Math.round((e.loaded / e.total) * 100);
                                        progressEl.querySelector('.pct').textContent = pct + '%';
                                    }
                                };
                                
                                xhr.onload = () => {
                                    if (xhr.status === 200) {
                                        const result = JSON.parse(xhr.responseText);
                                        document.getElementById(targetInputId).value = result.url;
                                        progressEl.textContent = '✅ Berjaya (Lokal)!';
                                    } else {
                                        progressEl.textContent = '❌ Ralat upload lokal';
                                    }
                                };
                                
                                xhr.send(formData);
                            }
                        } catch (err) {
                            console.error('Upload Error:', err);
                            progressEl.textContent = '❌ Ralat sistem';
                        }
                    }
                    </script>
                <% } %>

