            <% } else if (msg === 'group_deleted') { %>
                <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6">Kumpulan berjaya dipadam!</div>
            <% } else if (msg === 'key_reset') { %>
                <div class="bg-blue-50 border border-blue-200 text-blue-700 px-4 py-3 rounded-lg mb-6">Enrollment key baru: <strong><%= newKey %></strong></div>
            <% } %>

            <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-sm text-left">
                        <thead class="text-xs text-gray-500 uppercase bg-gray-50 border-b border-gray-100">
                            <tr>
                                <th class="px-6 py-4">Nama Kumpulan</th>
                                <th class="px-6 py-4">Enrollment Key</th>
                                <th class="px-6 py-4">Modul Diberikan</th>
                                <th class="px-6 py-4">Bilangan Pelajar</th>
                                <th class="px-6 py-4 text-right">Tindakan</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            <% if (groups && groups.length > 0) { %>
                                <% groups.forEach(g => { %>
                                    <tr class="hover:bg-blue-50/30 transition">
                                        <td class="px-6 py-4 font-medium text-gray-900"><%= g.name %></td>
                                        <td class="px-6 py-4">
                                            <code class="bg-gray-100 px-2 py-1 rounded text-sm font-mono text-blue-600"><%= g.enrollmentKey %></code>
                                        </td>
                                        <td class="px-6 py-4">
                                            <% if (g.modules && g.modules.length > 0) { %>
                                                <span class="text-xs text-gray-600"><%= g.modules.length %> modul</span>
                                            <% } else { %>
                                                <span class="text-gray-400 text-xs">Tiada</span>
                                            <% } %>
                                        </td>
                                        <td class="px-6 py-4 text-gray-500"><%= g.studentCount || 0 %></td>
                                        <td class="px-6 py-4 text-right">
                                            <div class="flex items-center justify-end gap-2">
                                                <a href="/admin-mace/groups/edit/<%= g._id %>" class="text-blue-600 hover:text-blue-800 text-xs font-medium px-3 py-1.5 rounded hover:bg-blue-50 transition">Edit</a>
                                                <form action="/admin-mace/groups/reset-key/<%= g._id %>" method="POST" class="inline" onsubmit="return confirm('Reset enrollment key? Key lama tidak akan berfungsi.')">
                                                    <button type="submit" class="text-orange-600 hover:text-orange-800 text-xs font-medium px-3 py-1.5 rounded hover:bg-orange-50 transition">Reset Key</button>
                                                </form>
                                                <form action="/admin-mace/groups/delete/<%= g._id %>" method="POST" class="inline" onsubmit="return confirm('PADAM kumpulan ini?')">
                                                    <button type="submit" class="text-red-600 hover:text-red-800 text-xs font-medium px-3 py-1.5 rounded hover:bg-red-50 transition">Padam</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" class="px-6 py-12 text-center text-gray-400 italic">Tiada kumpulan lagi.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        <% } %>


        <!-- Footer -->
        <div class="text-center text-xs text-gray-400 py-8 mt-8 border-t border-gray-200">
            &copy; 2026 Majlis Sukan Negara Malaysia. Sistem eLearning Atlit SUKMA v2.0
        </div>
    </main>
</body>
</html>