                            height: 250,
                            plugins: 'link lists textcolor',
                            toolbar: 'undo redo | bold italic | forecolor | alignleft aligncenter alignright | bullist numlist | link',
                            menubar: false,
                            branding: false
                        });

                        let menuLinks = <%- JSON.stringify(branding.menuLinks || [
                            { label: 'Home', url: '/' },
                            { label: 'Modul', url: '/#modul' },
                            { label: 'Hubungi Kami', url: '/#kontak' },
                            { label: 'Akaun', url: '/dashboard' }
                        ]) %>;

                        function renderMenuLinks() {
                            const container = document.getElementById('menu-links-container');
                            container.innerHTML = '';
                            menuLinks.forEach((link, idx) => {
                                container.innerHTML += `
                                    <div class="flex items-center gap-3 bg-white p-2 rounded border border-gray-200">
                                        <input type="text" value="${link.label}" onchange="updateMenu(${idx}, 'label', this.value)" class="flex-1 text-sm border-none bg-transparent outline-none p-1" placeholder="Label Menu">
                                        <input type="text" value="${link.url}" onchange="updateMenu(${idx}, 'url', this.value)" class="flex-2 text-sm border-none bg-transparent outline-none p-1 text-blue-600" placeholder="URL Pautan (cth: https://...)">
                                        <button type="button" onclick="removeMenu(${idx})" class="text-red-500 hover:text-red-700 p-1">✕</button>
                                    </div>
                                `;
                            });
                        }
                        
                        function updateMenu(idx, field, val) { menuLinks[idx][field] = val; }
                        function addMenuLink() { menuLinks.push({ label: 'Menu Baru', url: '#' }); renderMenuLinks(); }
                        function removeMenu(idx) { menuLinks.splice(idx, 1); renderMenuLinks(); }
                        function saveMenuLinks() { document.getElementById('menuLinksJson').value = JSON.stringify(menuLinks); }
                        
                        document.addEventListener('DOMContentLoaded', renderMenuLinks);
                    </script>
                    
                    <!-- Script for R2 direct upload -->
                    <script>
                    async function uploadBrandingImage(fileInput, targetInputId, progressId) {
                        const file = fileInput.files[0];
                        if (!file) return;
                        
                        const progressEl = document.getElementById(progressId);
                        progressEl.classList.remove('hidden');
                        progressEl.classList.replace('text-red-600', 'text-blue-600');
                        progressEl.innerHTML = 'Memuat naik... <span class="pct">0%</span>';
                        
                        try {
                            const res = await fetch(`/admin-mace/api/presigned-url?filename=${encodeURIComponent(file.name)}&contentType=${encodeURIComponent(file.type)}`);
                            const data = await res.json();
                            
                            if (data.isR2) {
                                const xhr = new XMLHttpRequest();
                                xhr.open('PUT', data.uploadUrl, true);
                                xhr.setRequestHeader('Content-Type', file.type);
                                
                                xhr.upload.onprogress = (e) => {
                                    if (e.lengthComputable) {
                                        const pct = Math.round((e.loaded / e.total) * 100);
                                        progressEl.querySelector('.pct').textContent = pct + '%';
                                    }
                                };
                                
                                xhr.onload = () => {
                                    if (xhr.status === 200) {
                                        document.getElementById(targetInputId).value = data.publicUrl;
                                        progressEl.textContent = '✅ Berjaya!';
                                    } else {
                                        progressEl.textContent = '❌ Ralat upload R2';
                                        progressEl.classList.replace('text-blue-600', 'text-red-600');
                                    }
                                };
                                
                                xhr.send(file);
                            } else {
                                const formData = new FormData();
                                formData.append('file', file);
                                formData.append('fileKey', data.fileKey);
                                
                                const xhr = new XMLHttpRequest();
                                xhr.open('POST', data.uploadUrl, true);
                                
                                xhr.upload.onprogress = (e) => {
                                    if (e.lengthComputable) {
                                        const pct = Math.round((e.loaded / e.total) * 100);
                                        progressEl.querySelector('.pct').textContent = pct + '%';
                                    }
                                };
                                
                                xhr.onload = () => {
                                    if (xhr.status === 200) {
                                        const result = JSON.parse(xhr.responseText);
                                        document.getElementById(targetInputId).value = result.url;
                                        progressEl.textContent = '✅ Berjaya (Lokal)!';
                                    } else {
                                        progressEl.textContent = '❌ Ralat upload lokal';
                                    }
                                };
                                
                                xhr.send(formData);
                            }
                        } catch (err) {
                            console.error('Upload Error:', err);
                            progressEl.textContent = '❌ Ralat sistem';
                        }
                    }
                    </script>
                <% } %>
            </div>
        <% } %>

