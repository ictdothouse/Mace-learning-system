                    <div>
                        <h2 class="text-2xl font-bold text-gray-900 mb-2">📄 Pengurusan Laman CMS</h2>
                        <p class="text-gray-500">Daftar, edit, atau padam halaman tersuai dan uruskan menu navigasi awam.</p>
                    </div>
                    <button onclick="openPageModal()" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg font-medium transition flex items-center gap-2 shadow-sm">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                        Cipta Halaman Baru
                    </button>
                </div>

                <!-- Notifikasi Mesej -->
                <% if (msg) { %>
                    <% if (msg === 'page_created') { %>
                        <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 rounded-r-lg mb-6 shadow-sm">✓ Halaman berjaya dicipta!</div>
                    <% } else if (msg === 'page_updated') { %>
                        <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 rounded-r-lg mb-6">✓ Halaman berjaya dikemaskini!</div>
                    <% } else if (msg === 'page_deleted') { %>
                        <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 rounded-r-lg mb-6">🗑️ Halaman berjaya dipadam.</div>
                    <% } else if (msg === 'slug_exists') { %>
                        <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 rounded-r-lg mb-6">❌ Slug/Url halaman ini telah digunakan. Sila guna slug lain.</div>
                    <% } else { %>
                        <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 rounded-r-lg mb-6">❌ Berlaku ralat. Sila cuba lagi.</div>
                    <% } %>
                <% } %>

                <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="bg-gray-50/50 border-b border-gray-100 text-xs font-bold text-gray-500 uppercase tracking-wider">
                                    <th class="px-6 py-4">Nama Halaman</th>
                                    <th class="px-6 py-4">Slug / Url</th>
                                    <th class="px-6 py-4">Template</th>
                                    <th class="px-6 py-4">Tunjuk di Menu</th>
                                    <th class="px-6 py-4">Susunan Menu</th>
                                    <th class="px-6 py-4">Status</th>
                                    <th class="px-6 py-4 text-right">Tindakan</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-100 text-sm text-gray-700">
                                <% if (pages && pages.length > 0) { %>
                                    <% pages.forEach(p => { %>
                                        <tr class="hover:bg-gray-50/30 transition-colors">
                                            <td class="px-6 py-4 font-semibold text-gray-900"><%= p.title %></td>
                                            <td class="px-6 py-4 font-mono text-xs text-blue-600">/page/<%= p.slug %></td>
                                            <td class="px-6 py-4">
                                                <span class="px-2 py-1 rounded text-xs <%= p.customTemplate === 'modules' ? 'bg-purple-50 text-purple-700 font-semibold' : 'bg-gray-100 text-gray-700' %>">
                                                    <%= p.customTemplate === 'modules' ? 'Template Modul' : 'Default' %>
                                                </span>
                                            </td>
                                            <td class="px-6 py-4">
                                                <%= p.showInNavigation ? 'Ya' : 'Tidak' %>
                                            </td>
                                            <td class="px-6 py-4 font-medium"><%= p.navigationOrder %></td>
                                            <td class="px-6 py-4">
                                                <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium <%= p.isPublished ? 'bg-green-100 text-green-800' : 'bg-yellow-100 text-yellow-800' %>">
                                                    <%= p.isPublished ? 'Published' : 'Draft' %>
                                                </span>
                                            </td>
                                            <td class="px-6 py-4 text-right flex justify-end gap-2 border-none">
                                                <button onclick="editPage('<%= p._id %>', '<%= escape(JSON.stringify(p)) %>')" class="bg-blue-50 text-blue-600 px-3 py-1.5 rounded-lg text-xs font-medium hover:bg-blue-100 transition">Edit</button>
                                                <% if (p.slug !== 'modul') { %>
                                                    <form action="/admin-mace/pages/delete/<%= p._id %>" method="POST" onsubmit="return confirm('Adakah anda pasti mahu memadam halaman ini?')" class="inline">
                                                        <button type="submit" class="bg-red-50 text-red-600 px-3 py-1.5 rounded-lg text-xs font-medium hover:bg-red-100 transition">Padam</button>
                                                    </form>
                                                <% } %>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="7" class="px-6 py-8 text-center text-gray-500 italic">Tiada halaman CMS ditemui.</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Modal Cipta / Edit Page -->
            <div id="pageModal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50 overflow-y-auto">
                <div class="bg-white rounded-xl shadow-2xl max-w-5xl w-full mx-4 my-8 max-h-[90vh] overflow-y-auto">
                    <div class="p-6 border-b border-gray-200 flex justify-between items-center sticky top-0 bg-white z-10">
                        <h3 id="modalTitle" class="text-xl font-bold text-gray-900">Cipta Halaman Baru</h3>
                        <button onclick="closePageModal()" class="text-gray-400 hover:text-gray-600 text-2xl">&times;</button>
                    </div>
                    <form id="pageForm" method="POST" class="p-6 space-y-6">
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Tajuk Halaman (BM)</label>
                                <input type="text" name="title" id="page_title" required class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Tajuk Halaman (EN)</label>
                                <input type="text" name="title_en" id="page_title_en" required class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Slug / URL Halaman (Huruf kecil, cth: modul)</label>
                                <input type="text" name="slug" id="page_slug" required class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none">
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Custom Template</label>
                                <select name="customTemplate" id="page_template" class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none bg-white">
                                    <option value="default">Default (HTML Content)</option>
                                    <option value="modules">Template Modul (My Athlete Modules Grid)</option>
                                    <option value="contact">Template Hubungi Kami (Contact Us Page)</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Susunan Navigasi</label>
                                <input type="number" name="navigationOrder" id="page_nav_order" value="0" class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none">
                            </div>
                            <div class="flex items-center gap-6 pt-6">
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="checkbox" name="showInNavigation" id="page_show_nav" checked class="w-4 h-4 text-blue-600 rounded">
                                    <span class="text-sm font-medium text-gray-700">Tunjuk di Menu</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="checkbox" name="isPublished" id="page_published" checked class="w-4 h-4 text-blue-600 rounded">
                                    <span class="text-sm font-medium text-gray-700">Published</span>
                                </label>
                            </div>
                        </div>

                        <!-- CUSTOMIZABLE CARDS FOR MODULES TEMPLATE -->
                        <div id="modulesConfigSection" class="hidden space-y-6">
                            <h4 class="text-sm font-bold text-gray-700 border-b pb-2 uppercase">Konfigurasi Kad Modul (Akan Datang)</h4>
                            <input type="hidden" name="modulesConfigJson" id="modulesConfigJson">
                            
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <% for (let i = 2; i <= 5; i++) { %>
                                    <div class="border border-gray-200 rounded-xl p-4 bg-gray-50/50 space-y-4">
                                        <h5 class="font-bold text-xs text-blue-600 uppercase">Kad Modul <%= i %></h5>
                                        <div>
                                            <label class="block text-xs font-semibold text-gray-500 mb-1">Tajuk Kad</label>
                                            <input type="text" id="card_title_<%= i %>" class="w-full text-xs border border-gray-300 rounded-lg p-2 outline-none card-config-input" data-card-idx="<%= i - 2 %>" data-field="title">
                                        </div>
                                        <div>
                                            <label class="block text-xs font-semibold text-gray-500 mb-1">Label Status / Subtajuk</label>
                                            <input type="text" id="card_status_<%= i %>" class="w-full text-xs border border-gray-300 rounded-lg p-2 outline-none card-config-input" data-card-idx="<%= i - 2 %>" data-field="statusText">
                                        </div>
                                        <div>
                                            <label class="block text-xs font-semibold text-gray-500 mb-1">Gambar Kad (Thumbnail)</label>
                                            <div class="flex items-center gap-3">
                                                <img id="card_preview_<%= i %>" src="https://images.unsplash.com/photo-1517649763962-0c623066013b?q=80&w=600&auto=format&fit=crop" class="w-16 h-10 object-cover rounded border border-gray-200 bg-white">
                                                <div class="flex-grow space-y-1">
                                                    <!-- hidden field for image URL -->
                                                    <input type="hidden" id="card_url_<%= i %>" class="card-config-input" data-card-idx="<%= i - 2 %>" data-field="imageUrl">
                                                    
                                                    <!-- File upload helper input -->
                                                    <input type="file" id="card_file_<%= i %>" onchange="uploadCardImage(<%= i %>)" class="hidden">
                                                    <button type="button" onclick="document.getElementById('card_file_<%= i %>').click()" class="text-xs bg-white border border-gray-300 text-gray-700 px-3 py-1.5 rounded-lg hover:bg-gray-50 font-medium transition">
                                                        Muat Naik Fail Gambar
                                                    </button>
                                                    <div id="card_uploading_<%= i %>" class="text-xs text-blue-500 hidden animate-pulse font-medium">Memuat naik...</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                <% } %>
                            </div>
                        </div>

                        <!-- CUSTOMIZABLE FIELDS FOR CONTACT TEMPLATE -->
                        <div id="contactConfigSection" class="hidden space-y-6">
                            <h4 class="text-sm font-bold text-gray-700 border-b pb-2 uppercase font-semibold">Konfigurasi Laman Hubungi Kami</h4>
                            
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">Tajuk Banner Atas</label>
                                    <input type="text" name="contact_bannerTitle" id="contact_bannerTitle" class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none">
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">Pautan Email Hubungi</label>
                                    <input type="text" name="contact_email" id="contact_email" class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none">
                                </div>
                            </div>
                            
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Teks Keterangan / Deskripsi</label>
                                <textarea name="contact_description" id="contact_description" rows="3" class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none"></textarea>
                            </div>
                            
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="border border-gray-200 rounded-xl p-4 bg-gray-50/50 space-y-3">
                                    <label class="block text-xs font-semibold text-gray-500 mb-1 uppercase">Gambar Latar Belakang Banner (Stadium/Atlet)</label>
                                    <div class="flex items-center gap-3">
                                        <img id="contact_bannerPreview" src="https://images.unsplash.com/photo-1540747737956-37872f747802?q=80&w=1200&auto=format&fit=crop" class="w-20 h-10 object-cover rounded border border-gray-200 bg-white">
                                        <div class="flex-grow">
                                            <input type="hidden" name="contact_bannerImage" id="contact_bannerImage">
                                            <input type="file" id="contact_bannerFile" onchange="uploadContactImage('banner')" class="hidden">
                                            <button type="button" onclick="document.getElementById('contact_bannerFile').click()" class="text-xs bg-white border border-gray-300 text-gray-700 px-3 py-1.5 rounded-lg hover:bg-gray-50 font-medium transition">Muat Naik Gambar</button>
                                            <div id="contact_bannerUploading" class="text-xs text-blue-500 hidden animate-pulse font-medium">Memuat naik...</div>
                                        </div>
                                    </div>
                                </div>
                                <div class="border border-gray-200 rounded-xl p-4 bg-gray-50/50 space-y-3">
                                    <label class="block text-xs font-semibold text-gray-500 mb-1 uppercase">Gambar Ilustrasi Kanan (Pilihan, Kosongkan untuk Envelopes SVG)</label>
                                    <div class="flex items-center gap-3">
                                        <img id="contact_imagePreview" src="" class="w-20 h-10 object-cover rounded border border-gray-200 bg-white hidden">
                                        <div class="flex-grow">
                                            <input type="hidden" name="contact_imageUrl" id="contact_imageUrl">
                                            <input type="file" id="contact_imageFile" onchange="uploadContactImage('illustration')" class="hidden">
                                            <button type="button" onclick="document.getElementById('contact_imageFile').click()" class="text-xs bg-white border border-gray-300 text-gray-700 px-3 py-1.5 rounded-lg hover:bg-gray-50 font-medium transition">Muat Naik Gambar</button>
                                            <div id="contact_imageUploading" class="text-xs text-blue-500 hidden animate-pulse font-medium">Memuat naik...</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div id="contentEditorSection" class="space-y-6">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Kandungan Halaman (Bahasa Melayu)</label>
                                <textarea id="pageContent" class="w-full h-80 border border-gray-300 rounded-lg outline-none"></textarea>
                                <input type="hidden" name="content" id="page_content_hidden">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Kandungan Halaman (English)</label>
                                <textarea id="pageContentEn" class="w-full h-80 border border-gray-300 rounded-lg outline-none"></textarea>
                                <input type="hidden" name="content_en" id="page_content_en_hidden">
                            </div>
                        </div>

                        <div class="flex justify-end gap-3 pt-6 border-t border-gray-200">
                            <button type="button" onclick="closePageModal()" class="px-6 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition">Batal</button>
                            <button type="submit" class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">Simpan Halaman</button>
                        </div>
                    </form>
                </div>
            </div>

            <script src="https://cdnjs.cloudflare.com/ajax/libs/tinymce/6.8.2/tinymce.min.js"></script>
            <script>
                document.addEventListener('DOMContentLoaded', () => {
                    tinymce.init({
                        selector: '#pageContent, #pageContentEn',
                        height: 350,
                        plugins: 'link lists textcolor code table',
                        toolbar: 'undo redo | bold italic | forecolor | alignleft aligncenter alignright | bullist numlist | link | code table',
                        menubar: false,
                        branding: false
                    });

                    const form = document.getElementById('pageForm');
                    if (form) {
                        form.addEventListener('submit', (e) => {
                            // Sync TinyMCE content to hidden fields
                            document.getElementById('page_content_hidden').value = tinymce.get('pageContent').getContent();
                            document.getElementById('page_content_en_hidden').value = tinymce.get('pageContentEn').getContent();
                            
                            // Serialize card configs if modules template is active
                            if (document.getElementById('page_template').value === 'modules') {
                                serializeModulesConfig();
                            }
                        });
                    }

                    // Hide editor section and show card configs if templates are selected
                    const templateSelect = document.getElementById('page_template');
                    if (templateSelect) {
                        templateSelect.addEventListener('change', () => {
                            const val = templateSelect.value;
                            document.getElementById('contentEditorSection').style.display = val === 'default' ? 'block' : 'none';
                            document.getElementById('modulesConfigSection').style.display = val === 'modules' ? 'block' : 'none';
                            document.getElementById('contactConfigSection').style.display = val === 'contact' ? 'block' : 'none';
                        });
                    }
                });

                function serializeModulesConfig() {
                    const configs = [];
                    for (let i = 2; i <= 5; i++) {
                        configs.push({
                            title: document.getElementById(`card_title_${i}`).value || '',
                            statusText: document.getElementById(`card_status_${i}`).value || '',
                            imageUrl: document.getElementById(`card_url_${i}`).value || ''
                        });
                    }
                    document.getElementById('modulesConfigJson').value = JSON.stringify(configs);
                }

                async function uploadCardImage(idx) {
                    const fileInput = document.getElementById(`card_file_${idx}`);
                    const previewImg = document.getElementById(`card_preview_${idx}`);
                    const hiddenUrlInput = document.getElementById(`card_url_${idx}`);
                    const uploadingMsg = document.getElementById(`card_uploading_${idx}`);
                    
                    if (!fileInput.files || fileInput.files.length === 0) return;
                    
                    const file = fileInput.files[0];
                    const formData = new FormData();
                    formData.append('image', file);
                    
                    uploadingMsg.classList.remove('hidden');
                    
                    try {
                        const response = await fetch('/admin-mace/api/upload-image', {
                            method: 'POST',
                            body: formData
                        });
                        const result = await response.json();
                        
                        if (result.success && result.url) {
                            previewImg.src = result.url;
                            hiddenUrlInput.value = result.url;
                        } else {
                            alert('Gagal memuat naik gambar. Sila cuba lagi.');
                        }
                    } catch (err) {
                        console.error('Error uploading card image:', err);
                        alert('Ralat semasa memuat naik gambar.');
                    } finally {
                        uploadingMsg.classList.add('hidden');
                    }
                }

                async function uploadContactImage(type) {
                    const prefix = type === 'banner' ? 'contact_banner' : 'contact_image';
                    const fileInput = document.getElementById(`${prefix}File`);
                    const previewImg = document.getElementById(`${prefix}Preview`);
                    const hiddenUrlInput = document.getElementById(type === 'banner' ? 'contact_bannerImage' : 'contact_imageUrl');
                    const uploadingMsg = document.getElementById(`${prefix}Uploading`);
                    
                    if (!fileInput.files || fileInput.files.length === 0) return;
                    
                    const file = fileInput.files[0];
                    const formData = new FormData();
                    formData.append('image', file);
                    
                    uploadingMsg.classList.remove('hidden');
                    
                    try {
                        const response = await fetch('/admin-mace/api/upload-image', {
                            method: 'POST',
                            body: formData
                        });
                        const result = await response.json();
                        
                        if (result.success && result.url) {
                            previewImg.src = result.url;
                            previewImg.classList.remove('hidden');
                            hiddenUrlInput.value = result.url;
                        } else {
                            alert('Gagal memuat naik gambar. Sila cuba lagi.');
                        }
                    } catch (err) {
                        console.error('Error uploading contact image:', err);
                        alert('Ralat semasa memuat naik gambar.');
                    } finally {
                        uploadingMsg.classList.add('hidden');
                    }
                }

                function resetCardDefaults() {
                    const defaultImages = [
                        'https://images.unsplash.com/photo-1517649763962-0c623066013b?q=80&w=600&auto=format&fit=crop',
                        'https://images.unsplash.com/photo-1508098682722-e99c43a406b2?q=80&w=600&auto=format&fit=crop',
                        'https://images.unsplash.com/photo-1530541930197-ff16ac917b0e?q=80&w=600&auto=format&fit=crop',
                        'https://images.unsplash.com/photo-1476480862126-209bfaa8edc8?q=80&w=600&auto=format&fit=crop'
                    ];
                    const defaultTitles = ['CAREER BOOST', 'POCKET POWER', 'MODE ON!', 'SMART ATHLETE'];
                    for (let i = 2; i <= 5; i++) {
                        document.getElementById(`card_title_${i}`).value = defaultTitles[i - 2];
                        document.getElementById(`card_status_${i}`).value = 'Akan Datang';
                        document.getElementById(`card_url_${i}`).value = defaultImages[i - 2];
                        document.getElementById(`card_preview_${i}`).src = defaultImages[i - 2];
                    }
                }

                function openPageModal() {
                    const form = document.getElementById('pageForm');
                    form.reset();
                    form.action = '/admin-mace/pages/create';
                    document.getElementById('modalTitle').innerText = 'Cipta Halaman Baru';
                    
                    if (tinymce.get('pageContent')) tinymce.get('pageContent').setContent('');
                    if (tinymce.get('pageContentEn')) tinymce.get('pageContentEn').setContent('');
                    
                    document.getElementById('page_show_nav').checked = true;
                    document.getElementById('page_published').checked = true;
                    document.getElementById('page_title_en').value = '';
                    
                    document.getElementById('contentEditorSection').style.display = 'block';
                    document.getElementById('modulesConfigSection').style.display = 'none';
                    document.getElementById('contactConfigSection').style.display = 'none';
                    
                    // Reset contact defaults
                    document.getElementById('contact_bannerTitle').value = 'Hubungi';
                    document.getElementById('contact_email').value = 'mace@nsc.gov.my';
                    document.getElementById('contact_description').value = 'Sebarang pertanyaan atau maklumbalas, hubungi kami menerusi email :';
                    document.getElementById('contact_bannerImage').value = 'https://images.unsplash.com/photo-1540747737956-37872f747802?q=80&w=1200&auto=format&fit=crop';
                    document.getElementById('contact_bannerPreview').src = 'https://images.unsplash.com/photo-1540747737956-37872f747802?q=80&w=1200&auto=format&fit=crop';
                    document.getElementById('contact_imageUrl').value = '';
                    document.getElementById('contact_imagePreview').src = '';
                    document.getElementById('contact_imagePreview').classList.add('hidden');
                    
                    resetCardDefaults();
                    
                    document.getElementById('pageModal').classList.remove('hidden');
                    document.getElementById('pageModal').classList.add('flex');
                }

                function closePageModal() {
                    document.getElementById('pageModal').classList.add('hidden');
                    document.getElementById('pageModal').classList.remove('flex');
                }

                function editPage(id, jsonStr) {
                    const data = JSON.parse(decodeURIComponent(jsonStr.replace(/&quot;/g, '"')));
                    const form = document.getElementById('pageForm');
                    form.action = '/admin-mace/pages/update/' + id;
                    document.getElementById('modalTitle').innerText = 'Edit Halaman CMS';
                    
                    document.getElementById('page_title').value = data.title || '';
                    document.getElementById('page_title_en').value = data.title_en || '';
                    document.getElementById('page_slug').value = data.slug || '';
                    document.getElementById('page_template').value = data.customTemplate || 'default';
                    document.getElementById('page_nav_order').value = data.navigationOrder || 0;
                    document.getElementById('page_show_nav').checked = data.showInNavigation !== false;
                    document.getElementById('page_published').checked = data.isPublished !== false;
                    
                    // Show or hide text editors depending on template selection
                    const val = data.customTemplate || 'default';
                    document.getElementById('contentEditorSection').style.display = val === 'default' ? 'block' : 'none';
                    document.getElementById('modulesConfigSection').style.display = val === 'modules' ? 'block' : 'none';
                    document.getElementById('contactConfigSection').style.display = val === 'contact' ? 'block' : 'none';
                    
                    // Populate card configs
                    const cardConfigs = data.modulesConfig || [];
                    const defaultImages = [
                        'https://images.unsplash.com/photo-1517649763962-0c623066013b?q=80&w=600&auto=format&fit=crop',
                        'https://images.unsplash.com/photo-1508098682722-e99c43a406b2?q=80&w=600&auto=format&fit=crop',
                        'https://images.unsplash.com/photo-1530541930197-ff16ac917b0e?q=80&w=600&auto=format&fit=crop',
                        'https://images.unsplash.com/photo-1476480862126-209bfaa8edc8?q=80&w=600&auto=format&fit=crop'
                    ];
                    const defaultTitles = ['CAREER BOOST', 'POCKET POWER', 'MODE ON!', 'SMART ATHLETE'];
                    
                    for (let i = 2; i <= 5; i++) {
                        const card = cardConfigs[i - 2] || {};
                        const titleVal = card.title !== undefined ? card.title : defaultTitles[i - 2];
                        const statusVal = card.statusText !== undefined ? card.statusText : 'Akan Datang';
                        const imageVal = card.imageUrl || defaultImages[i - 2];
                        
                        document.getElementById(`card_title_${i}`).value = titleVal;
                        document.getElementById(`card_status_${i}`).value = statusVal;
                        document.getElementById(`card_url_${i}`).value = imageVal;
                        document.getElementById(`card_preview_${i}`).src = imageVal;
                    }
                    
                    // Populate contact configs
                    const contact = data.contactConfig || {};
                    document.getElementById('contact_bannerTitle').value = contact.bannerTitle || 'Hubungi';
                    document.getElementById('contact_email').value = contact.email || 'mace@nsc.gov.my';
                    document.getElementById('contact_description').value = contact.description || 'Sebarang pertanyaan atau maklumbalas, hubungi kami menerusi email :';
                    
                    const bannerImg = contact.bannerImage || 'https://images.unsplash.com/photo-1540747737956-37872f747802?q=80&w=1200&auto=format&fit=crop';
                    document.getElementById('contact_bannerImage').value = bannerImg;
                    document.getElementById('contact_bannerPreview').src = bannerImg;
                    
                    const illusImg = contact.imageUrl || '';
                    document.getElementById('contact_imageUrl').value = illusImg;
                    if (illusImg) {
                        document.getElementById('contact_imagePreview').src = illusImg;
                        document.getElementById('contact_imagePreview').classList.remove('hidden');
                    } else {
                        document.getElementById('contact_imagePreview').src = '';
                        document.getElementById('contact_imagePreview').classList.add('hidden');
                    }
                    
                    if (tinymce.get('pageContent')) tinymce.get('pageContent').setContent(data.content || '');
                    if (tinymce.get('pageContentEn')) tinymce.get('pageContentEn').setContent(data.content_en || '');
                    
                    document.getElementById('pageModal').classList.remove('hidden');
                    document.getElementById('pageModal').classList.add('flex');
                }
            </script>
        <% } %>

        <!-- ========================================== -->
        <!-- HALAMAN: PENGURUSAN PENGGUNA             -->
        <!-- ========================================== -->
        <% if (page === 'users') { %>
            <div class="mb-6 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                <div>
                    <h2 class="text-2xl font-bold text-gray-900">Pengurusan Profil & Akaun</h2>
                    <p class="text-gray-500 text-sm mt-1">Lihat maklumat atlet, kemaskini data login, atau pulihkan akaun bermasalah.</p>
                </div>
            </div>

            <!-- Bar Carian & Penapis -->
            <form action="/admin-mace/users" method="GET" class="bg-white p-4 rounded-xl shadow-sm border border-gray-100 mb-6 flex flex-col md:flex-row gap-4 items-end">
                <div class="flex-1 w-full">
                    <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Cari Nama atau No. IC</label>
                    <input type="text" name="search" value="<%= currentSearch %>" placeholder="Contoh: Ahmad atau 900101..." 
                        class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none transition">
                </div>
                <div class="w-full md:w-48">
                    <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Tapis Mengikut Negeri</label>
                    <select name="state" class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none bg-white">
                        <option value="all" <%= currentState === 'all' ? 'selected' : '' %>>Semua Negeri</option>
                        <% (statesList || []).forEach(s => { %>
                            <option value="<%= s %>" <%= currentState === s ? 'selected' : '' %>><%= s %></option>
                        <% }) %>
                    </select>
                </div>
                <button type="submit" class="w-full md:w-auto bg-blue-600 text-white px-6 py-2 rounded-lg font-medium hover:bg-blue-700 transition shadow-sm">
                    Cari & Tapis
                </button>
            </form>

            <!-- Jadual Profil Atlet -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-sm text-left">
                        <thead class="text-xs text-gray-500 uppercase bg-gray-50 border-b border-gray-100">
                            <tr>
                                <th class="px-6 py-4 w-1/4">Maklumat Peribadi & Login</th>
                                <th class="px-6 py-4">Kemajuan Kursus</th>
                                <th class="px-6 py-4 text-right">Tindakan Admin</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            <% if (athletes && athletes.length > 0) { %>
                                <% athletes.forEach(a => { %>
                                    <tr class="hover:bg-blue-50/30 transition group">
                                        <td class="px-6 py-4 align-top">
                                            <!-- Borang Edit Profil Inline -->
                                            <form action="/admin-mace/athletes/update/<%= a._id %>" method="POST" class="space-y-3">
                                                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                                                    <div>
                                                        <label class="text-[10px] text-gray-400 uppercase font-bold">Nama Penuh (Login)</label>
                                                        <input type="text" name="fullName" value="<%= a.fullName %>" required 
                                                            class="w-full text-sm border border-gray-200 rounded px-2 py-1.5 focus:border-blue-500 outline-none bg-white">
                                                    </div>
                                                    <div>
                                                        <label class="text-[10px] text-gray-400 uppercase font-bold">No. IC (ID Utama)</label>
                                                        <input type="text" name="icNumber" value="<%= a.icNumber %>" required 
                                                            class="w-full text-sm border border-gray-200 rounded px-2 py-1.5 focus:border-blue-500 outline-none font-mono bg-gray-50">
                                                    </div>
                                                </div>
                                                <div class="grid grid-cols-3 gap-3">
                                                    <div>
                                                        <label class="text-[10px] text-gray-400 uppercase font-bold">Jantina</label>
                                                        <select name="jantina" class="w-full text-sm border border-gray-200 rounded px-2 py-1.5 bg-white">
                                                            <option value="Lelaki" <%= a.jantina === 'Lelaki' ? 'selected' : '' %>>Lelaki</option>
                                                            <option value="Perempuan" <%= a.jantina === 'Perempuan' ? 'selected' : '' %>>Perempuan</option>
                                                        </select>
                                                    </div>
                                                    <div>
                                                        <label class="text-[10px] text-gray-400 uppercase font-bold">Umur</label>
                                                        <input type="number" name="umur" value="<%= a.umur %>" min="10" max="60" 
                                                            class="w-full text-sm border border-gray-200 rounded px-2 py-1.5 bg-white">
                                                    </div>
                                                    <div>
                                                        <label class="text-[10px] text-gray-400 uppercase font-bold">Negeri</label>
                                                        <input type="text" name="negeriWakil" value="<%= a.negeriWakil %>" required 
                                                            class="w-full text-sm border border-gray-200 rounded px-2 py-1.5 bg-white">
                                                    </div>
                                                </div>
                                                <div class="pt-2 flex justify-end">
                                                    <button type="submit" class="text-xs bg-gray-800 text-white px-3 py-1.5 rounded hover:bg-black transition opacity-0 group-hover:opacity-100">
                                                        💾 Simpan Perubahan
                                                    </button>
                                                </div>
                                            </form>
                                        </td>
                                        
                                        <td class="px-6 py-4 align-top">
                                            <div class="space-y-2">
                                                <div class="flex items-center justify-between text-xs">
                                                    <span class="text-gray-500">Status Semasa:</span>
                                                    <span class="<%= a.currentStage >= 4 ? 'bg-green-100 text-green-700' : 'bg-blue-100 text-blue-700' %> px-2 py-0.5 rounded-full font-bold">
                                                        <%= a.currentStage >= 4 ? 'SELESAI (LULUS)' : `STAGE ${a.currentStage}` %>
                                                    </span>
                                                </div>
                                                
                                                <!-- Bar Markah Kuiz -->
                                                <div class="grid grid-cols-3 gap-2 mt-3">
                                                    <div class="text-center p-2 rounded bg-gray-50 border border-gray-100">
                                                        <div class="text-[10px] text-gray-400 uppercase">Kuiz 1</div>
                                                        <div class="font-bold <%= a.quizScores?.quiz1 > 0 ? 'text-green-600' : 'text-gray-300' %>"><%= a.quizScores?.quiz1 || '-' %>%</div>
                                                    </div>
                                                    <div class="text-center p-2 rounded bg-gray-50 border border-gray-100">
                                                        <div class="text-[10px] text-gray-400 uppercase">Kuiz 2</div>
                                                        <div class="font-bold <%= a.quizScores?.quiz2 > 0 ? 'text-green-600' : 'text-gray-300' %>"><%= a.quizScores?.quiz2 || '-' %>%</div>
                                                    </div>
                                                    <div class="text-center p-2 rounded bg-gray-50 border border-gray-100">
                                                        <div class="text-[10px] text-gray-400 uppercase">Kuiz 3</div>
                                                        <div class="font-bold <%= a.quizScores?.quiz3 > 0 ? 'text-green-600' : 'text-gray-300' %>"><%= a.quizScores?.quiz3 || '-' %>%</div>
                                                    </div>
                                                </div>
                                                
                                                <% if (a.completedAt) { %>
                                                    <div class="text-[10px] text-gray-400 mt-2 text-right">Selesai pada: <%= new Date(a.completedAt).toLocaleDateString('ms-MY') %></div>
                                                <% } %>
                                            </div>
                                        </td>
                                        
                                        <td class="px-6 py-4 align-top text-right">
                                            <!-- Butang Tindakan untuk Atlet -->
                                            <div class="flex flex-col gap-2">
                                                <!-- Convert to Student -->
                                                <form action="/admin-mace/athletes/convert/<%= a._id %>" method="POST" onsubmit="return confirm('Buat akaun student untuk atlet ini? Password akan dijana secara automatik.')">
                                                    <button type="submit" class="inline-flex items-center gap-1.5 text-xs font-medium text-blue-600 hover:text-blue-800 hover:bg-blue-50 px-3 py-2 rounded-lg transition border border-transparent hover:border-blue-100 w-full justify-center">
                                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" /></svg>
                                                        Buat Akaun Student
                                                    </button>
                                                </form>
                                                <!-- Delete Athlete -->
                                                <form action="/admin-mace/athletes/delete/<%= a._id %>" method="POST" onsubmit="return confirm('PADAM rekod atlet ini? Tindakan tidak boleh undur.')">
                                                    <button type="submit" class="inline-flex items-center gap-1.5 text-xs font-medium text-red-600 hover:text-red-800 hover:bg-red-50 px-3 py-2 rounded-lg transition border border-transparent hover:border-red-100 w-full justify-center">
                                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                                                        Padam Atlet
                                                    </button>
                                                </form>
                                            </div>
                                            <p class="text-[10px] text-gray-400 mt-2 leading-tight">Gunakan 'Buat Akaun Student' untuk benarkan akses e-learning.</p>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="3" class="px-6 py-12 text-center text-gray-400 italic">Tiada rekod atlet dijumpai mengikut carian anda.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        <% } %>
        <!-- ========================================== -->
        <!-- HALAMAN: PENGURUSAN GURU / INSTRUKTOR    -->
        <!-- ========================================== -->
        <% if (page === 'teachers') { %>
            <div class="mb-6 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                <div>
                    <h2 class="text-2xl font-bold text-gray-900">Pengurusan <%= getTerm('teacher') %></h2>
                    <p class="text-gray-500 text-sm mt-1">Daftar, edit, atau padam akaun <%= getTerm('teacher').toLowerCase() %>. <%= getTerm('teacher') %> boleh mencipta modul, lesson, kuiz, dan kumpulan.</p>
                </div>
                <a href="/admin-mace/teachers/new" class="bg-blue-600 text-white px-6 py-2.5 rounded-lg font-medium hover:bg-blue-700 transition shadow-sm flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                    Tambah <%= getTerm('teacher') %> Baru
                </a>
            </div>

            <% if (msg === 'teacher_created') { %>
                <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6"><%= getTerm('teacher') %> berjaya didaftarkan!</div>
            <% } else if (msg === 'teacher_updated') { %>
                <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6">Maklumat <%= getTerm('teacher').toLowerCase() %> dikemaskini!</div>
            <% } else if (msg === 'teacher_deleted') { %>
                <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6"><%= getTerm('teacher') %> berjaya dipadam!</div>
            <% } else if (msg === 'email_exists') { %>
                <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6">❌ E-mel tersebut telah digunakan oleh pengguna lain.</div>
            <% } else if (msg === 'username_exists') { %>
                <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6">❌ Username tersebut telah digunakan oleh pengguna lain.</div>
            <% } else if (msg === 'missing_fields') { %>
                <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6">❌ Sila isi semua ruangan yang wajib.</div>
            <% } else if (msg === 'create_error') { %>
                <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 rounded-r-lg mb-6 shadow-sm flex items-center gap-2 animate-fade-in">❌ Ralat: Gagal menambah guru baru. Sila cuba lagi.</div>
            <% } else if (msg === 'password_reset') { %>
                <div class="bg-blue-50 border border-blue-200 text-blue-700 px-4 py-3 rounded-lg mb-6">Password baru: <strong><%= newPassword %></strong></div>
            <% } %>

            <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-sm text-left">
                        <thead class="text-xs text-gray-500 uppercase bg-gray-50 border-b border-gray-100">
                            <tr>
                                <th class="px-6 py-4">Nama</th>
                                <th class="px-6 py-4">Username</th>
                                <th class="px-6 py-4">Email</th>
                                <th class="px-6 py-4">Tarikh Daftar</th>
                                <th class="px-6 py-4 text-right">Tindakan</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            <% if (teachers && teachers.length > 0) { %>
                                <% teachers.forEach(t => { %>
                                    <tr class="hover:bg-blue-50/30 transition">
                                        <td class="px-6 py-4 font-medium text-gray-900"><%= t.fullName %></td>
                                        <td class="px-6 py-4 text-gray-600 font-mono text-xs"><%= t.username || '-' %></td>
                                        <td class="px-6 py-4 text-gray-600"><%= t.email %></td>
                                        <td class="px-6 py-4 text-gray-500"><%= new Date(t.createdAt).toLocaleDateString('ms-MY') %></td>
                                        <td class="px-6 py-4 text-right">
                                            <div class="flex items-center justify-end gap-2">
                                                <a href="/admin-mace/teachers/edit/<%= t._id %>" class="text-blue-600 hover:text-blue-800 text-xs font-medium px-3 py-1.5 rounded hover:bg-blue-50 transition">Edit</a>
                                                <form action="/admin-mace/teachers/reset-password/<%= t._id %>" method="POST" class="inline" onsubmit="return confirm('Reset password untuk guru ini?')">
                                                    <button type="submit" class="text-orange-600 hover:text-orange-800 text-xs font-medium px-3 py-1.5 rounded hover:bg-orange-50 transition">Reset PW</button>
                                                </form>
                                                <form action="/admin-mace/teachers/delete/<%= t._id %>" method="POST" class="inline" onsubmit="return confirm('PADAM akaun guru ini? Tindakan tidak boleh undur.')">
                                                    <button type="submit" class="text-red-600 hover:text-red-800 text-xs font-medium px-3 py-1.5 rounded hover:bg-red-50 transition">Padam</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" class="px-6 py-12 text-center text-gray-400 italic">Tiada guru berdaftar lagi.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        <% } %>

        <!-- ========================================== -->
        <!-- HALAMAN: PENGURUSAN PELAJAR (STUDENT)    -->
        <!-- ========================================== -->
        <% if (page === 'students') { %>
            <div class="mb-6 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                <div>
                    <h2 class="text-2xl font-bold text-gray-900"><%= lang === 'en' ? getTerm('student') + ' Management' : 'Pengurusan ' + getTerm('student') %></h2>
                    <p class="text-gray-500 text-sm mt-1"><%= lang === 'en' ? 'Manage ' + getTerm('student').toLowerCase() + ' accounts, assign groups, reset password, or delete accounts.' : 'Urus akaun ' + getTerm('student').toLowerCase() + ', tetapkan kumpulan, reset password, atau padam akaun.' %></p>
                </div>
            </div>

            <!-- Filters Form -->
            <form method="GET" action="/admin-mace/students" class="mb-6 bg-white border border-gray-100 rounded-xl p-5 shadow-sm">
                <input type="hidden" name="lang" value="<%= lang %>">
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                    <!-- Negeri Filter -->
                    <div>
                        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2"><%= lang === 'en' ? 'State' : 'Negeri' %></label>
                        <select name="negeri" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm bg-white focus:ring-2 focus:ring-blue-500 outline-none text-gray-700">
                            <option value=""><%= lang === 'en' ? 'All States' : 'Semua Negeri' %></option>
                            <% states.forEach(st => { %>
                                <option value="<%= st %>" <%= filters.negeri === st ? 'selected' : '' %>><%= st %></option>
                            <% }) %>
                        </select>
                    </div>

                    <!-- Kumpulan Filter -->
                    <div>
                        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2"><%= lang === 'en' ? 'Group' : 'Kumpulan' %></label>
                        <select name="groupId" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm bg-white focus:ring-2 focus:ring-blue-500 outline-none text-gray-700">
                            <option value=""><%= lang === 'en' ? 'All Groups' : 'Semua Kumpulan' %></option>
                            <% groups.forEach(g => { %>
                                <option value="<%= g._id %>" <%= filters.groupId === g._id.toString() ? 'selected' : '' %>><%= g.name %></option>
                            <% }) %>
                        </select>
                    </div>

                    <!-- Tarikh Mula -->
                    <div>
                        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2"><%= lang === 'en' ? 'Start Register Date' : 'Tarikh Daftar Mula' %></label>
                        <input type="date" name="startDate" value="<%= filters.startDate %>" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm bg-white focus:ring-2 focus:ring-blue-500 outline-none text-gray-700">
                    </div>

                    <!-- Tarikh Tamat -->
                    <div>
                        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2"><%= lang === 'en' ? 'End Register Date' : 'Tarikh Daftar Tamat' %></label>
                        <input type="date" name="endDate" value="<%= filters.endDate %>" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm bg-white focus:ring-2 focus:ring-blue-500 outline-none text-gray-700">
                    </div>
                </div>

                <div class="flex justify-end gap-2 mt-4 pt-4 border-t border-gray-50">
                    <a href="/admin-mace/students?lang=<%= lang %>" class="border border-gray-300 hover:bg-gray-50 text-gray-700 text-xs px-4 py-2 rounded-lg font-medium transition flex items-center gap-1.5">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89H17" /></svg>
                        <%= lang === 'en' ? 'Reset' : 'Reset' %>
                    </a>
                    <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white text-xs px-5 py-2 rounded-lg font-medium transition flex items-center gap-1.5 shadow-sm">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" /></svg>
                        <%= lang === 'en' ? 'Filter' : 'Tapis' %>
                    </button>
                </div>
            </form>

            <% if (msg === 'student_updated') { %>
                <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6"><%= lang === 'en' ? getTerm('student') + ' account details updated!' : 'Maklumat ' + getTerm('student').toLowerCase() + ' dikemaskini!' %></div>
            <% } else if (msg === 'student_deleted') { %>
                <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6"><%= lang === 'en' ? getTerm('student') + ' successfully deleted!' : getTerm('student') + ' berjaya dipadam!' %></div>
            <% } else if (msg === 'password_reset') { %>
                <div class="bg-blue-50 border border-blue-200 text-blue-700 px-4 py-3 rounded-lg mb-6"><%= lang === 'en' ? 'New password:' : 'Password baru:' %> <strong><%= newPassword %></strong></div>
            <% } else if (msg === 'athlete_updated') { %>
                <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6"><%= lang === 'en' ? getTerm('student') + ' record updated!' : 'Maklumat ' + getTerm('student').toLowerCase() + ' dikemaskini!' %></div>
            <% } else if (msg === 'athlete_deleted') { %>
