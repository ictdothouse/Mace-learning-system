                <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6"><%= lang === 'en' ? '✗ Enrollment key not found. Please try again.' : '✗ Enrollment key tidak dijumpai. Sila semak semula.' %></div>
