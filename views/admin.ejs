                <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 rounded-r-lg mb-6 shadow-sm">✅ Profil anda berjaya dikemaskini.</div>
            <% } else if (locals.msg === 'email_exists') { %>
                <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 rounded-r-lg mb-6 shadow-sm">❌ Email tersebut telah digunakan.</div>
            <% } else if (locals.msg === 'username_exists') { %>
                <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 rounded-r-lg mb-6 shadow-sm">❌ Username tersebut telah digunakan.</div>
            <% } else if (locals.msg === 'not_db_admin') { %>
