<!DOCTYPE html>
<html lang="ms">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel MSN - SUKMA eLearning</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: #f1f5f9; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
        .sidebar-link.active { background-color: rgba(255,255,255,0.1); border-left: 4px solid #fbbf24; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
        .animate-fade-in { animation: fadeIn 0.3s ease-out forwards; }
    </style>
</head>
<body class="bg-gray-100 min-h-screen flex text-gray-800 font-sans">
    
    <!-- SIDEBAR MENU -->
    <aside class="w-64 bg-blue-900 text-white flex-shrink-0 hidden md:flex flex-col h-screen sticky top-0 shadow-xl z-20">
        <div class="p-6 border-b border-blue-800">
            <h1 class="text-xl font-bold tracking-wider flex items-center gap-2">
                <span class="text-yellow-400 text-2xl">🏅</span> ADMIN MSN
            </h1>
            <p class="text-xs text-blue-300 mt-1">Sistem eLearning Atlit SUKMA v2</p>
        </div>
        
        <nav class="flex-1 py-6 space-y-1">
            <!-- Dashboard -->
            <a href="/admin-mace" class="sidebar-link <%= page === 'dashboard' ? 'active' : '' %> flex items-center px-6 py-3 hover:bg-blue-800 transition border-l-4 border-transparent">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" /></svg>
                Dashboard
            </a>
            
            <!-- 🆕 PENGURUSAN GURU / INSTRUKTOR -->
            <a href="/admin-mace/teachers" class="sidebar-link <%= page === 'teachers' ? 'active' : '' %> flex items-center px-6 py-3 hover:bg-blue-800 transition border-l-4 border-transparent">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                Teacher / Instruktor
            </a>

            <!-- 🆕 PENGURUSAN PELAJAR (STUDENT) -->
            <a href="/admin-mace/students" class="sidebar-link <%= page === 'students' ? 'active' : '' %> flex items-center px-6 py-3 hover:bg-blue-800 transition border-l-4 border-transparent">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
                Pelajar (Student)
            </a>

            <!-- Pengurusan Pengguna (Atlit Lama) -->
            <a href="/admin-mace/users" class="sidebar-link <%= page === 'users' ? 'active' : '' %> flex items-center px-6 py-3 hover:bg-blue-800 transition border-l-4 border-transparent">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
                Atlit (SUKMA)
            </a>

            <!-- 🆕 PENGURUSAN KUMPULAN & ENROLLMENT -->
            <a href="/admin-mace/groups" class="sidebar-link <%= page === 'groups' ? 'active' : '' %> flex items-center px-6 py-3 hover:bg-blue-800 transition border-l-4 border-transparent">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
                Kumpulan & Enrollment
            </a>

            <!-- 🆕 EDIT MODUL & KUIZ (dengan Level) -->
            <a href="/admin-mace/modules" class="sidebar-link <%= page === 'modules' ? 'active' : '' %> flex items-center px-6 py-3 hover:bg-blue-800 transition border-l-4 border-transparent">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
                Modul & Lesson (Level)
            </a>
            
            <!-- 🎨 TEMPLATE SIJIL -->
            <a href="/admin-mace/templates" class="sidebar-link <%= page === 'templates' ? 'active' : '' %> flex items-center px-6 py-3 hover:bg-blue-800 transition border-l-4 border-transparent">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                Template Sijil
            </a>
            
            <!-- Tetapan Sistem -->
            <a href="/admin-mace/settings" class="sidebar-link <%= page === 'settings' ? 'active' : '' %> flex items-center px-6 py-3 hover:bg-blue-800 transition border-l-4 border-transparent">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                Tetapan Sistem
            </a>
        </nav>

        <div class="p-6 border-t border-blue-800">
            <a href="/" class="flex items-center text-sm text-blue-300 hover:text-white transition group">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
                Kembali ke Laman Utama
            </a>
        </div>
    </aside>

    <!-- MAIN CONTENT AREA -->
    <main class="flex-1 p-6 md:p-10 overflow-y-auto h-screen relative">
        
        <!-- Mobile Header -->
        <div class="md:hidden mb-6 flex justify-between items-center bg-white p-4 rounded-lg shadow-sm">
            <h1 class="font-bold text-blue-900">ADMIN MSN</h1>
            <div class="flex gap-2">
                <a href="/admin-mace" class="text-xs bg-blue-100 text-blue-700 px-2 py-1 rounded">Dashboard</a>
                <a href="/admin-mace/users" class="text-xs bg-blue-100 text-blue-700 px-2 py-1 rounded">Users</a>
                <a href="/admin-mace/modules" class="text-xs bg-blue-100 text-blue-700 px-2 py-1 rounded">Modul</a>
                <a href="/admin-mace/templates" class="text-xs bg-blue-100 text-blue-700 px-2 py-1 rounded">Sijil</a>
                <a href="/admin-mace/settings" class="text-xs bg-blue-100 text-blue-700 px-2 py-1 rounded">Settings</a>
            </div>
        </div>

        <!-- Notifikasi Global -->
        <% if (locals.msg === 'success_upload') { %>
            <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 rounded-r-lg mb-6 shadow-sm flex items-center gap-2 animate-fade-in">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                Fail berjaya dimuat naik: <%= locals.file %>
            </div>
        <% } else if (locals.msg === 'profile_updated') { %>
            <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 rounded-r-lg mb-6 shadow-sm flex items-center gap-2 animate-fade-in">✅ Profil atlit berjaya dikemaskini.</div>
        <% } else if (locals.msg === 'reset_success') { %>
            <div class="bg-blue-100 border-l-4 border-blue-500 text-blue-700 p-4 rounded-r-lg mb-6 shadow-sm flex items-center gap-2 animate-fade-in">🔄 Kemajuan atlit telah diset semula ke Stage 1.</div>
        <% } else if (locals.msg === 'ic_exists') { %>
            <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 rounded-r-lg mb-6 shadow-sm flex items-center gap-2 animate-fade-in">❌ No. IC tersebut sudah digunakan oleh atlit lain.</div>
        <% } else if (locals.msg === 'error_no_file') { %>
            <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 rounded-r-lg mb-6 shadow-sm">⚠️ Sila pilih fail untuk dimuat naik.</div>
        <% } else if (locals.msg === 'error_upload') { %>
            <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 rounded-r-lg mb-6 shadow-sm">❌ Ralat semasa memuat naik fail.</div>
        <% } else if (locals.msg === 'template_created') { %>
            <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 rounded-r-lg mb-6 shadow-sm flex items-center gap-2 animate-fade-in">✅ Template sijil berjaya dicipta!</div>
        <% } else if (locals.msg === 'template_updated') { %>
            <div class="bg-blue-100 border-l-4 border-blue-500 text-blue-700 p-4 rounded-r-lg mb-6 shadow-sm flex items-center gap-2 animate-fade-in">✅ Template sijil berjaya dikemaskini!</div>
        <% } else if (locals.msg === 'template_activated') { %>
            <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 rounded-r-lg mb-6 shadow-sm flex items-center gap-2 animate-fade-in">✅ Template aktif telah ditukar!</div>
        <% } else if (locals.msg === 'template_deleted') { %>
            <div class="bg-blue-100 border-l-4 border-blue-500 text-blue-700 p-4 rounded-r-lg mb-6 shadow-sm flex items-center gap-2 animate-fade-in">🗑️ Template sijil berjaya dipadam.</div>
        <% } else if (locals.msg === 'create_error' || locals.msg === 'update_error' || locals.msg === 'activate_error' || locals.msg === 'delete_error') { %>
            <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 rounded-r-lg mb-6 shadow-sm flex items-center gap-2 animate-fade-in">❌ Ralat operasi template.</div>
        <% } %>

        <!-- ========================================== -->
        <!-- HALAMAN: DASHBOARD                         -->
        <!-- ========================================== -->
        <% if (page === 'dashboard' || !page) { %>
            <div class="mb-8 flex flex-col sm:flex-row justify-between items-start sm:items-end gap-4">
                <div>
                    <h2 class="text-2xl font-bold text-gray-900">Dashboard Pemantauan</h2>
                    <p class="text-gray-500 text-sm mt-1">Statistik terkini prestasi atlit SUKMA secara live.</p>
                </div>
                <a href="/admin-mace/download" class="shrink-0 bg-blue-600 hover:bg-blue-700 text-white px-5 py-2.5 rounded-lg text-sm font-medium transition flex items-center gap-2 shadow-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
                    Muat Turun CSV
                </a>
            </div>

            <!-- Kad Statistik -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-500 font-medium uppercase tracking-wider">Jumlah Keseluruhan</p>
                        <p class="text-3xl font-bold text-gray-900 mt-2"><%= total || 0 %></p>
                    </div>
                    <div class="bg-blue-50 p-3 rounded-full text-blue-600">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
                    </div>
                </div>
                
                <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-500 font-medium uppercase tracking-wider">Atlit Lulus (Stage 4)</p>
                        <p class="text-3xl font-bold text-green-600 mt-2"><%= passed || 0 %></p>
                    </div>
                    <div class="bg-green-50 p-3 rounded-full text-green-600">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                    </div>
                </div>

                <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-500 font-medium uppercase tracking-wider">Masih Belajar</p>
                        <p class="text-3xl font-bold text-orange-500 mt-2"><%= learning || 0 %></p>
                    </div>
                    <div class="bg-orange-50 p-3 rounded-full text-orange-500">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                    </div>
                </div>
            </div>

            <!-- Carta Negeri & Senarai Terkini -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <div class="lg:col-span-1 bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
                    <div class="px-6 py-4 border-b border-gray-100 bg-gray-50 font-bold text-gray-700 flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 7m0 13V7" /></svg>
                        Pecahan Mengikut Negeri
                    </div>
                    <div class="p-4 max-h-[400px] overflow-y-auto">
                        <% if (byState && byState.length > 0) { %>
                            <table class="w-full text-sm">
                                <thead class="text-xs text-gray-500 uppercase bg-gray-50 sticky top-0">
                                    <tr><th class="py-2 text-left">Negeri</th><th class="py-2 text-right">Jml</th><th class="py-2 text-right">Lulus</th></tr>
                                </thead>
                                <tbody class="divide-y divide-gray-100">
                                    <% byState.forEach(s => { %>
                                        <tr class="hover:bg-gray-50">
                                            <td class="py-2.5 font-medium text-gray-700"><%= s._id || 'Tidak Dinyatakan' %></td>
                                            <td class="py-2.5 text-right text-gray-600"><%= s.total %></td>
                                            <td class="py-2.5 text-right text-green-600 font-bold"><%= s.passed %></td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        <% } else { %>
                            <p class="text-center text-gray-400 py-8 italic">Tiada data negeri tersedia.</p>
                        <% } %>
                    </div>
                </div>

                <div class="lg:col-span-2 bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
                    <div class="px-6 py-4 border-b border-gray-100 bg-gray-50 font-bold text-gray-700 flex justify-between items-center">
                        <span class="flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
                            Senarai Atlit Terkini (100 Terakhir)
                        </span>
                        <span class="text-xs bg-blue-100 text-blue-700 px-2.5 py-1 rounded-full font-medium">Live Data</span>
                    </div>
                    <div class="overflow-x-auto max-h-[500px]">
                        <table class="w-full text-sm text-left">
                            <thead class="text-xs text-gray-500 uppercase bg-gray-50 sticky top-0 z-10 shadow-sm">
                                <tr>
                                    <th class="px-6 py-3">Nama</th>
                                    <th class="px-6 py-3">IC</th>
                                    <th class="px-6 py-3">Negeri</th>
                                    <th class="px-6 py-3 text-center">K1</th>
                                    <th class="px-6 py-3 text-center">K2</th>
                                    <th class="px-6 py-3 text-center">K3</th>
                                    <th class="px-6 py-3">Status</th>
                                    <th class="px-6 py-3 text-right">Tindakan</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-100">
                                <% if (athletes && athletes.length > 0) { %>
                                    <% athletes.forEach(a => { 
                                        const status = a.currentStage >= 4 ? 'Lulus' : `Stage ${a.currentStage}`;
                                        const color = a.currentStage >= 4 ? 'bg-green-100 text-green-700' : 'bg-orange-100 text-orange-700';
                                    %>
                                        <tr class="hover:bg-blue-50/50 transition-colors">
                                            <td class="px-6 py-3 font-medium text-gray-900"><%= a.fullName %></td>
                                            <td class="px-6 py-3 font-mono text-xs text-gray-500 bg-gray-50 rounded px-2 py-1 inline-block"><%= a.icNumber %></td>
                                            <td class="px-6 py-3 text-gray-600"><%= a.negeriWakil %></td>
                                            <td class="px-6 py-3 text-center font-mono <%= a.quizScores?.quiz1 > 0 ? 'text-green-600' : 'text-gray-300' %>"><%= a.quizScores?.quiz1 || '-' %></td>
                                            <td class="px-6 py-3 text-center font-mono <%= a.quizScores?.quiz2 > 0 ? 'text-green-600' : 'text-gray-300' %>"><%= a.quizScores?.quiz2 || '-' %></td>
                                            <td class="px-6 py-3 text-center font-mono <%= a.quizScores?.quiz3 > 0 ? 'text-green-600' : 'text-gray-300' %>"><%= a.quizScores?.quiz3 || '-' %></td>
                                            <td class="px-6 py-3"><span class="<%= color %> px-2.5 py-1 rounded-full text-xs font-bold"><%= status %></span></td>
                                            <td class="px-6 py-3 text-right">
                                                <a href="/admin-mace/certificate/preview/<%= a._id %>" target="_blank" 
                                                   class="text-blue-600 hover:text-blue-800 text-sm font-medium hover:underline">
                                                    📄 Sijil
                                                </a>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="8" class="px-6 py-12 text-center text-gray-400 italic">Tiada rekod atlit dijumpai.</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        <% } %>

        <!-- ========================================== -->
        <!-- HALAMAN: PENGURUSAN MODUL & LESSON         -->
        <!-- ========================================== -->
        <% if (page === 'modules') { %>
            <div class="max-w-7xl mx-auto">
                <div class="flex justify-between items-center mb-8">
                    <div>
                        <h2 class="text-2xl font-bold text-gray-900 mb-2">📚 Pengurusan Modul & Lesson</h2>
                        <p class="text-gray-500">Urus modul pembelajaran dan lesson di dalamnya.</p>
                    </div>
                    <a href="/admin-mace/modules/new" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg font-medium transition flex items-center gap-2 shadow-sm">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                        Tambah Modul Baru
                    </a>
                </div>

                <!-- Senarai Modul -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    <% if (modules && modules.length > 0) { %>
                        <% modules.forEach(mod => { %>
                            <div class="bg-white rounded-xl shadow-sm border <%= mod.isActive ? 'border-green-200' : 'border-gray-200' %> overflow-hidden hover:shadow-md transition">
                                <% if (mod.thumbnail) { %>
                                    <img src="<%= mod.thumbnail %>" alt="<%= mod.title %>" class="w-full h-40 object-cover">
                                <% } else { %>
                                    <div class="w-full h-40 bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-white opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
                                    </div>
                                <% } %>
                                
                                <div class="p-5">
                                    <div class="flex justify-between items-start mb-3">
                                        <h3 class="text-lg font-bold text-gray-900"><%= mod.title %></h3>
                                        <% if (mod.isActive) { %>
                                            <span class="bg-green-100 text-green-700 text-xs font-bold px-2 py-1 rounded">Aktif</span>
                                        <% } else { %>
                                            <span class="bg-gray-100 text-gray-600 text-xs font-bold px-2 py-1 rounded">Tidak Aktif</span>
                                        <% } %>
                                    </div>
                                    
                                    <p class="text-sm text-gray-600 mb-4 line-clamp-2"><%= mod.description ? mod.description.replace(/<[^>]*>/g, '').substring(0, 100) : 'Tiada deskripsi' %>...</p>
                                    
                                    <div class="flex items-center gap-4 text-xs text-gray-500 mb-4">
                                        <span class="flex items-center gap-1">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
                                            Order: <%= mod.order %>
                                        </span>
                                    </div>
                                    
                                    <div class="flex gap-2 pt-4 border-t border-gray-100">
                                        <a href="/admin-mace/lessons?moduleId=<%= mod._id %>" class="flex-1 bg-purple-50 text-purple-600 px-3 py-2 rounded-lg text-sm font-medium hover:bg-purple-100 transition text-center">
                                            📖 Urus Lesson
                                        </a>
                                        <a href="/admin-mace/modules/edit/<%= mod._id %>" class="flex-1 bg-blue-50 text-blue-600 px-3 py-2 rounded-lg text-sm font-medium hover:bg-blue-100 transition text-center">
                                            ✏️ Edit
                                        </a>
                                        <form action="/admin-mace/modules/delete/<%= mod._id %>" method="POST" onsubmit="return confirm('Padam modul ini?')" class="flex-1">
                                            <button type="submit" class="w-full bg-red-50 text-red-600 px-3 py-2 rounded-lg text-sm font-medium hover:bg-red-100 transition">
                                                🗑️
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="col-span-full text-center py-12">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-gray-300 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
                            <p class="text-gray-500 text-lg">Belum ada modul dicipta.</p>
                            <p class="text-gray-400 text-sm mt-2">Klik "Tambah Modul Baru" untuk mula.</p>
                        </div>
                    <% } %>
                </div>
            </div>
        <% } %>

        <!-- ========================================== -->
        <!-- HALAMAN: PENGURUSAN LESSON                 -->
        <!-- ========================================== -->
        <% if (page === 'lessons' || page === 'lessons-select-module') { %>
            <div class="max-w-7xl mx-auto">
                <div class="flex justify-between items-center mb-8">
                    <div>
                        <h2 class="text-2xl font-bold text-gray-900 mb-2">📖 Pengurusan Lesson</h2>
                        <p class="text-gray-500">Urus lesson dan kuiz untuk setiap modul.</p>
                    </div>
                    <% if (page === 'lessons-select-module') { %>
                        <a href="/admin-mace/modules" class="bg-gray-500 hover:bg-gray-600 text-white px-6 py-3 rounded-lg font-medium transition flex items-center gap-2 shadow-sm">
                            ← Kembali ke Modul
                        </a>
                    <% } else { %>
                        <a href="/admin-mace/lessons/new" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg font-medium transition flex items-center gap-2 shadow-sm">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                            Tambah Lesson Baru
                        </a>
                    <% } %>
                </div>

                <% if (page === 'lessons-select-module') { %>
                    <!-- Pilih Modul -->
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                        <% if (modules && modules.length > 0) { %>
                            <% modules.forEach(mod => { %>
                                <div class="bg-white rounded-xl shadow-sm border border-blue-200 overflow-hidden hover:shadow-md transition">
                                    <% if (mod.thumbnail) { %>
                                        <img src="<%= mod.thumbnail %>" alt="<%= mod.title %>" class="w-full h-40 object-cover">
                                    <% } else { %>
                                        <div class="w-full h-40 bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-white opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
                                        </div>
                                    <% } %>
                                    <div class="p-5">
                                        <h3 class="text-lg font-bold text-gray-900 mb-2"><%= mod.title %></h3>
                                        <p class="text-sm text-gray-600 mb-4 line-clamp-2"><%= mod.description ? mod.description.replace(/<[^>]*>/g, '').substring(0, 80) : 'Tiada deskripsi' %>...</p>
                                        <a href="/admin-mace/lessons?moduleId=<%= mod._id %>" class="block w-full bg-purple-50 text-purple-600 px-4 py-3 rounded-lg text-sm font-medium hover:bg-purple-100 transition text-center">
                                            📖 Urus Lesson →
                                        </a>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="col-span-full text-center py-12">
                                <p class="text-gray-500 text-lg">Belum ada modul.</p>
                                <a href="/admin-mace/modules/new" class="text-blue-600 hover:underline mt-2 inline-block">Tambah Modul Baru</a>
                            </div>
                        <% } %>
                    </div>
                <% } else { %>
                    <!-- Senarai Lesson untuk Modul -->
                    <div class="mb-6 p-4 bg-blue-50 border border-blue-200 rounded-lg flex justify-between items-center">
                        <div>
                            <span class="text-sm text-gray-600">Modul:</span>
                            <strong class="text-lg text-blue-900 ml-2"><%= module ? module.title : '-' %></strong>
                        </div>
                        <a href="/admin-mace/modules" class="text-sm text-blue-600 hover:underline">← Kembali ke semua modul</a>
                    </div>

                    <div class="space-y-4">
                        <% if (lessons && lessons.length > 0) { %>
                            <% lessons.forEach((lesson, idx) => { %>
                                <div class="bg-white rounded-xl shadow-sm border <%= lesson.isActive ? 'border-green-200' : 'border-gray-200' %> p-5 hover:shadow-md transition">
                                    <div class="flex justify-between items-start">
                                        <div class="flex-1">
                                            <div class="flex items-center gap-3 mb-2">
                                                <span class="bg-purple-100 text-purple-700 text-xs font-bold px-2 py-1 rounded">Lesson <%= lesson.order || (idx + 1) %></span>
                                                <% if (lesson.isActive) { %>
                                                    <span class="bg-green-100 text-green-700 text-xs font-bold px-2 py-1 rounded">Aktif</span>
                                                <% } else { %>
                                                    <span class="bg-gray-100 text-gray-600 text-xs font-bold px-2 py-1 rounded">Tidak Aktif</span>
                                                <% } %>
                                            </div>
                                            <h3 class="text-lg font-bold text-gray-900 mb-2"><%= lesson.title %></h3>
                                            <p class="text-sm text-gray-600 line-clamp-2"><%= lesson.contentHtml ? lesson.contentHtml.replace(/<[^>]*>/g, '').substring(0, 150) : 'Tiada kandungan' %>...</p>
                                            
                                            <% if (lesson.quizQuestions && lesson.quizQuestions.length > 0) { %>
                                                <div class="mt-3 flex items-center gap-2 text-xs text-blue-600">
                                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.459 1.225-2.5 2.772-2.5 1.547 0 2.222 1.041 2.772 2.5M8.228 9c-.549 1.459-1.225 2.5-2.772 2.5S2.772 10.459 3.321 9m4.907 0c.549-1.459 1.225-2.5 2.772-2.5 1.547 0 2.222 1.041 2.772 2.5m-5.544 5c.549-1.459 1.225-2.5 2.772-2.5 1.547 0 2.222 1.041 2.772 2.5M8.228 14c-.549 1.459-1.225 2.5-2.772 2.5S2.772 15.459 3.321 14m4.907 0c.549-1.459 1.225-2.5 2.772-2.5 1.547 0 2.222 1.041 2.772 2.5" /></svg>
                                                    <span><%= lesson.quizQuestions.length %> soalan kuiz</span>
                                                </div>
                                            <% } %>
                                            
                                            <% if (lesson.videoUrl) { %>
                                                <div class="mt-2 text-xs text-gray-500 flex items-center gap-1">
                                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
                                                    Video disertakan
                                                </div>
                                            <% } %>
                                        </div>
                                        <div class="flex gap-2 ml-4">
                                            <a href="/admin-mace/lessons/edit/<%= lesson._id %>" class="bg-blue-50 text-blue-600 px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-100 transition whitespace-nowrap">
                                                ✏️ Edit
                                            </a>
                                            <form action="/admin-mace/lessons/delete/<%= lesson._id %>?moduleId=<%= module._id %>" method="POST" onsubmit="return confirm('Padam lesson ini?')">
                                                <button type="submit" class="bg-red-50 text-red-600 px-4 py-2 rounded-lg text-sm font-medium hover:bg-red-100 transition">
                                                    🗑️
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="text-center py-12 bg-white rounded-xl border border-dashed border-gray-300">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-gray-300 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
                                <p class="text-gray-500 text-lg">Belum ada lesson untuk modul ini.</p>
                                <a href="/admin-mace/lessons/new" class="text-blue-600 hover:underline mt-2 inline-block">Tambah Lesson Pertama</a>
                            </div>
                        <% } %>
                    </div>
                <% } %>
            </div>
        <% } %>

        <!-- ========================================== -->
        <!-- HALAMAN: TETAPAN SISTEM                  -->
        <!-- ========================================== -->
        <% if (page === 'settings') { %>
            <div class="max-w-3xl mx-auto">
                <h2 class="text-2xl font-bold text-gray-900 mb-2">Tetapan Sistem</h2>
                <p class="text-gray-500 mb-8">Urus fail backup dan konfigurasi sistem Node.js.</p>

                <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8 mb-8">
                    <h3 class="text-lg font-bold text-gray-800 mb-4 flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" /></svg>
                        Upload Data Backup (CSV/JSON)
                    </h3>
                    <p class="text-sm text-gray-500 mb-6">Muat naik fail export dari WordPress sebagai simpanan keselamatan di server Node.js.</p>
                    
                    <form action="/admin-mace/upload-data" method="POST" enctype="multipart/form-data" class="flex flex-col sm:flex-row gap-4 items-end">
                        <div class="flex-1 w-full">
                            <label class="block text-xs font-semibold text-gray-600 mb-2 uppercase tracking-wide">Pilih Fail Export</label>
                            <input type="file" name="dataFile" accept=".csv,.json" required 
                                class="w-full text-sm text-gray-500 file:mr-4 file:py-2.5 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-purple-50 file:text-purple-700 hover:file:bg-purple-100 cursor-pointer border border-gray-200 rounded-lg p-2 focus:ring-2 focus:ring-purple-500 outline-none transition">
                        </div>
                        <button type="submit" class="w-full sm:w-auto bg-purple-600 text-white px-8 py-2.5 rounded-lg font-medium hover:bg-purple-700 transition shadow-sm shrink-0">
                            Muat Naik
                        </button>
                    </form>

                    <% if (uploadedFiles && uploadedFiles.length > 0) { %>
                        <div class="mt-8 pt-6 border-t border-gray-100">
                            <h4 class="text-xs font-bold text-gray-500 uppercase tracking-wide mb-3">Fail Yang Pernah Dimuat Naik:</h4>
                            <ul class="space-y-2 max-h-40 overflow-y-auto pr-2">
                                <% uploadedFiles.forEach(f => { %>
                                    <li class="flex justify-between items-center bg-gray-50 px-4 py-3 rounded-lg text-sm border border-gray-100">
                                        <span class="flex items-center gap-2 text-gray-700 truncate">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                                            <%= f.name %>
                                        </span>
                                        <span class="text-xs text-gray-400 font-mono ml-4 shrink-0"><%= f.size %></span>
                                    </li>
                                <% }) %>
                            </ul>
                        </div>
                    <% } %>
                </div>
            </div>
        <% } %>

        <!-- ========================================== -->
        <!-- HALAMAN: TEMPLATE SIJIL                  -->
        <!-- ========================================== -->
        <% if (page === 'templates') { %>
            <div class="max-w-7xl mx-auto">
                <div class="flex justify-between items-center mb-8">
                    <div>
                        <h2 class="text-2xl font-bold text-gray-900 mb-2">🎨 Template Sijil</h2>
                        <p class="text-gray-500">Urus dan customize template sijil untuk atlit dengan live preview & drag-drop.</p>
                    </div>
                    <button onclick="document.getElementById('createTemplateModal').classList.remove('hidden')" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg font-medium transition flex items-center gap-2 shadow-sm">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                        Cipta Template Baru
                    </button>
                </div>

                <!-- Senarai Template -->
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                    <% if (templates && templates.length > 0) { %>
                        <% templates.forEach(t => { %>
                            <div class="bg-white rounded-xl shadow-sm border-2 <%= t.isActive ? 'border-green-500' : 'border-gray-200' %> p-6 relative">
                                <% if (t.isActive) { %>
                                    <span class="absolute top-4 right-4 bg-green-500 text-white text-xs font-bold px-3 py-1 rounded-full">AKTIF</span>
                                <% } %>
                                
                                <h3 class="text-lg font-bold text-gray-900 mb-2"><%= t.name %></h3>
                                <p class="text-sm text-gray-500 mb-4">Tajuk: <%= t.title %></p>
                                
                                <div class="flex gap-2 mb-4">
                                    <div class="flex items-center gap-1">
                                        <span class="text-xs text-gray-500">Primary:</span>
                                        <div class="w-6 h-6 rounded border" style="background-color: <%= t.primaryColor %>"></div>
                                    </div>
                                    <div class="flex items-center gap-1">
                                        <span class="text-xs text-gray-500">Secondary:</span>
                                        <div class="w-6 h-6 rounded border" style="background-color: <%= t.secondaryColor %>"></div>
                                    </div>
                                </div>
                                
                                <div class="flex gap-2 text-xs text-gray-500 mb-4">
                                    <span>Font: <%= t.fontFamily %></span>
                                    <span>|</span>
                                    <span><%= t.showBorder ? '✓ Border' : '✗ Border' %></span>
                                    <span>|</span>
                                    <span><%= t.showLogo ? '✓ Logo' : '✗ Logo' %></span>
                                </div>
                                
                                <div class="flex gap-2 pt-4 border-t border-gray-100">
                                    <button onclick="editTemplate('<%= t._id %>', '<%= escape(JSON.stringify(t)) %>')" class="flex-1 bg-blue-50 text-blue-600 px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-100 transition">Edit</button>
                                    <% if (!t.isActive) { %>
                                        <form action="/admin-mace/templates/set-active/<%= t._id %>" method="POST" class="flex-1">
                                            <button type="submit" class="w-full bg-green-50 text-green-600 px-4 py-2 rounded-lg text-sm font-medium hover:bg-green-100 transition">Set Aktif</button>
                                        </form>
                                    <% } %>
                                    <form action="/admin-mace/templates/delete/<%= t._id %>" method="POST" onsubmit="return confirm('Padam template ini?')" class="flex-1">
                                        <button type="submit" class="w-full bg-red-50 text-red-600 px-4 py-2 rounded-lg text-sm font-medium hover:bg-red-100 transition">Padam</button>
                                    </form>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="col-span-2 text-center py-12 text-gray-400 italic">Tiada template lagi. Cipta template pertama anda!</div>
                    <% } %>
                </div>
            </div>

            <!-- Modal: Cipta/Edit Template dengan LIVE PREVIEW -->
            <div id="createTemplateModal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50 overflow-y-auto">
                <div class="bg-white rounded-xl shadow-2xl max-w-7xl w-full mx-4 my-8 max-h-[95vh] overflow-hidden flex flex-col">
                    <div class="p-6 border-b border-gray-200 flex justify-between items-center flex-shrink-0">
                        <h3 class="text-xl font-bold text-gray-900">Cipta Template Baharu - Live Preview & Drag-Drop</h3>
                        <button onclick="document.getElementById('createTemplateModal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 text-2xl">&times;</button>
                    </div>
                    
                    <div class="flex-1 overflow-hidden flex flex-col lg:flex-row">
                        <!-- LEFT: Form Controls -->
                        <div class="w-full lg:w-1/2 overflow-y-auto p-6 border-r border-gray-200">
                            <form id="createTemplateForm" action="/admin-mace/templates/create" method="POST" class="space-y-6">
                                <!-- Basic Info -->
                                <div>
                                    <h4 class="font-bold text-gray-700 border-b pb-2 mb-3">Maklumat Asas</h4>
                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-1">Nama Template</label>
                                        <input type="text" name="name" required class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 outline-none">
                                    </div>
                                </div>

                                <!-- Content Text -->
                                <div>
                                    <h4 class="font-bold text-gray-700 border-b pb-2 mb-3">Kandungan Text</h4>
                                    <div class="space-y-3">
                                        <div>
                                            <label class="block text-sm font-medium text-gray-700 mb-1">Tajuk Utama</label>
                                            <input type="text" name="title" value="SIJIL PENGHARGAAN" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 outline-none">
