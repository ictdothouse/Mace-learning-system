<!DOCTYPE html>
<html lang="ms">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sijil - <%= athlete.fullName %></title>
    <% 
        const athleteFont = template.athleteNameFont || 'Great Vibes';
        const formattedAthleteFont = athleteFont.trim().replace(/\s+/g, '+');
    %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Poppins:wght@300;400;600&family=Great+Vibes&display=swap" rel="stylesheet">
    <% if (athleteFont && !['Helvetica', 'Times-Roman', 'Courier', 'Arial', 'Georgia'].includes(athleteFont)) { %>
        <link href="https://fonts.googleapis.com/css2?family=<%= formattedAthleteFont %>&display=swap" rel="stylesheet">
    <% } %>
    <!-- html2pdf.js CDN library -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background-color: #0b0f19; /* dark slate-950/90 background */
            margin: 0;
            padding: 0;
            min-height: 100vh;
        }
        
        <% 
            const isPortrait = (template.orientation === 'portrait');
            const width = isPortrait ? 793 : 1122;
            const height = isPortrait ? 1122 : 793;
        %>
        .certificate-container {
            width: <%= width %>px !important;
            height: <%= height %>px !important;
            margin: 0 auto;
            position: relative;
            background: white;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            overflow: hidden;
            flex-shrink: 0;
        }

        .cert-scroll-wrapper {
            width: 100%;
            overflow: hidden;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            padding: 16px 0;
            transition: height 0.15s ease-out;
        }

        .certificate-container.html2pdf-printing {
            transform: none !important;
        }

        /* Print styles overridden in main @media print block below */
        
        .certificate-content {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            padding: 40px;
            pointer-events: none; /* Let clicks pass if needed, though mostly for print */
        }
        
        /* Background */
        .bg-layer {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
        }
        
        
        .bg-color {
            background-color: <%= template.backgroundColor || '#ffffff' %>;
        }
        
        .bg-image {
            background-image: url('<%= template.backgroundImageType === "r2" ? "https://imghub-cdn.cloudflare.com/" + template.backgroundR2Key : (template.backgroundImageUrl || "") %>');
            background-size: cover;
            background-position: center;
            opacity: <%= template.backgroundOpacity || 1 %>;
        }
        
        /* Border */
        .border-frame {
            position: absolute;
            top: 20px;
            left: 20px;
            right: 20px;
            bottom: 20px;
            border: <%= template.showBorder ? (template.borderWidth || 3) + 'px solid ' + (template.borderColor || '#004aad') : 'none' %>;
            z-index: 1;
            pointer-events: none;
        }
        
        .border-double {
            position: absolute;
            top: 30px;
            left: 30px;
            right: 30px;
            bottom: 30px;
            border: 2px solid <%= template.showBorder ? (template.borderColor || '#004aad') : 'transparent' %>;
            z-index: 1;
            pointer-events: none;
        }
        
        /* Logo */
        .logo {
            position: absolute;
            z-index: 10;
        }
        
        <% if (template.showLogo && template.logoUrl) { %>
            <% if (template.logoPosition === 'top-left') { %>
                .logo { top: 40px; left: 40px; }
            <% } else if (template.logoPosition === 'top-right') { %>
                .logo { top: 40px; right: 40px; }
            <% } else if (template.logoPosition === 'bottom-left') { %>
                .logo { bottom: 40px; left: 40px; }
            <% } else if (template.logoPosition === 'bottom-right') { %>
                .logo { bottom: 40px; right: 40px; }
            <% } else { %>
                .logo { top: 40px; left: 50%; transform: translateX(-50%); }
            <% } %>
        <% } %>
        
        /* Content Elements */
        .element {
            position: absolute;
            transform: translate(-50%, -50%);
            z-index: 5;
            white-space: pre-wrap;
            max-width: 95%;
            word-wrap: break-word;
            text-align: center;
        }
        
        .align-left {
            transform: translate(0, -50%);
            text-align: left;
        }
        
        .align-center {
            text-align: center;
        }
        
        .align-right {
            transform: translate(-100%, -50%);
            text-align: right;
        }
        
        /* Unified @media print config */
        @media print {
            .no-print {
                display: none !important;
            }
            
            html, body {
                background: white !important;
                padding: 0 !important;
                margin: 0 !important;
                width: <%= isPortrait ? '210mm' : '297mm' %> !important;
                height: <%= isPortrait ? '297mm' : '210mm' %> !important;
                overflow: hidden !important;
                -webkit-print-color-adjust: exact !important;
                print-color-adjust: exact !important;
            }

            .cert-scroll-wrapper {
                padding: 0 !important;
                margin: 0 !important;
                width: 100% !important;
                height: 100% !important;
                display: block !important;
                overflow: hidden !important;
                position: relative !important;
            }

            .certificate-container {
                box-shadow: none !important;
                margin: 0 !important;
                width: <%= isPortrait ? '210mm' : '297mm' %> !important;
                height: <%= isPortrait ? '297mm' : '210mm' %> !important;
                position: static !important;
                transform: none !important;
                page-break-inside: avoid !important;
                page-break-after: avoid !important;
                zoom: 1 !important;
            }

            @page {
                size: A4 <%= isPortrait ? 'portrait' : 'landscape' %>;
                margin: 0 !important;
            }
        }
        /* ── Image Protection ─────────────────────────────────────────────── */
        /* Prevent right-click, drag, and selection on all images */
        img {
            -webkit-user-drag: none !important;
            -khtml-user-drag: none !important;
            -moz-user-drag: none !important;
            -o-user-drag: none !important;
            user-drag: none !important;
            pointer-events: none !important;
            -webkit-user-select: none !important;
            user-select: none !important;
        }
        /* Transparent overlay on certificate to block image clicks */
        .cert-protect-overlay {
            position: absolute;
            inset: 0;
            z-index: 999;
            background: transparent;
            cursor: default;
        }
        /* Prevent any text selection inside certificate */
        .certificate-container {
            -webkit-user-select: none !important;
            user-select: none !important;
        }
    </style>
</head>
<body>
    <!-- Top System Header -->
    <header class="no-print bg-slate-900/90 border-b border-slate-800 backdrop-blur-md sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
            <!-- Left: Brand Logo OR Title -->
            <div class="flex items-center gap-3">
                <% if (locals.branding && locals.branding.logoUrl) { %>
                    <img src="<%= branding.logoUrl %>" alt="Logo" class="h-8 md:h-10 w-auto object-contain">
                <% } else { %>
                    <span class="text-sm md:text-base font-extrabold tracking-wider uppercase text-white bg-gradient-to-r from-indigo-400 to-cyan-400 bg-clip-text text-transparent">
                        <%= (locals.branding && locals.branding.siteName) ? locals.branding.siteName : 'MACE Learning System' %>
                    </span>
                <% } %>
            </div>

            <!-- Right: Language Toggle & Back Button -->
            <div class="flex items-center gap-2 sm:gap-4">
                <!-- Language Toggle -->
                <div class="flex gap-1 bg-white/10 rounded-lg p-1">
                    <a href="?lang=ms" class="text-[10px] sm:text-xs px-2.5 py-1 rounded font-semibold transition-all <%= lang === 'ms' ? 'bg-white text-indigo-900' : 'text-white/60 hover:text-white' %>">BM</a>
                    <a href="?lang=en" class="text-[10px] sm:text-xs px-2.5 py-1 rounded font-semibold transition-all <%= lang === 'en' ? 'bg-white text-indigo-900' : 'text-white/60 hover:text-white' %>">EN</a>
                </div>

                <a href="<%= locals.backUrl || '/dashboard' %>" class="inline-flex items-center gap-2 bg-slate-800 hover:bg-slate-700 text-slate-200 hover:text-white px-3 py-1.5 sm:px-4 sm:py-2 rounded-xl text-xs sm:text-sm font-semibold border border-slate-700 transition-all shadow-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
                    <%= lang === 'en' ? 'Back' : 'Kembali' %>
                </a>
            </div>
        </div>
    </header>

    <!-- Main Workspace -->
    <main class="no-print max-w-6xl mx-auto w-full px-4 py-6 md:py-10 flex flex-col gap-6">
        <!-- Status Card with CTA Download button -->
        <div class="w-full bg-slate-900/60 border border-slate-800/80 rounded-3xl p-6 md:p-8 backdrop-blur-md shadow-xl flex flex-col md:flex-row md:items-center justify-between gap-6">
            <div class="flex-1">
                <div class="flex items-center gap-2 mb-2">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">
                        ✓ <%= lang === 'en' ? 'Verified Certificate' : 'Sijil Sah & Diperakui' %>
                     </span>
                </div>
                <h2 class="text-xl md:text-2xl font-bold text-white mb-2"><%= lang === 'en' ? 'Certificate of Achievement' : 'Sijil Penghargaan & Pencapaian' %></h2>
                <p class="text-xs md:text-sm text-slate-400 leading-relaxed">
                    <%= lang === 'en' ? 'Your certificate has been successfully generated. Click the button to download or print your high-resolution official PDF.' : 'Sijil anda telah dijana dengan jayanya. Sila klik butang di bawah untuk memuat turun atau mencetak PDF rasmi beresolusi tinggi.' %>
                </p>
            </div>
            
            <div class="shrink-0 flex items-center">
                <button id="btnPrintPDF" onclick="downloadPDF()" class="inline-flex items-center justify-center gap-2 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-500 hover:to-indigo-500 text-white font-bold px-6 py-4 rounded-2xl shadow-lg shadow-indigo-500/20 hover:shadow-indigo-500/30 transition-all transform hover:scale-[1.02] active:scale-[0.98] no-print">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                    <%= lang === 'en' ? 'Download / Save PDF' : 'Muat Turun / Simpan PDF' %>
                </button>
            </div>
        </div>

        <!-- Document Preview Canvas -->
        <div class="w-full flex items-center justify-center p-4 bg-slate-900/30 border border-slate-800/40 rounded-3xl backdrop-blur-sm min-h-[400px]">
            <div class="cert-scroll-wrapper">
                <div class="certificate-container shadow-2xl">
        <!-- Background Layers -->
        <div class="bg-layer bg-color"></div>
        <% if (template.backgroundImageType !== 'none' && (template.backgroundImageUrl || template.backgroundR2Key)) { %>
            <div class="bg-layer">
                <% 
                    let bgUrl = template.backgroundImageType === "r2" ? "https://imghub-cdn.cloudflare.com/" + template.backgroundR2Key : (template.backgroundImageUrl || "");
                    if (bgUrl) {
                        const separator = bgUrl.includes('?') ? '&' : '?';
                        bgUrl = bgUrl + separator + '_cb=' + Date.now();
                    }
                %>
                <!-- img needed for html2canvas PDF export; protected via CSS pointer-events:none + JS -->
                <img src="<%= bgUrl %>" crossorigin="anonymous"
                    ondragstart="return false"
                    oncontextmenu="return false"
                    style="width: 100%; height: 100%; object-fit: cover; opacity: <%= template.backgroundOpacity || 1 %>; display: block; z-index: 0; pointer-events: none; -webkit-user-drag: none; user-select: none;">
            </div>
        <% } %>
        <!-- Transparent protection overlay: intercepts all mouse events on certificate area -->
        <div class="cert-protect-overlay" oncontextmenu="return false"></div>
        
        <!-- Border Frames -->
        <% if (template.showBorder) { %>
            <div class="border-frame"></div>
            <div class="border-double"></div>
        <% } %>
        
        <!-- Logo -->
        <% if (template.showLogo && template.logoUrl) { %>
            <% 
                let finalLogoUrl = template.logoUrl;
                if (finalLogoUrl) {
                    const separator = finalLogoUrl.includes('?') ? '&' : '?';
                    finalLogoUrl = finalLogoUrl + separator + '_cb=' + Date.now();
                }
            %>
            <img src="<%= finalLogoUrl %>" crossorigin="anonymous" alt="Logo" class="logo" style="width: <%= template.logoSize?.width || 80 %>px; height: <%= template.logoSize?.height || 80 %>px;">
        <% } %>
        
        <!-- Content Area -->
        <div class="certificate-content">
            <% 
            const elements = template.elements || {};
            const t = elements.title || {};
            const sub = elements.subtitle || {};
            const desc = elements.description || {};
            const name = elements.athleteName || {};
            const ic = elements.icNumber || {};
            const negeri = elements.negeri || {};
            const sukan = elements.sukan || {};
            const course = elements.courseName || {};
            const date = elements.date || {};
            const sign = elements.signatory || {};
            const signTitle = elements.signatoryTitle || {};
            %>
            
            <!-- Title -->
            <% if (template.showTitle) { %>
                <div class="element align-<%= t.align || 'center' %>" 
                     style="left: <%= t.positionX || 50 %>%; top: <%= t.positionY || 10 %>%; 
                            font-size: <%= t.fontSize || 36 %>px; 
                            color: <%= t.color || '#004aad' %>; 
                            font-weight: <%= t.fontWeight || 'bold' %>;
                            line-height: <%= t.lineHeight || 1.2 %>;
                            letter-spacing: <%= t.letterSpacing || 0 %>px;
                            font-family: 'Playfair Display', serif;"><%= template.title %></div>
            <% } %>
            
            <!-- Subtitle -->
            <% if (template.showSubtitle) { %>
                <div class="element align-<%= sub.align || 'center' %>" 
                     style="left: <%= sub.positionX || 50 %>%; top: <%= sub.positionY || 18 %>%; 
                            font-size: <%= sub.fontSize || 18 %>px; 
                            color: <%= sub.color || '#333333' %>; 
                            font-weight: <%= sub.fontWeight || 'normal' %>;
                            line-height: <%= sub.lineHeight || 1.3 %>;
                            letter-spacing: <%= sub.letterSpacing || 0 %>px;"><%= template.subtitle %></div>
            <% } %>
            
            <!-- Description -->
            <% if (template.showDescription) { %>
                <div class="element align-<%= desc.align || 'center' %>" 
                     style="left: <%= desc.positionX || 50 %>%; top: <%= desc.positionY || 28 %>%; 
                            font-size: <%= desc.fontSize || 16 %>px; 
                            color: <%= desc.color || '#000000' %>; 
                            font-weight: <%= desc.fontWeight || 'normal' %>;
                            line-height: <%= desc.lineHeight || 1.4 %>;
                            letter-spacing: <%= desc.letterSpacing || 0 %>px;"><%= template.description %></div>
            <% } %>
            
            <!-- Athlete Name -->
            <% if (template.showAthleteName) { %>
                <div class="element align-<%= name.align || 'center' %>" 
                     style="left: <%= name.positionX || 50 %>%; top: <%= name.positionY || 38 %>%; 
                            font-size: <%= name.fontSize || 42 %>px; 
                            color: <%= name.color || '#004aad' %>; 
                            font-weight: <%= name.fontWeight || 'bold' %>;
                            line-height: <%= name.lineHeight || 1.2 %>;
                            letter-spacing: <%= name.letterSpacing || 0 %>px;
                            font-family: '<%= template.athleteNameFont || "Great Vibes" %>', cursive;"><%= athlete.fullName %></div>
            <% } %>
            
            <!-- IC Number -->
            <% if (template.showIcNumber) { %>
                <div class="element align-<%= ic.align || 'center' %>" 
                     style="left: <%= ic.positionX || 50 %>%; top: <%= ic.positionY || 48 %>%; 
                            font-size: <%= ic.fontSize || 14 %>px; 
                            color: <%= ic.color || '#666666' %>; 
                            font-weight: <%= ic.fontWeight || 'normal' %>;
                            line-height: <%= ic.lineHeight || 1.3 %>;
                            letter-spacing: <%= ic.letterSpacing || 0 %>px;">No. IC: <%= athlete.icNumber %></div>
            <% } %>
            
            <!-- Negeri -->
            <% if (template.showNegeri) { %>
                <div class="element align-<%= negeri.align || 'center' %>" 
                     style="left: <%= negeri.positionX || 50 %>%; top: <%= negeri.positionY || 52 %>%; 
                            font-size: <%= negeri.fontSize || 16 %>px; 
                            color: <%= negeri.color || '#000000' %>; 
                            font-weight: <%= negeri.fontWeight || 'normal' %>;
                            line-height: <%= negeri.lineHeight || 1.3 %>;
                            letter-spacing: <%= negeri.letterSpacing || 0 %>px;">Mewakili Negeri: <strong><%= athlete.negeriWakil %></strong></div>
            <% } %>
            
            <!-- Sukan -->
            <% if (template.showSukan) { %>
                <div class="element align-<%= sukan.align || 'center' %>" 
                     style="left: <%= sukan.positionX || 50 %>%; top: <%= sukan.positionY || 56 %>%; 
                            font-size: <%= sukan.fontSize || 16 %>px; 
                            color: <%= sukan.color || '#004aad' %>; 
                            font-weight: <%= sukan.fontWeight || 'bold' %>;
                            line-height: <%= sukan.lineHeight || 1.3 %>;
                            letter-spacing: <%= sukan.letterSpacing || 0 %>px;">Cabang Sukan: <strong><%= athlete.sukan || '-' %></strong></div>
            <% } %>
            
            <!-- Course Name -->
            <% if (template.showCourseName) { %>
                <div class="element align-<%= course.align || 'center' %>" 
                     style="left: <%= course.positionX || 50 %>%; top: <%= course.positionY || 60 %>%; 
                            font-size: <%= course.fontSize || 20 %>px; 
                            color: <%= course.color || '#004aad' %>; 
                            font-weight: <%= course.fontWeight || 'bold' %>;
                            line-height: <%= course.lineHeight || 1.3 %>;
                            letter-spacing: <%= course.letterSpacing || 0 %>px;"><%= course.name || template.courseName %></div>
            <% } %>
            
            <!-- Date -->
            <% if (template.showDate) { %>
                <div class="element align-<%= date.align || 'center' %>" 
                     style="left: <%= date.positionX || 50 %>%; top: <%= date.positionY || 68 %>%; 
                            font-size: <%= date.fontSize || 14 %>px; 
                            color: <%= date.color || '#000000' %>; 
                            font-weight: <%= date.fontWeight || 'normal' %>;
                            line-height: <%= date.lineHeight || 1.3 %>;
                            letter-spacing: <%= date.letterSpacing || 0 %>px;">Tarikh: <%= courseDate %></div>
            <% } %>
            
            <!-- Signatory -->
            <% if (template.showSignatory) { %>
                <div class="element align-<%= sign.align || 'left' %>" 
                     style="left: <%= sign.positionX || 20 %>%; top: <%= sign.positionY || 80 %>%; 
                            font-size: <%= sign.fontSize || 14 %>px; 
                            color: <%= sign.color || '#000000' %>; 
                            font-weight: <%= sign.fontWeight || 'bold' %>;
                            line-height: <%= sign.lineHeight || 1.3 %>;
                            letter-spacing: <%= sign.letterSpacing || 0 %>px;"><%= template.signatoryName %></div>
                
                <div class="element align-<%= signTitle.align || 'left' %>" 
                     style="left: <%= signTitle.positionX || 20 %>%; top: <%= signTitle.positionY || 85 %>%; 
                            font-size: <%= signTitle.fontSize || 12 %>px; 
                            color: <%= signTitle.color || '#666666' %>; 
                            font-weight: <%= signTitle.fontWeight || 'normal' %>;
                            line-height: <%= signTitle.lineHeight || 1.3 %>;
                            letter-spacing: <%= signTitle.letterSpacing || 0 %>px;"><%= template.signatoryTitle %></div>
            <% } %>
            
            <!-- Footer -->
            <% if (template.showFooter) { %>
                <div class="element align-center" 
                     style="left: 50%; top: 95%; 
                            font-size: 10px; 
                            color: #999999; 
                            font-weight: normal;
                            line-height: 1.3;
                            letter-spacing: 0px;"><%= template.footerLine1 %><br><%= template.footerLine2 %></div>
            <% } %>
        </div>
    </div>
    </div>
    </main>
    
    <script>
        function adjustCertificateScale() {
            const container = document.querySelector('.certificate-container');
            const wrapper = document.querySelector('.cert-scroll-wrapper');
            if (!container || !wrapper) return;

            // Ignore scaling during PDF generation
            if (container.classList.contains('html2pdf-printing')) {
                container.style.transform = 'none';
                container.style.margin = '0 auto';
                return;
            }

            const isPortrait = <%= isPortrait %>;
            const targetWidth = isPortrait ? 793 : 1122;
            const targetHeight = isPortrait ? 1122 : 793;

            // Get available width and height (accounting for header/padding)
            const availableWidth = wrapper.getBoundingClientRect().width;
            const availableHeight = window.innerHeight - 100; // Leave space for header
            
            // Calculate scale to fit either width or height, whichever is smaller
            const scaleWidth = availableWidth / targetWidth;
            const scaleHeight = availableHeight / targetHeight;
            
            // Limit max scale to 1 to avoid blurry upscaling
            let scale = Math.min(scaleWidth, scaleHeight, 1);
            
            // On mobile, if height is too restrictive (e.g. landscape keyboard), prioritize width fitting
            if (window.innerWidth < 768) {
                scale = Math.min(scaleWidth, 1);
            }

            container.style.transform = `scale(${scale})`;
            container.style.transformOrigin = 'center top';
            wrapper.style.height = `${targetHeight * scale}px`;
            wrapper.style.minHeight = 'auto';
        }

        // Run scale adjustment on load and resize
        window.addEventListener('load', adjustCertificateScale);
        window.addEventListener('resize', adjustCertificateScale);

        function downloadPDF() {
            const button = document.getElementById('btnPrintPDF');
            const originalText = button.innerHTML;
            button.innerHTML = '<%= lang === "en" ? "⏳ Generating PDF..." : "⏳ Menjana PDF..." %>';
            button.disabled = true;

            const overlay = document.getElementById('pdfLoadingOverlay');
            if (overlay) {
                overlay.querySelector('#overlayText').innerText = '<%= lang === "en" ? "Generating PDF... Please wait" : "Menjana PDF... Sila tunggu sebentar" %>';
                overlay.classList.remove('hidden');
            }

            const element = document.querySelector('.certificate-container');
            if (!element) {
                button.innerHTML = originalText;
                button.disabled = false;
                if (overlay) overlay.classList.add('hidden');
                return;
            }
            // Save original body layout and force target width for mobile capture
            const originalBodyWidth = document.body.style.width;
            const originalBodyOverflow = document.body.style.overflow;
            
            const isPortrait = <%= isPortrait %>;
            const targetWidth = isPortrait ? 793 : 1122;
            
            if (window.innerWidth < targetWidth) {
                document.body.style.width = `${targetWidth}px`;
                document.body.style.overflow = 'visible';
            }

            // Save original transform styles and clear them for printing
            const originalTransform = element.style.transform;
            const originalTransformOrigin = element.style.transformOrigin;
            element.style.transform = 'none';
            element.style.transformOrigin = 'center center';
            
            const opt = {
                margin:       0,
                pagebreak:    { mode: 'css' },
                filename:     'Sijil_<%= athlete.fullName.trim().replace(/[^a-zA-Z0-9]/g, "_") %>.pdf',
                image:        { type: 'jpeg', quality: 1.0 },
                html2canvas:  { 
                    scale: 3, // 3x high resolution scaling to prevent pixelation/blurriness while ensuring mobile compatibility
                    useCORS: true, 
                    allowTaint: false,
                    logging: false,
                    imageTimeout: 0,
                    scrollX: 0,
                    scrollY: 0
                },
                jsPDF:        { 
                    unit: 'mm', 
                    format: 'a4', 
                    orientation: isPortrait ? 'portrait' : 'landscape' 
                }
            };

            // Wait for browser repaint before capturing to ensure 100% sharpness
            setTimeout(() => {
                html2pdf().set(opt).from(element).save().then(() => {
                    document.body.style.width = originalBodyWidth;
                    document.body.style.overflow = originalBodyOverflow;
                    element.style.transform = originalTransform;
                    element.style.transformOrigin = originalTransformOrigin;
                    adjustCertificateScale();
                    
                    if (overlay) overlay.classList.add('hidden');
                    button.innerHTML = originalText;
                    button.disabled = false;
                }).catch(err => {
                    document.body.style.width = originalBodyWidth;
                    document.body.style.overflow = originalBodyOverflow;
                    element.style.transform = originalTransform;
                    element.style.transformOrigin = originalTransformOrigin;
                    adjustCertificateScale();
                    
                    if (overlay) overlay.classList.add('hidden');
                    console.error('PDF Generation Error:', err);
                    alert('<%= lang === "en" ? "Failed to generate PDF. Please try again." : "Gagal menjana PDF. Sila cuba lagi." %>');
                    button.innerHTML = originalText;
                    button.disabled = false;
                });
            }, 150);
        }
    </script>

    <!-- Image Protection Script -->
    <script>
        // Block right-click context menu on the entire page
        document.addEventListener('contextmenu', function(e) {
            e.preventDefault();
            return false;
        });

        // Block keyboard shortcuts that can save/view source/print
        document.addEventListener('keydown', function(e) {
            const key = e.key.toLowerCase();
            // Block Ctrl+S (Save), Ctrl+U (View Source), Ctrl+P (Print), Ctrl+Shift+I (DevTools), F12
            if (e.ctrlKey && (key === 's' || key === 'u' || key === 'p')) {
                e.preventDefault(); return false;
            }
            if ((e.ctrlKey && e.shiftKey && (key === 'i' || key === 'j' || key === 'c')) ||
                e.key === 'F12') {
                e.preventDefault(); return false;
            }
            // Block PrintScreen
            if (e.key === 'PrintScreen') {
                e.preventDefault();
                navigator.clipboard?.writeText('');
                return false;
            }
        });

        // Block drag on all images
        document.addEventListener('dragstart', function(e) {
            if (e.target.tagName === 'IMG') {
                e.preventDefault(); return false;
            }
        });
    </script>
    
    <!-- Full-screen loading overlay to mask the visual jump during PDF capture -->
    <div id="pdfLoadingOverlay" class="fixed inset-0 bg-slate-950/85 backdrop-blur-md z-[99999] flex flex-col items-center justify-center hidden">
        <div class="flex flex-col items-center gap-4">
            <div class="w-12 h-12 border-4 border-blue-500 border-t-transparent rounded-full animate-spin"></div>
            <p class="text-white font-semibold text-lg animate-pulse" id="overlayText">Menjana PDF...</p>
        </div>
    </div>
</body>
</html>
