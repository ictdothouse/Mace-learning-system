<!DOCTYPE html>
<html lang="ms">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>eLearning Atlet SUKMA - Kemasukan</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .tab-active { 
            border-bottom-color: #2563eb; 
            color: #2563eb;
            font-weight: 600;
        }
        .tab-inactive { 
            color: #6b7280; 
        }
        .tab-inactive:hover { 
            color: #374151; 
        }
        @media print {
            .no-print { display: none !important; }
        }
    </style>
</head>
<body class="bg-gradient-to-br from-blue-900 via-blue-800 to-blue-700 min-h-screen flex items-center justify-center p-4 sm:p-6 lg:p-8">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg overflow-hidden">
        <!-- Header with Logo -->
        <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-6 py-8 text-center">
            <div class="flex justify-center mb-4">
                <div class="bg-white/20 backdrop-blur-sm p-3 rounded-full">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                </div>
            </div>
            <h1 class="text-2xl sm:text-3xl font-bold text-white mb-2">eLearning Atlet SUKMA</h1>
            <p class="text-blue-100 text-sm sm:text-base">Majlis Sukan Negara Malaysia</p>
        </div>

        <!-- Error Message -->
        <% if (locals.error) { %>
            <div class="mx-6 mt-6 bg-red-50 border-l-4 border-red-500 p-4 rounded-r-lg shadow-sm">
                <div class="flex items-start">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-red-500 mr-3 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <div>
                        <p class="font-semibold text-red-800">Ralat</p>
                        <p class="text-red-700 text-sm mt-1"><%= error %></p>
                    </div>
                </div>
            </div>
        <% } %>

        <!-- Tab Switcher -->
        <div class="flex border-b border-gray-200 mx-6 mt-6">
            <button onclick="switchTab('new')" id="tab-new" class="flex-1 pb-3 px-2 sm:px-4 text-sm sm:text-base font-medium border-b-2 transition-all duration-200 tab-active focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
                Pengguna Baru
            </button>
            <button onclick="switchTab('resume')" id="tab-resume" class="flex-1 pb-3 px-2 sm:px-4 text-sm sm:text-base font-medium border-b-2 border-transparent transition-all duration-200 tab-inactive focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
                Semak Akaun
            </button>
        </div>

        <!-- Form Container -->
        <div class="p-6 sm:p-8">
            <!-- Form Pengguna Baru -->
            <form id="form-new" action="/access" method="POST" class="space-y-5">
                <input type="hidden" name="action" value="new">
                
                <div>
                    <label class="block text-gray-700 font-semibold mb-2 text-sm sm:text-base">Nama Penuh *</label>
                    <input type="text" name="fullName" required 
                        class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all text-sm sm:text-base uppercase-input"
                        placeholder="Contoh: AHMAD BIN ABDULLAH"
                        style="text-transform: uppercase;">
                    <p class="text-xs text-orange-600 mt-1 flex items-center gap-1">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                        </svg>
                        <strong>PENTING:</strong> Mesti sama seperti nama dalam IC untuk memudahkan log masuk kemudian.
                    </p>
                </div>

                <div>
                    <label class="block text-gray-700 font-semibold mb-2 text-sm sm:text-base">No. IC *</label>
                    <input type="text" name="icNumber" required 
                        class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all text-sm sm:text-base"
                        placeholder="Contoh: 900101011111" maxlength="12" pattern="[0-9]{12}">
                    <p class="text-xs text-gray-500 mt-1">Masukkan 12 digit nombor IC tanpa dash</p>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-gray-700 font-semibold mb-2 text-sm sm:text-base">Jantina *</label>
                        <select name="jantina" required 
                            class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all text-sm sm:text-base bg-white">
                            <option value="">Pilih</option>
                            <option value="Lelaki">Lelaki</option>
                            <option value="Perempuan">Perempuan</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-gray-700 font-semibold mb-2 text-sm sm:text-base">Umur *</label>
                        <input type="number" name="umur" required min="10" max="60"
                            class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all text-sm sm:text-base"
                            placeholder="Umur">
                    </div>
                </div>

                <div>
                    <label class="block text-gray-700 font-semibold mb-2 text-sm sm:text-base">Negeri Wakil *</label>
                    <select name="negeri" required 
                        class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all text-sm sm:text-base bg-white">
                        <option value="">Pilih Negeri</option>
                        <option>Johor</option>
                        <option>Kedah</option>
                        <option>Kelantan</option>
                        <option>Melaka</option>
                        <option>Negeri Sembilan</option>
                        <option>Pahang</option>
                        <option>Perak</option>
                        <option>Perlis</option>
                        <option>Pulau Pinang</option>
                        <option>Sabah</option>
                        <option>Sarawak</option>
                        <option>Selangor</option>
                        <option>Terengganu</option>
                        <option>W.P. Kuala Lumpur</option>
                    </select>
                </div>

                <div>
                    <label class="block text-gray-700 font-semibold mb-2 text-sm sm:text-base">Sukan *</label>
                    <input type="text" name="sukan" required id="sukanInput"
                        class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all text-sm sm:text-base uppercase-input-sukan"
                        placeholder="Contoh: BADMINTON, OLAHRAGA, RENANG"
                        style="text-transform: uppercase;">
                    <p class="text-xs text-gray-500 mt-1">Masukkan nama sukan seperti yang tercatat dalam pendaftaran rasmi. Huruf besar automatik.</p>
                </div>

                <button type="submit" 
                    class="w-full bg-blue-600 text-white font-bold py-4 rounded-lg hover:bg-blue-700 active:bg-blue-800 transition-all duration-200 transform hover:scale-[1.02] active:scale-[0.98] shadow-lg hover:shadow-xl text-sm sm:text-base flex items-center justify-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                    Mula Kursus
                </button>
            </form>

            <!-- Form Semak Akaun -->
            <form id="form-resume" action="/access" method="POST" class="space-y-5 hidden">
                <input type="hidden" name="action" value="resume">
                
                <div>
                    <label class="block text-gray-700 font-semibold mb-2 text-sm sm:text-base">Nama Penuh *</label>
                    <input type="text" name="fullName" required 
                        class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-green-500 focus:ring-2 focus:ring-green-200 outline-none transition-all text-sm sm:text-base"
                        placeholder="Nama seperti didaftarkan">
                </div>

                <div>
                    <label class="block text-gray-700 font-semibold mb-2 text-sm sm:text-base">No. IC *</label>
                    <input type="text" name="icNumber" required 
                        class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-green-500 focus:ring-2 focus:ring-green-200 outline-none transition-all text-sm sm:text-base"
                        placeholder="No. IC" maxlength="12" pattern="[0-9]{12}">
                </div>

                <button type="submit" 
                    class="w-full bg-green-600 text-white font-bold py-4 rounded-lg hover:bg-green-700 active:bg-green-800 transition-all duration-200 transform hover:scale-[1.02] active:scale-[0.98] shadow-lg hover:shadow-xl text-sm sm:text-base flex items-center justify-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    Sambung Belajar
                </button>
            </form>
        </div>

        <!-- Footer -->
        <div class="bg-gray-50 px-6 py-4 text-center border-t border-gray-200">
            <p class="text-xs text-gray-500">© 2024 Majlis Sukan Negara. Hak cipta terpelihara.</p>
        </div>
    </div>

    <script>
        function switchTab(tab) {
            const formNew = document.getElementById('form-new');
            const formResume = document.getElementById('form-resume');
            const tabNew = document.getElementById('tab-new');
            const tabResume = document.getElementById('tab-resume');

            if (tab === 'new') {
                formNew.classList.remove('hidden');
                formResume.classList.add('hidden');
                tabNew.classList.add('tab-active', 'border-blue-600');
                tabNew.classList.remove('tab-inactive', 'border-transparent');
                tabResume.classList.add('tab-inactive', 'border-transparent');
                tabResume.classList.remove('tab-active', 'border-blue-600');
            } else {
                formNew.classList.add('hidden');
                formResume.classList.remove('hidden');
                tabResume.classList.add('tab-active', 'border-blue-600');
                tabResume.classList.remove('tab-inactive', 'border-transparent');
                tabNew.classList.add('tab-inactive', 'border-transparent');
                tabNew.classList.remove('tab-active', 'border-blue-600');
            }
        }

        // Auto-format IC number
        document.querySelectorAll('input[name="icNumber"]').forEach(input => {
            input.addEventListener('input', function(e) {
                this.value = this.value.replace(/[^0-9]/g, '').slice(0, 12);
            });
        });

        // Auto-uppercase for fullName (both display and value)
        const fullNameInput = document.querySelector('form#form-new input[name="fullName"]');
        if (fullNameInput) {
            fullNameInput.addEventListener('input', function(e) {
                const cursorPos = this.selectionStart;
                const upperValue = this.value.toUpperCase();
                this.value = upperValue;
                this.setSelectionRange(cursorPos, cursorPos);
            });
            // Also ensure it's uppercase on blur
            fullNameInput.addEventListener('blur', function(e) {
                this.value = this.value.toUpperCase();
            });
        }

        // Auto-uppercase for sukan (both display and value)
        const sukanInput = document.getElementById('sukanInput');
        if (sukanInput) {
            sukanInput.addEventListener('input', function(e) {
                const cursorPos = this.selectionStart;
                const upperValue = this.value.toUpperCase();
                this.value = upperValue;
                this.setSelectionRange(cursorPos, cursorPos);
            });
            // Also ensure it's uppercase on blur
            sukanInput.addEventListener('blur', function(e) {
                this.value = this.value.toUpperCase();
            });
        }
    </script>
</body>
</html>