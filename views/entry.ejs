<!DOCTYPE html>
<html lang="<%= lang || 'ms' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= __('site_title') %> - <%= __('welcome') %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { font-family: 'Plus Jakarta Sans', sans-serif; }
        .tab-active { border-bottom-color: #2563eb; color: #2563eb; font-weight: 600; }
        .tab-inactive { color: #6b7280; }
        .tab-inactive:hover { color: #374151; }
        @keyframes fadeInUp { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }
        .fade-in { animation: fadeInUp 0.5s ease-out forwards; }
    </style>
</head>
<body class="bg-gradient-to-br from-indigo-900 via-blue-900 to-blue-800 min-h-screen flex flex-col items-center justify-center p-4 sm:p-6">

    <!-- Language Toggle (top right) -->
    <div class="fixed top-4 right-4 z-50 flex gap-1 bg-white/10 backdrop-blur-md rounded-lg p-1 border border-white/20">
        <form method="POST" action="/set-language" class="inline">
            <input type="hidden" name="lang" value="ms">
            <button type="submit" class="text-xs px-2.5 py-1 rounded font-semibold transition-all <%= lang === 'ms' ? 'bg-white text-indigo-900' : 'text-white/70 hover:text-white' %>">BM</button>
        </form>
        <form method="POST" action="/set-language" class="inline">
            <input type="hidden" name="lang" value="en">
            <button type="submit" class="text-xs px-2.5 py-1 rounded font-semibold transition-all <%= lang === 'en' ? 'bg-white text-indigo-900' : 'text-white/70 hover:text-white' %>">EN</button>
        </form>
    </div>

    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md overflow-hidden fade-in">
        <!-- Header -->
        <div class="bg-gradient-to-r from-indigo-600 to-blue-600 px-6 py-8 text-center">
            <div class="flex justify-center mb-4">
                <div class="bg-white/20 backdrop-blur-sm p-3 rounded-full">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                </div>
            </div>
            <h1 class="text-2xl sm:text-3xl font-extrabold text-white mb-1"><%= __('site_title') %></h1>
            <p class="text-indigo-100 text-sm"><%= __('site_subtitle') %></p>
        </div>

        <!-- Error Message -->
        <% if (locals.error) { %>
            <div class="mx-5 mt-5 bg-red-50 border-l-4 border-red-500 p-4 rounded-r-lg">
                <div class="flex items-start gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-red-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <div>
                        <p class="font-semibold text-red-800 text-sm"><%= __('entry_error_label') %></p>
                        <p class="text-red-700 text-sm mt-0.5"><%= error %></p>
                    </div>
                </div>
            </div>
        <% } %>

        <!-- Tab Switcher -->
        <div class="flex border-b border-gray-200 mx-5 mt-5">
            <button onclick="switchTab('new')" id="tab-new" class="flex-1 pb-3 px-2 text-sm font-medium border-b-2 transition-all duration-200 tab-active focus:outline-none">
                <%= __('entry_tab_new') %>
            </button>
            <button onclick="switchTab('resume')" id="tab-resume" class="flex-1 pb-3 px-2 text-sm font-medium border-b-2 border-transparent transition-all duration-200 tab-inactive focus:outline-none">
                <%= __('entry_tab_resume') %>
            </button>
        </div>

        <div class="p-5 sm:p-6">
            <!-- Form Pengguna Baru -->
            <form id="form-new" action="/access" method="POST" class="space-y-4">
                <input type="hidden" name="action" value="new">
                
                <div>
                    <label class="block text-gray-700 font-semibold mb-1.5 text-sm"><%= __('entry_field_fullname') %> *</label>
                    <input type="text" name="fullName" required 
                        class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none transition-all text-sm"
                        placeholder="<%= __('entry_field_fullname_placeholder') %>"
                        style="text-transform: uppercase;">
                    <p class="text-xs text-orange-600 mt-1.5 flex items-start gap-1.5">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                        </svg>
                        <span><strong><%= __('entry_important') %>:</strong> <%= __('entry_field_fullname_hint') %></span>
                    </p>
                </div>

                <div>
                    <label class="block text-gray-700 font-semibold mb-1.5 text-sm"><%= __('entry_field_ic') %> *</label>
                    <input type="text" name="icNumber" required 
                        class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none transition-all text-sm"
                        placeholder="<%= __('entry_field_ic_placeholder') %>" maxlength="12" pattern="[0-9]{12}">
                    <p class="text-xs text-gray-400 mt-1"><%= __('entry_field_ic_hint') %></p>
                </div>

                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label class="block text-gray-700 font-semibold mb-1.5 text-sm"><%= __('entry_field_gender') %> *</label>
                        <select name="jantina" required class="w-full px-3 py-3 border-2 border-gray-200 rounded-xl focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none transition-all text-sm bg-white">
                            <option value=""><%= __('entry_field_gender_select') %></option>
                            <option value="Lelaki"><%= __('entry_field_gender_male') %></option>
                            <option value="Perempuan"><%= __('entry_field_gender_female') %></option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-gray-700 font-semibold mb-1.5 text-sm"><%= __('entry_field_age') %> *</label>
                        <input type="number" name="umur" required min="10" max="60"
                            class="w-full px-3 py-3 border-2 border-gray-200 rounded-xl focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none transition-all text-sm"
                            placeholder="<%= __('entry_field_age_placeholder') %>">
                    </div>
                </div>

                <div>
                    <label class="block text-gray-700 font-semibold mb-1.5 text-sm"><%= __('entry_field_state') %> *</label>
                    <select name="negeri" required class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none transition-all text-sm bg-white">
                        <option value=""><%= __('entry_field_state_select') %></option>
                        <option>Johor</option>
                        <option>Kedah</option>
                        <option>Kelantan</option>
                        <option>Melaka</option>
                        <option>Negeri Sembilan</option>
                        <option>Pahang</option>
                        <option>Perak</option>
                        <option>Perlis</option>
                        <option>Pulau Pinang</option>
                        <option>Sabah</option>
                        <option>Sarawak</option>
                        <option>Selangor</option>
                        <option>Terengganu</option>
                        <option>W.P. Kuala Lumpur</option>
                    </select>
                </div>

                <div>
                    <label class="block text-gray-700 font-semibold mb-1.5 text-sm"><%= __('entry_field_sport') %> *</label>
                    <input type="text" name="sukan" required id="sukanInput"
                        class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none transition-all text-sm"
                        placeholder="<%= __('entry_field_sport_placeholder') %>"
                        style="text-transform: uppercase;">
                    <p class="text-xs text-gray-400 mt-1"><%= __('entry_field_sport_hint') %></p>
                </div>

                <button type="submit" 
                    class="w-full bg-indigo-600 text-white font-bold py-3.5 rounded-xl hover:bg-indigo-700 active:bg-indigo-800 transition-all duration-200 transform hover:scale-[1.01] active:scale-[0.99] shadow-lg text-sm flex items-center justify-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                    <%= __('entry_btn_start') %>
                </button>
            </form>

            <!-- Form Semak Akaun -->
            <form id="form-resume" action="/access" method="POST" class="space-y-4 hidden">
                <input type="hidden" name="action" value="resume">
                
                <div>
                    <label class="block text-gray-700 font-semibold mb-1.5 text-sm"><%= __('entry_field_fullname') %> *</label>
                    <input type="text" name="fullName" required 
                        class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-green-500 focus:ring-2 focus:ring-green-100 outline-none transition-all text-sm"
                        placeholder="<%= __('entry_resume_name_placeholder') %>">
                </div>

                <div>
                    <label class="block text-gray-700 font-semibold mb-1.5 text-sm"><%= __('entry_field_ic') %> *</label>
                    <input type="text" name="icNumber" required 
                        class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-green-500 focus:ring-2 focus:ring-green-100 outline-none transition-all text-sm"
                        placeholder="<%= __('entry_resume_ic_placeholder') %>" maxlength="12" pattern="[0-9]{12}">
                </div>

                <button type="submit" 
                    class="w-full bg-emerald-600 text-white font-bold py-3.5 rounded-xl hover:bg-emerald-700 active:bg-emerald-800 transition-all duration-200 transform hover:scale-[1.01] active:scale-[0.99] shadow-lg text-sm flex items-center justify-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <%= __('entry_btn_resume') %>
                </button>
            </form>
        </div>

        <!-- Footer -->
        <div class="bg-gray-50 px-5 py-3 text-center border-t border-gray-100">
            <p class="text-xs text-gray-400"><%= __('entry_footer') %></p>
        </div>
    </div>

    <script>
        function switchTab(tab) {
            const formNew = document.getElementById('form-new');
            const formResume = document.getElementById('form-resume');
            const tabNew = document.getElementById('tab-new');
            const tabResume = document.getElementById('tab-resume');

            if (tab === 'new') {
                formNew.classList.remove('hidden');
                formResume.classList.add('hidden');
                tabNew.classList.add('tab-active');
                tabNew.classList.remove('tab-inactive', 'border-transparent');
                tabResume.classList.add('tab-inactive', 'border-transparent');
                tabResume.classList.remove('tab-active');
            } else {
                formNew.classList.add('hidden');
                formResume.classList.remove('hidden');
                tabResume.classList.add('tab-active');
                tabResume.classList.remove('tab-inactive', 'border-transparent');
                tabNew.classList.add('tab-inactive', 'border-transparent');
                tabNew.classList.remove('tab-active');
            }
        }

        // Auto-format IC
        document.querySelectorAll('input[name="icNumber"]').forEach(input => {
            input.addEventListener('input', function() {
                this.value = this.value.replace(/[^0-9]/g, '').slice(0, 12);
            });
        });

        // Auto-uppercase fullName
        const fullNameInput = document.querySelector('form#form-new input[name="fullName"]');
        if (fullNameInput) {
            fullNameInput.addEventListener('input', function() {
                const pos = this.selectionStart;
                this.value = this.value.toUpperCase();
                this.setSelectionRange(pos, pos);
            });
        }

        // Auto-uppercase sukan
        const sukanInput = document.getElementById('sukanInput');
        if (sukanInput) {
            sukanInput.addEventListener('input', function() {
                const pos = this.selectionStart;
                this.value = this.value.toUpperCase();
                this.setSelectionRange(pos, pos);
            });
        }
    </script>
</body>
</html>