<!DOCTYPE html>
<html lang="<%= lang || 'ms' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= module.title %> - <%= (locals.branding && locals.branding.siteName) ? locals.branding.siteName : 'MACE eLearning' %></title>
    <% if (locals.branding && locals.branding.faviconUrl) { %>
    <link rel="icon" href="<%= branding.faviconUrl %>">
    <% } %>
    <!-- Preconnect to external domains for faster resource loading -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://cdn.tailwindcss.com">
    <!-- Preload LCP Hero Image to avoid 3-second resource load delay on mobile -->
    <% if (module.thumbnail) { %>
    <link rel="preload" as="image" href="<%= module.thumbnail %>">
    <% } %>
    <!-- Tailwind CSS: loaded async so it does not block initial render (saves 810ms) -->
    <link rel="preload" href="https://cdn.tailwindcss.com" as="script">
    <script src="https://cdn.tailwindcss.com" defer></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
    <noscript><link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet"></noscript>
    <style>
        :root {
            --primary-color: <%= locals.branding?.primaryColor || '#4f46e5' %>;
        }
        * { font-family: 'Plus Jakarta Sans', sans-serif; }
        .bg-primary { background-color: var(--primary-color); }
        .text-primary { color: var(--primary-color); }
        
        .prose p { margin-bottom: 1em; line-height: 1.7; color: #374151; }
        .prose h1 { font-size: 2.25rem; font-weight: 800; margin-bottom: 1rem; color: #111827; }
        .prose h2 { font-size: 1.5rem; font-weight: 700; margin-top: 1.5rem; margin-bottom: 1rem; color: #1f2937; }
    </style>
</head>
<body class="min-h-screen flex flex-col bg-gray-50">

    <!-- Top Header -->
    <nav class="bg-[#0f172a] text-white py-4 px-6 md:px-12 z-20 relative shadow-md">
        <div class="max-w-6xl mx-auto flex justify-between items-center w-full">
            <div class="flex items-center gap-4">
                <a href="/" class="flex items-center gap-3">
                    <% if (locals.branding && locals.branding.logoUrl) { %>
                        <img src="<%= branding.logoUrl %>" alt="Logo" class="h-8 md:h-10 w-auto object-contain">
                    <% } else { %>
                        <h1 class="text-lg md:text-xl font-extrabold uppercase tracking-wider"><%= (locals.branding && locals.branding.siteName) ? locals.branding.siteName : 'MACE' %></h1>
                    <% } %>
                </a>
            </div>
            
            <div class="flex items-center gap-4 md:gap-6">
                <!-- Dynamic Menu -->
                <div class="hidden md:flex items-center gap-6">
                    <a href="/" class="text-sm font-medium hover:text-gray-300 transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4.5 w-4.5 inline -mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                        </svg>
                    </a>
                    
                    <% if (locals.branding && branding.showMenu && branding.menuLinks && branding.menuLinks.length > 0) { %>
                        <% branding.menuLinks.forEach(link => { %>
                            <a href="<%= link.url %>" class="text-sm font-medium hover:text-gray-300 transition-colors"><%= lang === 'en' ? (link.label_en || ((link.label||'').trim().toLowerCase() === 'modul' ? 'Modules' : ((link.label||'').trim().toLowerCase() === 'hubungi kami' ? 'Contact Us' : link.label))) : link.label %></a>
                        <% }) %>
                    <% } %>

                    <% if (locals.navPages && navPages.length > 0) { %>
                        <% navPages.forEach(p => { %>
                            <a href="/page/<%= p.slug %>" class="text-sm font-medium hover:text-gray-300 transition-colors pb-1"><%= lang === 'en' ? (p.title_en || p.title) : p.title %></a>
                        <% }) %>
                    <% } %>
                </div>

                <!-- Language Switcher -->
                <div class="flex items-center gap-2 bg-white/10 rounded-lg p-1 border border-white/20">
                    <a href="?lang=ms" class="text-xs px-2 py-1 rounded font-semibold transition-all <%= lang === 'ms' ? 'bg-white text-gray-900' : 'text-white/70 hover:text-white' %>">BM</a>
                    <a href="?lang=en" class="text-xs px-2 py-1 rounded font-semibold transition-all <%= lang === 'en' ? 'bg-white text-gray-900' : 'text-white/70 hover:text-white' %>">EN</a>
                </div>

                <!-- Mobile Menu Toggle -->
                <button onclick="toggleMobileMenu()" class="md:hidden text-white hover:text-gray-300 focus:outline-none p-1 rounded-lg hover:bg-white/10 transition">
                    <svg id="mobile-menu-icon" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                    </svg>
                </button>
            </div>
        </div>
    </nav>

    <!-- Mobile Drawer -->
    <div id="mobile-drawer" class="hidden md:hidden bg-[#0f172a] border-t border-white/10 text-white py-3 px-6 space-y-1 transition-all duration-300 z-10">
        <a href="/" class="block text-sm font-medium py-2 border-b border-white/5 hover:text-orange-400 transition-colors"><%= lang === 'en' ? 'Home' : 'Laman Utama' %></a>
        <% if (locals.branding && branding.showMenu && branding.menuLinks && branding.menuLinks.length > 0) { %>
            <% branding.menuLinks.forEach(link => { %>
                <a href="<%= link.url %>" class="block text-sm font-medium py-2 border-b border-white/5 hover:text-orange-400 transition-colors"><%= lang === 'en' ? (link.label_en || link.label) : link.label %></a>
            <% }) %>
        <% } %>
    </div>

    <!-- Hero Banner -->
    <div class="relative bg-gradient-to-r from-blue-950 to-indigo-900 text-white py-20 px-6 md:px-12 text-left shadow-lg overflow-hidden">
        <!-- LCP Hero Image: uses <img> with fetchpriority=high for immediate LCP discovery -->
        <% if (module.thumbnail) { %>
        <img 
            src="<%= module.thumbnail %>"
            alt="<%= module.title %>"
            fetchpriority="high"
            class="absolute inset-0 w-full h-full object-cover opacity-20 mix-blend-overlay"
            style="z-index:0;"
        >
        <% } else { %>
        <div class="absolute inset-0 opacity-20 mix-blend-overlay bg-cover bg-center" style="background-image: url('https://images.unsplash.com/photo-1461896836934-ffe607ba8211?q=80&w=1200&auto=format&fit=crop');"></div>
        <% } %>
        <div class="relative z-10 max-w-5xl mx-auto">
            <h3 class="text-sm font-bold text-orange-400 uppercase tracking-widest mb-2"><%= lang === 'en' ? 'MODULE 1' : 'MODUL 1' %></h3>
            <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight uppercase mb-4 drop-shadow-md">
                <%= module.title %>
            </h1>
        </div>
    </div>

    <!-- Main Content Area -->
    <div class="flex-grow py-12 px-6 md:px-12 bg-white">
        <div class="max-w-4xl mx-auto">
            
            <% if (levels && levels.length > 0) { %>
                <!-- Levels Accordion Grid -->
                <div class="border border-gray-200 rounded-xl overflow-hidden shadow-sm divide-y divide-gray-200">
                    <% levels.forEach((lvl, index) => { %>
                        <div class="bg-white">
                            <!-- Accordion Header -->
                            <button onclick="toggleAccordion(<%= index %>)" class="w-full flex justify-between items-center px-6 py-5 text-left font-bold transition hover:bg-gray-50 select-none <%= index === 0 ? 'bg-orange-50/80 text-orange-800' : 'text-gray-800' %>">
                                <div class="flex items-center gap-3">
                                    <% if (index === 0) { %>
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-orange-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M18 12H6" /></svg>
                                    <% } else { %>
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-orange-500 fill-orange-500" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                                    <% } %>
                                    <span class="text-sm md:text-base font-extrabold uppercase tracking-wide">
                                        <%= lvl.name %> <%= index === 0 ? (lang === 'en' ? '- ACTIVE MODULE' : '- MODUL AKTIF') : '' %>
                                    </span>
                                </div>
                                <span id="icon-<%= index %>" class="<%= index === 0 ? 'text-orange-500' : 'text-gray-400' %> text-lg transition-transform duration-200 <%= index === 0 ? 'rotate-180' : '' %>">&#9662;</span>
                            </button>

                            <!-- Accordion Body -->
                            <div id="body-<%= index %>" class="<%= index === 0 ? 'block' : 'hidden' %> bg-gray-50 border-t border-gray-100 px-8 py-6">
                                <div class="max-w-xl space-y-5">
                                    <% if (lvl.description) { %>
                                        <p class="text-sm text-gray-600 mb-4"><%= lvl.description %></p>
                                    <% } %>

                                    <div>
                                        <h5 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">
                                            <%= lang === 'en' ? 'Who to complete? / Who needs to participate' : 'Siapa yang perlu menyertai?' %>
                                        </h5>
                                        <p class="text-sm font-extrabold text-gray-700">
                                            - <%= lvl.targetAudience || (lang === 'en' ? 'General athlete' : 'Atlet umum') %>
                                        </p>
                                    </div>

                                    <div>
                                        <h5 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">
                                            <%= lang === 'en' ? 'Estimate time to complete / Module duration' : 'Anggaran masa pembelajaran / Tempoh modul' %>
                                        </h5>
                                        <p class="text-sm font-extrabold text-gray-700">
                                            - <%= lvl.duration || (lang === 'en' ? '15 mins' : '15 minit') %>
                                        </p>
                                    </div>

                                    <div class="pt-4">
                                        <% if (lvl.firstLessonId) { %>
                                            <% if (isLoggedIn) { %>
                                                <a href="/lesson/<%= lvl.firstLessonId %>" class="inline-flex items-center gap-2 bg-orange-500 hover:bg-orange-600 text-white font-bold px-6 py-3 rounded-lg transition shadow-md hover:shadow-lg">
                                                    <!-- Star/Gear icon -->
                                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                                                    <%= lang === 'en' ? 'Start Module' : 'Mula Modul' %>
                                                </a>
                                            <% } else { %>
                                                <a href="/" onclick="alert('<%= lang === 'en' ? 'Please register or check your account to start the module.' : 'Sila daftar atau semak akaun untuk memulakan modul.' %>')" class="inline-flex items-center gap-2 bg-orange-500 hover:bg-orange-600 text-white font-bold px-6 py-3 rounded-lg transition shadow-md hover:shadow-lg">
                                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                                                    <%= lang === 'en' ? 'Start Module' : 'Mula Modul' %>
                                                </a>
                                            <% } %>
                                        <% } else { %>
                                            <p class="text-xs text-gray-400 italic">
                                                <%= lang === 'en' ? 'No lessons registered for this level yet.' : 'Tiada pelajaran didaftarkan untuk peringkat ini lagi.' %>
                                            </p>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <!-- Module without levels: show description and a big Start Button -->
                <div class="bg-gray-50 border border-gray-200 rounded-xl p-8 text-center max-w-xl mx-auto shadow-sm">
                    <div class="prose max-w-none mb-6 text-gray-700 text-left">
                        <%- module.description %>
                    </div>
                    <div class="pt-4">
                        <% if (isLoggedIn) { %>
                            <a href="/lesson/<%= firstLessonId %>" class="inline-flex items-center gap-2 bg-orange-500 hover:bg-orange-600 text-white font-bold px-8 py-3 rounded-lg transition shadow-md hover:shadow-lg">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                <%= lang === 'en' ? 'Start Module' : 'Mula Modul' %>
                            </a>
                        <% } else { %>
                            <a href="/" onclick="alert('<%= lang === 'en' ? 'Please register or check your account to start the module.' : 'Sila daftar atau semak akaun untuk memulakan modul.' %>')" class="inline-flex items-center gap-2 bg-orange-500 hover:bg-orange-600 text-white font-bold px-8 py-3 rounded-lg transition shadow-md hover:shadow-lg">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                <%= lang === 'en' ? 'Start Module' : 'Mula Modul' %>
                            </a>
                        <% } %>
                    </div>
                </div>
            <% } %>

        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-white px-5 py-6 text-center border-t border-gray-200 z-10 relative mt-auto">
        <div class="max-w-6xl mx-auto flex flex-col items-center justify-center gap-2 text-xs text-gray-500 font-medium">
            <div>
                <%- (locals.branding && branding.footerText) ? branding.footerText : '&copy; 2026 Majlis Sukan Negara Malaysia. Sistem eLearning Atlet MACE v2.0' %>
            </div>
            <% if (locals.branding && branding.footerLinks && branding.footerLinks.length > 0) { %>
                <div class="flex flex-wrap justify-center gap-3 mt-1">
                    <% branding.footerLinks.forEach((link, idx) => { %>
                        <a href="<%= link.url %>" class="hover:underline transition-colors"><%= lang === 'en' ? (link.label_en || link.label) : link.label %></a>
                        <% if (idx < branding.footerLinks.length - 1) { %><span class="text-gray-300">|</span><% } %>
                    <% }) %>
                </div>
            <% } %>
        </div>
    </footer>

    <script>
        function toggleMobileMenu() {
            const drawer = document.getElementById('mobile-drawer');
            drawer.classList.toggle('hidden');
        }

        function toggleAccordion(index) {
            const body = document.getElementById(`body-${index}`);
            const icon = document.getElementById(`icon-${index}`);
            
            if (body.classList.contains('hidden')) {
                body.classList.remove('hidden');
                icon.classList.add('rotate-180');
            } else {
                body.classList.add('hidden');
                icon.classList.remove('rotate-180');
            }
        }
    </script>
</body>
</html>
