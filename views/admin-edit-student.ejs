<!DOCTYPE html>
<html lang="ms">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit <%= getTerm('student') %> - Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50">
    <div class="min-h-screen p-8">
        <div class="max-w-2xl mx-auto bg-white rounded-xl shadow-sm border border-gray-100 p-8">
            <div class="mb-6">
                <a href="/admin-mace/students" class="text-blue-600 hover:text-blue-800 text-sm mb-4 inline-block">&larr; Kembali ke Senarai <%= getTerm('student') %></a>
                <h1 class="text-2xl font-bold text-gray-900">Edit Maklumat <%= getTerm('student') %></h1>
                <p class="text-gray-500 text-sm mt-1">Kemaskini maklumat <%= getTerm('student').toLowerCase() %> dan tetapkan kumpulan.</p>
            </div>

            <% if (student) { %>
                <form action="/admin-mace/students/edit/<%= student._id %>" method="POST" class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Nama Penuh</label>
                        <input type="text" name="fullName" value="<%= student.fullName %>" required class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none">
                    </div>
                    <% if (!isAthleteRecord) { %>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Username</label>
                            <input type="text" name="username" value="<%= student.username || '' %>" required class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none font-mono lowercase">
                        </div>
                    <% } %>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Email (Pilihan)</label>
                        <input type="email" name="email" value="<%= student.email %>" class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Password Baru (kosongkan jika tidak mahu tukar)</label>
                        <input type="password" name="password" placeholder="Biarkan kosong jika tidak mahu tukar" class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Kumpulan</label>
                        <select name="groupIds" class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none bg-white">
                            <option value="">-- Tiada Kumpulan --</option>
                            <% (groups || []).forEach(g => { %>
                                <option value="<%= g._id %>" <%= student.enrolledGroups && student.enrolledGroups.some(grp => grp._id.toString() === g._id.toString()) ? 'selected' : '' %>><%= g.name %> (Key: <%= g.enrollmentKey %>)</option>
                            <% }) %>
                        </select>
                        <p class="text-xs text-gray-500 mt-1"><%= getTerm('student') %> akan dapat akses modul yang ditetapkan untuk kumpulan ini.</p>
                    </div>
                    <div class="flex items-center gap-2">
                        <input type="checkbox" name="isActive" id="isActive" <%= student.isActive ? 'checked' : '' %> class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
                        <label for="isActive" class="text-sm text-gray-700">Akaun Aktif</label>
                    </div>
                    <div class="pt-4 flex gap-3">
                        <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded-lg font-medium hover:bg-blue-700 transition">Simpan Perubahan</button>
                        <a href="/admin-mace/students" class="bg-gray-100 text-gray-700 px-6 py-2 rounded-lg font-medium hover:bg-gray-200 transition">Batal</a>
                    </div>
                </form>
            <% } %>
        </div>
    </div>
</body>
</html>
