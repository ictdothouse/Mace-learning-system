<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MACE Server MonitorPanel</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .terminal {
            background-color: #1e1e1e;
            color: #00ff00;
            font-family: 'Courier New', Courier, monospace;
            padding: 1rem;
            border-radius: 0.5rem;
            height: 300px;
            overflow-y: auto;
            white-space: pre-wrap;
            box-shadow: inset 0 0 10px rgba(0,0,0,0.5);
        }
        .terminal::-webkit-scrollbar {
            width: 8px;
        }
        .terminal::-webkit-scrollbar-track {
            background: #111; 
        }
        .terminal::-webkit-scrollbar-thumb {
            background: #555; 
            border-radius: 4px;
        }
        .terminal::-webkit-scrollbar-thumb:hover {
            background: #888; 
        }
    </style>
</head>
<body class="bg-gray-50 min-h-screen text-gray-800 font-sans">
    
    <div class="max-w-5xl mx-auto p-6 pt-10">
        
        <!-- Header -->
        <div class="flex justify-between items-center bg-blue-600 text-white p-6 rounded-xl shadow-lg mb-8">
            <div>
                <h1 class="text-2xl font-bold flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" /></svg>
                    MACE MonitorPanel
                </h1>
                <p class="text-blue-100 text-sm mt-1">Urus pelayan dan sistem Node.js dengan mudah.</p>
            </div>
            <div class="text-right">
                <p class="text-xs text-blue-200">Status Pelayan</p>
                <div class="flex items-center gap-2 mt-1">
                    <span class="relative flex h-3 w-3">
                      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                      <span class="relative inline-flex rounded-full h-3 w-3 bg-green-500"></span>
                    </span>
                    <span class="font-semibold text-sm">Online</span>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <!-- System Stats -->
            <div class="bg-white p-5 rounded-xl shadow-sm border border-gray-100">
                <h3 class="text-sm font-semibold text-gray-500 mb-4">Penggunaan RAM</h3>
                <div class="flex items-end justify-between mb-2">
                    <span class="text-2xl font-bold text-gray-800"><%= systemInfo.usedMem %></span>
                    <span class="text-sm text-gray-400 mb-1">/ <%= systemInfo.totalMem %></span>
                </div>
                <div class="w-full bg-gray-200 rounded-full h-2.5">
                  <div class="bg-blue-600 h-2.5 rounded-full" style="width: <%= systemInfo.memPercent %>%"></div>
                </div>
            </div>
            
            <div class="bg-white p-5 rounded-xl shadow-sm border border-gray-100">
                <h3 class="text-sm font-semibold text-gray-500 mb-4">CPU Core & Platform</h3>
                <p class="text-xl font-bold text-gray-800"><%= systemInfo.cpus %> Core(s)</p>
                <p class="text-sm text-gray-500 mt-1 capitalize"><%= systemInfo.platform %> (<%= systemInfo.release %>)</p>
            </div>

            <div class="bg-white p-5 rounded-xl shadow-sm border border-gray-100">
                <h3 class="text-sm font-semibold text-gray-500 mb-4">Uptime Pelayan</h3>
                <p class="text-xl font-bold text-gray-800"><%= systemInfo.uptime %></p>
                <p class="text-sm text-gray-500 mt-1">Masa berlalu sejak reboot.</p>
            </div>
        </div>

        <!-- Layout Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
            
            <!-- Tindakan / Butang -->
            <div class="lg:col-span-4 space-y-6">
                <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
                    <h2 class="text-lg font-bold mb-4">Pusat Kawalan Node.js</h2>
                    
                    <div class="space-y-3">
                        <button onclick="runCommand('pm2 status')" class="w-full text-left px-4 py-3 bg-gray-50 hover:bg-gray-100 border border-gray-200 rounded-lg flex items-center gap-3 transition">
                            <span class="bg-gray-200 text-gray-700 p-2 rounded-md">📊</span>
                            <div>
                                <p class="font-semibold text-sm">PM2 Status</p>
                                <p class="text-xs text-gray-500">Semak status sistem</p>
                            </div>
                        </button>

                        <button onclick="runCommand('git pull origin main')" class="w-full text-left px-4 py-3 bg-blue-50 hover:bg-blue-100 border border-blue-200 rounded-lg flex items-center gap-3 transition">
                            <span class="bg-blue-200 text-blue-700 p-2 rounded-md">⬇️</span>
                            <div>
                                <p class="font-semibold text-sm text-blue-900">Git Pull</p>
                                <p class="text-xs text-blue-700">Tarik kod baru dari GitHub</p>
                            </div>
                        </button>
                        
                        <button onclick="runCommand('pm2 restart mace-system --update-env')" class="w-full text-left px-4 py-3 bg-amber-50 hover:bg-amber-100 border border-amber-200 rounded-lg flex items-center gap-3 transition">
                            <span class="bg-amber-200 text-amber-700 p-2 rounded-md">🔄</span>
                            <div>
                                <p class="font-semibold text-sm text-amber-900">Restart Sistem</p>
                                <p class="text-xs text-amber-700">Mula semula sistem utama</p>
                            </div>
                        </button>

                        <button onclick="runCommand('pm2 logs mace-system --lines 50 --nostream')" class="w-full text-left px-4 py-3 bg-purple-50 hover:bg-purple-100 border border-purple-200 rounded-lg flex items-center gap-3 transition">
                            <span class="bg-purple-200 text-purple-700 p-2 rounded-md">📝</span>
                            <div>
                                <p class="font-semibold text-sm text-purple-900">Baca Log Server</p>
                                <p class="text-xs text-purple-700">Lihat ralat 50 baris terakhir</p>
                            </div>
                        </button>
                    </div>
                </div>

                <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
                    <h2 class="text-lg font-bold mb-4">Pusat Kawalan MongoDB</h2>
                    
                    <div class="space-y-3">
                        <button onclick="runCommand('sudo systemctl status mongod')" class="w-full text-left px-4 py-3 bg-green-50 hover:bg-green-100 border border-green-200 rounded-lg flex items-center gap-3 transition">
                            <span class="bg-green-200 text-green-700 p-2 rounded-md">🟢</span>
                            <div>
                                <p class="font-semibold text-sm text-green-900">Status MongoDB</p>
                                <p class="text-xs text-green-700">Semak sama ada DB aktif</p>
                            </div>
                        </button>

                        <button onclick="runCommand('sudo systemctl restart mongod')" class="w-full text-left px-4 py-3 bg-red-50 hover:bg-red-100 border border-red-200 rounded-lg flex items-center gap-3 transition">
                            <span class="bg-red-200 text-red-700 p-2 rounded-md">🔁</span>
                            <div>
                                <p class="font-semibold text-sm text-red-900">Restart MongoDB</p>
                                <p class="text-xs text-red-700">Jika berlaku ralat 502</p>
                            </div>
                        </button>
                    </div>
                </div>

                <!-- Auto Deploy Info Box -->
                <div class="bg-gradient-to-br from-gray-900 to-gray-800 p-6 rounded-xl shadow-sm text-white">
                    <h2 class="text-lg font-bold mb-2 flex items-center gap-2">
                        <span>⚡</span> Auto Deploy
                    </h2>
                    <p class="text-sm text-gray-300 mb-4 leading-relaxed">
                        Anda boleh setup webhook di GitHub untuk tarik kod automatik tanpa perlu klik manual.
                    </p>
                    <div class="bg-black/50 p-3 rounded-lg border border-gray-700">
                        <p class="text-xs text-gray-400 mb-1">Payload URL:</p>
                        <code class="text-xs text-green-400 select-all font-mono break-all">http://IP_VPS_ANDA:4000/webhook/github</code>
                    </div>
                    <p class="text-xs text-gray-400 mt-3 italic">
                        Pergi ke GitHub Repository > Settings > Webhooks > Add Webhook. Pilih Content type "application/json".
                    </p>
                </div>
            </div>

            <!-- Terminal Output -->
            <div class="lg:col-span-8">
                <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 h-full flex flex-col">
                    <div class="flex justify-between items-center mb-4">
                        <h2 class="text-lg font-bold">Terminal Output</h2>
                        <span id="loader" class="hidden text-sm text-blue-600 font-semibold flex items-center gap-2">
                            <svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                            Menjalankan arahan...
                        </span>
                    </div>
                    <div id="terminal" class="terminal flex-grow">Selamat datang ke MACE MonitorPanel.
Sila klik butang di sebelah kiri untuk menjalankan arahan server.</div>
                </div>
            </div>

        </div>
    </div>

    <script>
        async function runCommand(cmd) {
            const terminal = document.getElementById('terminal');
            const loader = document.getElementById('loader');
            
            terminal.innerHTML += `\n\n<span style="color:#fff;">$ ${cmd}</span>\n`;
            terminal.scrollTop = terminal.scrollHeight;
            
            loader.classList.remove('hidden');

            try {
                const res = await fetch('/api/exec', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ cmd })
                });
                
                const data = await res.json();
                
                if (data.error) {
                    terminal.innerHTML += `<span style="color:#ff5555;">[Error] ${data.error}</span>`;
                } else {
                    // escape html to prevent rendering issues in terminal
                    const safeOutput = data.output.replace(/</g, "&lt;").replace(/>/g, "&gt;");
                    terminal.innerHTML += safeOutput;
                }
            } catch (err) {
                terminal.innerHTML += `<span style="color:#ff5555;">[Network Error] Gagal menghubungi pelayan.</span>`;
            }
            
            loader.classList.add('hidden');
            terminal.scrollTop = terminal.scrollHeight;
        }
    </script>
</body>
</html>
