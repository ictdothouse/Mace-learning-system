<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MACE Server MonitorPanel</title>
    <!-- Shadcn UI heavily relies on Inter font -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    },
                    colors: {
                        border: "hsl(214.3 31.8% 91.4%)",
                        input: "hsl(214.3 31.8% 91.4%)",
                        ring: "hsl(222.2 84% 4.9%)",
                        background: "hsl(0 0% 100%)",
                        foreground: "hsl(222.2 84% 4.9%)",
                        primary: {
                            DEFAULT: "hsl(222.2 47.4% 11.2%)",
                            foreground: "hsl(210 40% 98%)",
                        },
                        secondary: {
                            DEFAULT: "hsl(210 40% 96.1%)",
                            foreground: "hsl(222.2 47.4% 11.2%)",
                        },
                        destructive: {
                            DEFAULT: "hsl(0 84.2% 60.2%)",
                            foreground: "hsl(210 40% 98%)",
                        },
                        muted: {
                            DEFAULT: "hsl(210 40% 96.1%)",
                            foreground: "hsl(215.4 16.3% 46.9%)",
                        },
                        accent: {
                            DEFAULT: "hsl(210 40% 96.1%)",
                            foreground: "hsl(222.2 47.4% 11.2%)",
                        },
                        card: {
                            DEFAULT: "hsl(0 0% 100%)",
                            foreground: "hsl(222.2 84% 4.9%)",
                        },
                    },
                    borderRadius: {
                        lg: "0.5rem",
                        md: "calc(0.5rem - 2px)",
                        sm: "calc(0.5rem - 4px)",
                    }
                }
            }
        }
    </script>
    <style>
        .terminal {
            background-color: #09090b;
            color: #a1a1aa; /* zinc-400 */
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
            padding: 1.25rem;
            border-radius: 0.5rem;
            height: 350px;
            overflow-y: auto;
            white-space: pre-wrap;
            font-size: 0.875rem;
            line-height: 1.5;
        }
        .terminal::-webkit-scrollbar {
            width: 8px;
        }
        .terminal::-webkit-scrollbar-track {
            background: #18181b; 
        }
        .terminal::-webkit-scrollbar-thumb {
            background: #3f3f46; 
            border-radius: 4px;
        }
        .terminal::-webkit-scrollbar-thumb:hover {
            background: #52525b; 
        }
        .term-cmd { color: #fafafa; font-weight: 500; }
        .term-err { color: #ef4444; }
        .term-info { color: #10b981; }
    </style>
</head>
<body class="bg-zinc-50 min-h-screen text-foreground antialiased selection:bg-primary selection:text-primary-foreground">
    
    <div class="max-w-6xl mx-auto p-6 pt-10">
        
        <!-- Header -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center bg-card text-card-foreground p-6 rounded-xl shadow-sm border border-border mb-8 gap-4">
            <div>
                <h1 class="text-2xl font-bold tracking-tight flex items-center gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M7 7h10"/><path d="M7 12h10"/><path d="M7 17h10"/></svg>
                    MACE MonitorPanel
                </h1>
                <p class="text-muted-foreground text-sm mt-1">Sistem Pemantauan Automasi Node.js & MongoDB</p>
            </div>
            <div class="flex items-center gap-3 bg-secondary px-4 py-2 rounded-md border border-border">
                <span class="relative flex h-2.5 w-2.5">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-500"></span>
                </span>
                <span class="font-medium text-sm">Server Aktif</span>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <!-- System Stats -->
            <div class="bg-card p-5 rounded-xl shadow-sm border border-border flex flex-col justify-between">
                <div>
                    <h3 class="text-sm font-medium text-muted-foreground mb-4">Penggunaan RAM</h3>
                    <div class="flex items-baseline gap-2 mb-3">
                        <span class="text-3xl font-bold tracking-tight"><%= systemInfo.usedMem %></span>
                        <span class="text-sm text-muted-foreground font-medium">/ <%= systemInfo.totalMem %></span>
                    </div>
                </div>
                <div class="w-full bg-secondary rounded-full h-2 overflow-hidden">
                  <div class="bg-primary h-2 rounded-full transition-all duration-500" style="width: <%= systemInfo.memPercent %>%"></div>
                </div>
            </div>
            
            <div class="bg-card p-5 rounded-xl shadow-sm border border-border flex flex-col justify-between">
                <div>
                    <h3 class="text-sm font-medium text-muted-foreground mb-4">Senibina Sistem</h3>
                    <p class="text-3xl font-bold tracking-tight"><%= systemInfo.cpus %> <span class="text-lg font-semibold text-muted-foreground">Cores</span></p>
                </div>
                <p class="text-sm text-muted-foreground mt-4 capitalize font-medium flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><rect width="16" height="16" x="4" y="4" rx="2"/><rect width="6" height="6" x="9" y="9" rx="1"/><path d="M15 2v2"/><path d="M15 20v2"/><path d="M2 15h2"/><path d="M2 9h2"/><path d="M20 15h2"/><path d="M20 9h2"/><path d="M9 2v2"/><path d="M9 20v2"/></svg>
                    <%= systemInfo.platform %> (<%= systemInfo.release %>)
                </p>
            </div>

            <div class="bg-card p-5 rounded-xl shadow-sm border border-border flex flex-col justify-between">
                <div>
                    <h3 class="text-sm font-medium text-muted-foreground mb-4">Uptime Pelayan</h3>
                    <p class="text-3xl font-bold tracking-tight"><%= systemInfo.uptime %></p>
                </div>
                <p class="text-sm text-muted-foreground mt-4 font-medium flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    Waktu operasi sejak reboot
                </p>
            </div>
        </div>

        <!-- Layout Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
            
            <!-- Tindakan / Butang -->
            <div class="lg:col-span-4 space-y-6">
                
                <div class="bg-card p-6 rounded-xl shadow-sm border border-border">
                    <div class="mb-5">
                        <h2 class="text-lg font-semibold tracking-tight">Kemas Kini & Tarik Kod</h2>
                        <p class="text-sm text-muted-foreground mt-1">Ambil kod terbaru dari GitHub rasmi.</p>
                    </div>
                    
                    <button onclick="runCommand('git pull origin main')" class="w-full inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-primary text-primary-foreground hover:bg-primary/90 h-10 px-4 py-2 gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                        Git Pull (Update System)
                    </button>
                </div>

                <div class="bg-card p-6 rounded-xl shadow-sm border border-border">
                    <div class="mb-5">
                        <h2 class="text-lg font-semibold tracking-tight">Kawalan PM2 (Node.js)</h2>
                        <p class="text-sm text-muted-foreground mt-1">Uruskan proses aplikasi web utama.</p>
                    </div>
                    
                    <div class="space-y-3">
                        <button onclick="runCommand('pm2 restart mace-system --update-env')" class="w-full inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 border border-input bg-background hover:bg-accent hover:text-accent-foreground h-10 px-4 py-2 gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
                            Restart Aplikasi Utama
                        </button>
                        
                        <div class="grid grid-cols-2 gap-3">
                            <button onclick="runCommand('pm2 status')" class="inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 border border-input bg-background hover:bg-accent hover:text-accent-foreground h-9 px-3 gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><line x1="18" x2="18" y1="20" y2="10"/><line x1="12" x2="12" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="14"/></svg>
                                Status
                            </button>
                            <button onclick="runCommand('pm2 logs mace-system --lines 50 --nostream')" class="inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 border border-input bg-background hover:bg-accent hover:text-accent-foreground h-9 px-3 gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" x2="8" y1="13" y2="13"/><line x1="16" x2="8" y1="17" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                                Baca Log
                            </button>
                        </div>
                    </div>
                </div>

                <div class="bg-card p-6 rounded-xl shadow-sm border border-border">
                    <div class="mb-5">
                        <h2 class="text-lg font-semibold tracking-tight">Kawalan MongoDB</h2>
                        <p class="text-sm text-muted-foreground mt-1">Urus perkhidmatan pangkalan data.</p>
                    </div>
                    
                    <div class="grid grid-cols-2 gap-3">
                        <button onclick="runCommand('sudo systemctl status mongod')" class="inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 border border-input bg-background hover:bg-accent hover:text-accent-foreground h-9 px-3 gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
                            Status DB
                        </button>

                        <button onclick="runCommand('sudo systemctl restart mongod')" class="inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 border border-destructive/30 bg-background text-destructive hover:bg-destructive/10 h-9 px-3 gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
                            Restart
                        </button>
                    </div>
                </div>

                <button onclick="runCommand('pm2 restart mace-monitor')" class="w-full inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 border border-input bg-secondary hover:bg-secondary/80 text-secondary-foreground h-9 px-4 gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
                    Restart MonitorPanel
                </button>

            </div>

            <!-- Terminal Output -->
            <div class="lg:col-span-8 flex flex-col h-full min-h-[500px]">
                <div class="bg-card p-6 rounded-xl shadow-sm border border-border h-full flex flex-col">
                    <div class="flex justify-between items-center mb-5">
                        <div class="flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-muted-foreground"><polyline points="4 17 10 11 4 5"/><line x1="12" x2="20" y1="19" y2="19"/></svg>
                            <h2 class="text-lg font-semibold tracking-tight">Keluaran Terminal</h2>
                        </div>
                        <span id="loader" class="hidden text-sm text-primary font-medium flex items-center gap-2">
                            <svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                            Menjalankan arahan...
                        </span>
                    </div>
                    
                    <!-- Alert Box untuk Ralat & Amaran -->
                    <div id="alertBox" class="hidden mb-4 p-4 rounded-md border text-sm font-mono whitespace-pre-wrap max-h-40 overflow-y-auto shadow-sm"></div>

                    <div class="relative flex-grow flex flex-col">
                        <!-- Mac style window dots -->
                        <div class="absolute top-0 left-0 w-full bg-[#18181b] h-8 rounded-t-md flex items-center px-4 border-b border-[#27272a] z-10">
                            <div class="flex gap-1.5">
                                <div class="w-3 h-3 rounded-full bg-[#ff5f56]"></div>
                                <div class="w-3 h-3 rounded-full bg-[#ffbd2e]"></div>
                                <div class="w-3 h-3 rounded-full bg-[#27c93f]"></div>
                            </div>
                            <div class="mx-auto text-[#71717a] text-xs font-medium font-sans">ubuntu@mace-server:~</div>
                        </div>
                        <div id="terminal" class="terminal flex-grow pt-10 rounded-md border border-[#27272a] shadow-sm">Welcome to MACE MonitorPanel v2.0
Ready to execute commands. Please select an action from the left panel.</div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script>
        async function runCommand(cmd) {
            const terminal = document.getElementById('terminal');
            const loader = document.getElementById('loader');
            const alertBox = document.getElementById('alertBox');
            
            alertBox.classList.add('hidden');
            alertBox.className = 'hidden mb-4 p-4 rounded-md border text-sm font-mono whitespace-pre-wrap max-h-40 overflow-y-auto shadow-sm';
            alertBox.innerHTML = '';
            
            terminal.innerHTML += `\n\n<span class="term-cmd">$ ${cmd}</span>\n`;
            terminal.scrollTop = terminal.scrollHeight;
            
            loader.classList.remove('hidden');

            try {
                const res = await fetch('/api/exec', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ cmd })
                });
                
                const data = await res.json();
                
                if (data.error) {
                    alertBox.innerHTML = `<div class="font-bold mb-1 flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg> Ralat Dikesan:</div>${data.error}`;
                    alertBox.classList.remove('hidden');
                    alertBox.classList.add('bg-destructive/10', 'border-destructive/20', 'text-destructive');
                    
                    terminal.innerHTML += `<span class="term-err">[Error] ${data.error}</span>`;
                } else {
                    let safeOutput = data.output.replace(/</g, "&lt;").replace(/>/g, "&gt;");
                    
                    // 1. Buang simbol-simbol pelik (ANSI escape codes) dari output terminal asal
                    safeOutput = safeOutput.replace(/\x1B(?:[@-Z\\-_]|\[[0-?]*[ -/]*[@-~])/g, '');
                    
                    // 2. Warnakan kata kunci secara manual untuk keterlihatan yang cantik (Syntax Highlighting)
                    safeOutput = safeOutput
                        .replace(/\b(online|active|success)\b/gi, '<span class="text-emerald-400 font-bold">$&</span>')
                        .replace(/\b(error|failed|ralat|amar[aA]n)\b/gi, '<span class="text-destructive font-bold">$&</span>')
                        .replace(/\b(stopped|disabled|errored)\b/gi, '<span class="text-zinc-500 font-semibold italic">$&</span>')
                        .replace(/\b(mace-system|mace-monitor)\b/g, '<span class="text-cyan-400 font-bold">$&</span>')
                        .replace(/\b(mongod)\b/g, '<span class="text-emerald-300 font-bold">$&</span>')
                        .replace(/\b(pm2|node)\b/gi, '<span class="text-green-400 font-bold">$&</span>');
                    
                    // Ekstrak amaran/ralat dari output
                    if (safeOutput.includes('[Ralat Sistem]:')) {
                        const errMatch = safeOutput.split('[Ralat Sistem]:')[1];
                        alertBox.innerHTML = `<div class="font-bold mb-1 flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" x2="12" y1="9" y2="13"/><line x1="12" x2="12.01" y1="17" y2="17"/></svg> Ralat Sistem:</div>${errMatch.trim()}`;
                        alertBox.classList.remove('hidden');
                        alertBox.classList.add('bg-destructive/10', 'border-destructive/20', 'text-destructive');
                    } 
                    else if (safeOutput.includes('[Ralat/Amaran]:')) {
                        const warnMatch = safeOutput.split('[Ralat/Amaran]:')[1].split('[Ralat Sistem]:')[0];
                        alertBox.innerHTML = `<div class="font-bold mb-1 flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" x2="12" y1="9" y2="13"/><line x1="12" x2="12.01" y1="17" y2="17"/></svg> Amaran Keluaran:</div>${warnMatch.trim()}`;
                        alertBox.classList.remove('hidden');
                        alertBox.classList.add('bg-amber-500/10', 'border-amber-500/20', 'text-amber-700');
                    }
                    
                    terminal.innerHTML += safeOutput;
                }
            } catch (err) {
                if (cmd === 'pm2 restart mace-monitor') {
                    terminal.innerHTML += `\n<span class="term-info">[Info] MonitorPanel sedang dimulakan semula. Memuat semula (refresh) secara automatik...</span>`;
                    setTimeout(() => window.location.reload(), 2500);
                } else {
                    terminal.innerHTML += `<span class="term-err">[Network Error] Gagal menghubungi pelayan.</span>`;
                }
            }
            
            loader.classList.add('hidden');
            terminal.scrollTop = terminal.scrollHeight;
            
            // Auto reload without error message for monitor restart success (if it somehow responds before dying)
            if (cmd === 'pm2 restart mace-monitor') {
                setTimeout(() => window.location.reload(), 2500);
            }
        }
    </script>
</body>
</html>
