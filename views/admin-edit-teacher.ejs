<!DOCTYPE html>
<html lang="ms">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= editMode === 'create' ? 'Tambah ' + getTerm('teacher') + ' Baru' : 'Edit ' + getTerm('teacher') %> - Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50">
    <div class="min-h-screen p-8">
        <div class="max-w-2xl mx-auto bg-white rounded-xl shadow-sm border border-gray-100 p-8">
            <div class="mb-6">
                <a href="/admin-mace/teachers" class="text-blue-600 hover:text-blue-800 text-sm mb-4 inline-block">&larr; Kembali ke Senarai <%= getTerm('teacher') %></a>
                <h1 class="text-2xl font-bold text-gray-900"><%= editMode === 'create' ? 'Tambah ' + getTerm('teacher') + ' Baru' : 'Edit Maklumat ' + getTerm('teacher') %></h1>
                <p class="text-gray-500 text-sm mt-1"><%= getTerm('teacher') %> boleh mencipta modul, lesson, kuiz, dan menguruskan kumpulan <%= getTerm('student').toLowerCase() %>.</p>
            </div>

            <% if (editMode === 'edit' && teacher) { %>
                <form action="/admin-mace/teachers/edit/<%= teacher._id %>" method="POST" class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Nama Penuh</label>
                        <input type="text" name="fullName" value="<%= teacher.fullName %>" required class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Username</label>
                        <input type="text" name="username" value="<%= teacher.username || '' %>" required class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none font-mono lowercase">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Email (untuk login)</label>
                        <input type="email" name="email" value="<%= teacher.email %>" required class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Password Baru (kosongkan jika tidak mahu tukar)</label>
                        <input type="password" name="password" placeholder="Biarkan kosong jika tidak mahu tukar" class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none">
                    </div>
                    <div class="pt-4 flex gap-3">
                        <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded-lg font-medium hover:bg-blue-700 transition">Simpan Perubahan</button>
                        <a href="/admin-mace/teachers" class="bg-gray-100 text-gray-700 px-6 py-2 rounded-lg font-medium hover:bg-gray-200 transition">Batal</a>
                    </div>
                </form>
            <% } else { %>
                <form action="/admin-mace/teachers/new" method="POST" class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Nama Penuh</label>
                        <input type="text" name="fullName" required placeholder="Cth: Cikgu Ahmad" class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Username</label>
                        <input type="text" name="username" required placeholder="Cth: ahmadmace" class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none font-mono lowercase">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Email (untuk login)</label>
                        <input type="email" name="email" required placeholder="Cth: ahmad@MSN.gov.my" class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Password Awal</label>
                        <input type="password" name="password" required minlength="6" class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none">
                        <p class="text-xs text-gray-500 mt-1">Minimum 6 aksara</p>
                    </div>
                    <div class="pt-4 flex gap-3">
                        <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded-lg font-medium hover:bg-blue-700 transition">Daftar <%= getTerm('teacher') %></button>
                        <a href="/admin-mace/teachers" class="bg-gray-100 text-gray-700 px-6 py-2 rounded-lg font-medium hover:bg-gray-200 transition">Batal</a>
                    </div>
                </form>
            <% } %>
        </div>
    </div>
</body>
</html>
