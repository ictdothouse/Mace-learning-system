<!DOCTYPE html>
<html lang="<%= lang || 'ms' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Urus Ahli Kumpulan - MACE eLearning</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <% if (locals.branding && locals.branding.faviconUrl) { %>
    <link rel="icon" href="<%= branding.faviconUrl %>">
    <% } %>
    <style>
        :root {
            --primary-color: <%= locals.branding?.primaryColor || '#1e3a8a' %>;
        }
        .bg-blue-900 { background-color: var(--primary-color) !important; }
        .text-blue-900 { color: var(--primary-color) !important; }
        .sidebar-link.active { background-color: rgba(255,255,255,0.1); border-left: 4px solid #fbbf24; }
    </style>
</head>
<body class="bg-gray-100 min-h-screen flex text-gray-800 font-sans">
    
    <!-- MOBILE OVERLAY BACKDROP -->
    <div id="sidebarOverlay" class="fixed inset-0 bg-black/50 z-30 hidden transition-opacity duration-300 opacity-0" onclick="toggleSidebar()"></div>

    <!-- SIDEBAR MENU -->
    <aside id="adminSidebar" class="w-64 bg-blue-900 text-white flex flex-col fixed inset-y-0 left-0 md:sticky md:h-screen md:top-0 shadow-xl z-40 transition-transform duration-300 -translate-x-full md:translate-x-0">
        <div class="p-6 border-b border-blue-800 flex justify-between items-center">
            <div>
                <h1 class="text-xl font-bold tracking-wider flex items-center gap-2">
                    <% if (locals.branding && locals.branding.logoUrl) { %>
                        <img src="<%= branding.logoUrl %>" alt="Logo" class="h-8 w-auto object-contain">
                    <% } else { %>
                        <span class="text-yellow-400 text-2xl">🏅</span>
                        <%= (locals.branding && locals.branding.siteName) ? locals.branding.siteName : ('MACE ' + getTerm('teacher').toUpperCase()) %>
                    <% } %>
                </h1>
                <p class="text-xs text-blue-300 mt-1">Panel <%= getTerm('teacher') %></p>
            </div>
            <button onclick="toggleSidebar()" class="md:hidden text-blue-300 hover:text-white focus:outline-none p-1 rounded-lg hover:bg-blue-800/50 transition">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>
        
        <nav class="flex-1 py-6 space-y-1 overflow-y-auto">
            <a href="/teacher/dashboard" class="sidebar-link flex items-center px-6 py-3 hover:bg-blue-800 transition border-l-4 border-transparent">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" /></svg>
                Dashboard
            </a>
            <a href="/teacher/groups" class="sidebar-link active flex items-center px-6 py-3 hover:bg-blue-800 transition border-l-4 border-transparent">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0" /></svg>
                Kumpulan Saya
            </a>
        </nav>

        <div class="p-6 border-t border-blue-800">
            <a href="/auth/logout" class="flex items-center text-sm text-blue-300 hover:text-white transition group">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
                Keluar
            </a>
        </div>
    </aside>

    <!-- MAIN CONTENT AREA -->
    <main class="flex-1 p-6 md:p-10 overflow-y-auto h-screen relative">
        <div class="mb-6 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
            <div>
                <a href="/teacher/groups" class="text-blue-600 hover:text-blue-800 text-sm font-semibold mb-2 inline-block">← Kembali ke Senarai</a>
                <h2 class="text-2xl font-bold text-gray-900">Urus Ahli Kumpulan</h2>
                <p class="text-gray-500 text-sm mt-1">Urus senarai <%= getTerm('student').toLowerCase() %> untuk kumpulan <strong><%= group.name %></strong>.</p>
            </div>
            
            <!-- Form Tambah Pelajar -->
            <form action="/teacher/groups/<%= group._id %>/students/add" method="POST" class="w-full md:w-auto flex gap-2">
                <select name="studentId" required class="flex-1 md:w-64 border border-gray-300 rounded-lg px-3 py-2 text-sm bg-white focus:ring-2 focus:ring-blue-500 outline-none">
                    <option value="">Pilih <%= getTerm('student') %> Untuk Ditambah...</option>
                    <% allStudents.forEach(s => { %>
                        <option value="<%= s._id %>"><%= s.fullName %> (<%= s.email %>)</option>
                    <% }) %>
                </select>
                <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-semibold transition shrink-0">+ Tambah</button>
            </form>
        </div>

        <% if (locals.msg === 'student_added') { %>
            <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 rounded-r-lg mb-6 shadow-sm">✓ <%= getTerm('student') %> berjaya ditambahkan ke dalam kumpulan!</div>
        <% } else if (locals.msg === 'student_removed') { %>
            <div class="bg-blue-100 border-l-4 border-blue-500 text-blue-700 p-4 rounded-r-lg mb-6 shadow-sm">🗑️ <%= getTerm('student') %> dikeluarkan dari kumpulan.</div>
        <% } %>

        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden mb-8">
            <div class="px-6 py-4 border-b border-gray-100 bg-gray-50 flex justify-between items-center">
                <span class="font-bold text-gray-700">Senarai Ahli Kumpulan (<%= group.students ? group.students.length : 0 %> <%= getTerm('student') %>)</span>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-sm text-left">
                    <thead class="text-xs text-gray-500 uppercase bg-gray-50 border-b border-gray-100">
                        <tr>
                            <th class="px-6 py-4">Nama Penuh</th>
                            <th class="px-6 py-4">Email</th>
                            <th class="px-6 py-4">Log Masuk Terakhir</th>
                            <th class="px-6 py-4 text-right">Tindakan</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        <% if (group.students && group.students.length > 0) { %>
                            <% group.students.forEach(s => { %>
                                <tr class="hover:bg-gray-50/50 transition">
                                    <td class="px-6 py-4 font-semibold text-gray-900"><%= s.fullName %></td>
                                    <td class="px-6 py-4 text-gray-600"><%= s.email %></td>
                                    <td class="px-6 py-4 text-gray-500"><%= s.lastLogin ? new Date(s.lastLogin).toLocaleString('ms-MY') : 'Belum Pernah' %></td>
                                    <td class="px-6 py-4 text-right">
                                        <form action="/teacher/groups/<%= group._id %>/students/remove/<%= s._id %>" method="POST" class="inline" onsubmit="return confirm('Keluarkan <%= getTerm('student').toLowerCase() %> ini dari kumpulan?')">
                                            <button type="submit" class="text-xs bg-red-50 hover:bg-red-100 text-red-600 px-2.5 py-1.5 rounded transition">🗑️ Keluarkan</button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="4" class="px-6 py-12 text-center text-gray-400 italic">Tiada <%= getTerm('student').toLowerCase() %> di dalam kumpulan ini lagi.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById('adminSidebar');
            const overlay = document.getElementById('sidebarOverlay');
            
            if (sidebar.classList.contains('-translate-x-full')) {
                sidebar.classList.remove('-translate-x-full');
                overlay.classList.remove('hidden');
                setTimeout(() => {
                    overlay.classList.remove('opacity-0');
                }, 50);
                document.body.style.overflow = 'hidden';
            } else {
                sidebar.classList.add('-translate-x-full');
                overlay.classList.add('opacity-0');
                setTimeout(() => {
                    overlay.classList.add('hidden');
                }, 300);
                document.body.style.overflow = '';
            }
        }
    </script>
</body>
</html>
