<!DOCTYPE html>
<html lang="ms">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= lesson ? 'Edit Modul' : 'Cipta Modul' %> - Admin MSN</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: #f1f5f9; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
        .sidebar-link.active { background-color: rgba(255,255,255,0.1); border-left: 4px solid #fbbf24; }
    </style>
</head>
<body class="bg-gray-100 min-h-screen flex text-gray-800 font-sans">
    
    <!-- SIDEBAR MENU -->
    <aside class="w-64 bg-blue-900 text-white flex-shrink-0 hidden md:flex flex-col h-screen sticky top-0 shadow-xl z-20">
        <div class="p-6 border-b border-blue-800">
            <h1 class="text-xl font-bold tracking-wider flex items-center gap-2"><span class="text-yellow-400 text-2xl">🏅</span> ADMIN MSN</h1>
            <p class="text-xs text-blue-300 mt-1">Sistem eLearning Atlet SUKMA v2</p>
        </div>
        <nav class="flex-1 py-6 space-y-1">
            <a href="/admin-mace" class="sidebar-link <%= page === 'dashboard' ? 'active' : '' %> flex items-center px-6 py-3 hover:bg-blue-800 transition border-l-4 border-transparent">Dashboard</a>
            <a href="/admin-mace/users" class="sidebar-link <%= page === 'users' ? 'active' : '' %> flex items-center px-6 py-3 hover:bg-blue-800 transition border-l-4 border-transparent">Pengurusan Pengguna</a>
            <a href="/admin-mace/manage-lessons" class="sidebar-link active flex items-center px-6 py-3 hover:bg-blue-800 transition border-l-4 border-transparent">Edit Modul & Kuiz</a>
            <a href="/admin-mace/settings" class="sidebar-link <%= page === 'settings' ? 'active' : '' %> flex items-center px-6 py-3 hover:bg-blue-800 transition border-l-4 border-transparent">Tetapan Sistem</a>
        </nav>
        <div class="p-6 border-t border-blue-800"><a href="/admin-mace/manage-lessons" class="flex items-center text-sm text-blue-300 hover:text-white transition">← Kembali ke Senarai Modul</a></div>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="flex-1 p-6 md:p-10 overflow-y-auto h-screen">
        <div class="max-w-4xl mx-auto">
            <div class="bg-white p-6 rounded-xl shadow-sm border mb-6">
                <h2 class="text-xl font-bold mb-4"><%= lesson ? 'Edit Modul' : 'Cipta Modul Baharu' %></h2>
                
                <form action="/admin-mace/manage-lessons/<%= lesson ? 'edit/' + lesson._id : 'new' %>" method="POST" class="space-y-6">
                    <div>
                        <label class="block text-sm font-medium mb-1">Tajuk Modul</label>
                        <input type="text" name="title" value="<%= lesson?.title || '' %>" required class="w-full border p-2 rounded focus:ring-2 focus:ring-blue-500 outline-none">
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium mb-1">Kandungan (HTML/Text)</label>
                        <textarea name="contentHtml" rows="5" class="w-full border p-2 rounded font-mono text-sm focus:ring-2 focus:ring-blue-500 outline-none"><%= lesson?.contentHtml || '' %></textarea>
                        <p class="text-xs text-gray-500 mt-1">Boleh guna tag HTML seperti &lt;b&gt;, &lt;i&gt;, &lt;p style="..."&gt;</p>
                    </div>

                    <div>
                        <label class="block text-sm font-medium mb-1">URL Video (Cloudflare R2 Filename)</label>
                        <input type="text" name="videoUrl" value="<%= lesson?.videoUrl || '' %>" placeholder="contoh: video_videos_1pengenalan.mp4" class="w-full border p-2 rounded focus:ring-2 focus:ring-blue-500 outline-none">
                    </div>

                    <!-- Pengurusan Kuiz Dinamik -->
                    <div class="border-t pt-4">
                        <h3 class="font-bold mb-3 flex items-center gap-2">Pengurusan Kuiz & Bank Soalan</h3>
                        <div id="quiz-editor" class="space-y-4"></div>
                        <button type="button" onclick="addQuestion()" class="mt-3 bg-blue-100 text-blue-700 px-4 py-2 rounded text-sm hover:bg-blue-200 transition">+ Tambah Soalan</button>
                        <input type="hidden" name="questionsJson" id="questionsJson">
                    </div>

                    <div class="flex gap-3 pt-4 border-t">
                        <button type="submit" class="bg-green-600 text-white px-6 py-2 rounded hover:bg-green-700 transition shadow-sm">💾 Simpan Modul</button>
                        <% if (lesson) { %>
                            <button type="button" onclick="if(confirm('Padam modul ini?')) window.location='/admin-mace/manage-lessons/delete/<%= lesson._id %>'" class="bg-red-100 text-red-700 px-6 py-2 rounded hover:bg-red-200 transition">🗑️ Padam</button>
                        <% } %>
                    </div>
                </form>
            </div>
        </div>
    </main>

    <script>
        // Logik Dynamic Quiz Editor
        let questions = <%= JSON.stringify(lesson?.quizQuestions || []) %>;

        function renderQuizEditor() {
            const container = document.getElementById('quiz-editor');
            container.innerHTML = '';
            questions.forEach((q, idx) => {
                container.innerHTML += `
                    <div class="border p-4 rounded bg-gray-50 relative group">
                        <button type="button" onclick="removeQuestion(${idx})" class="absolute top-2 right-2 text-red-500 hover:text-red-700 text-xs opacity-0 group-hover:opacity-100 transition">✕ Buang</button>
                        <label class="text-xs font-bold text-gray-600 uppercase tracking-wide">Soalan ${idx+1}</label>
                        <input type="text" class="w-full border p-2 rounded mb-3 mt-1 focus:ring-2 focus:ring-blue-500 outline-none" value="${q.text}" onchange="updateQ(${idx}, 'text', this.value)" placeholder="Masukkan soalan...">
                        
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
                            ${q.options.map((opt, oIdx) => `
                                <div class="flex items-center gap-2 bg-white p-2 rounded border">
                                    <input type="radio" name="correct_${idx}" ${q.correctIndex === oIdx ? 'checked' : ''} onchange="updateQ(${idx}, 'correctIndex', ${oIdx})" class="accent-green-600 h-4 w-4">
                                    <input type="text" class="w-full text-sm outline-none bg-transparent" value="${opt}" onchange="updateOpt(${idx}, ${oIdx}, this.value)">
                                </div>
                            `).join('')}
                        </div>
                        <button type="button" onclick="addOption(${idx})" class="mt-2 text-xs text-blue-600 hover:text-blue-800 underline">+ Tambah Pilihan Jawapan</button>
                    </div>
                `;
            });
            document.getElementById('questionsJson').value = JSON.stringify(questions);
        }

        function updateQ(idx, field, val) { questions[idx][field] = val; saveJson(); }
        function updateOpt(qIdx, oIdx, val) { questions[qIdx].options[oIdx] = val; saveJson(); }
        function addOption(qIdx) { questions[qIdx].options.push('Pilihan Baharu'); renderQuizEditor(); }
        function addQuestion() { 
            questions.push({ text: '', options: ['A', 'B'], correctIndex: 0 }); 
            renderQuizEditor(); 
        }
        function removeQuestion(idx) { 
            if(confirm('Buang soalan ini?')) { questions.splice(idx, 1); renderQuizEditor(); }
        }
        function saveJson() { document.getElementById('questionsJson').value = JSON.stringify(questions); }

        renderQuizEditor();
    </script>
</body>
</html>