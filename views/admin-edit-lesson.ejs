<!DOCTYPE html>
<html lang="ms">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= editMode === 'create' ? 'Cipta Modul Pembelajaran Baru' : 'Edit Modul Pembelajaran' %> - Admin MSN</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/tinymce/6.8.2/tinymce.min.js"></script>
</head>
<body class="bg-gray-50 min-h-screen">
    <div class="max-w-4xl mx-auto py-12 px-6">
        <!-- Header -->
        <div class="mb-8">
            <a href="/admin-mace/lessons?moduleId=<%= lesson && lesson.moduleId ? (lesson.moduleId._id || lesson.moduleId) : (modules[0] ? modules[0]._id : '') %>" 
                    class="text-blue-600 hover:text-blue-800 text-sm font-medium inline-flex items-center gap-1 mb-6 transition">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
                Kembali ke Senarai Pelajaran
            </a>
            <h1 class="text-3xl font-bold text-gray-900"><%= editMode === 'create' ? '📖 Cipta Pelajaran Baru' : '✏️ Edit Pelajaran' %></h1>
            <p class="text-gray-500 mt-2"><%= editMode === 'create' ? 'Tambah kandungan pembelajaran dan kuiz baru.' : 'Kemaskini kandungan pelajaran dan soalan kuiz.' %></p>
        </div>

        <!-- Form -->
        <form action="" method="POST" class="bg-white rounded-xl shadow-sm border border-gray-100 p-8 space-y-6">
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <!-- Pilihan Silibus/Modul Induk -->
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Modul Utama *</label>
                    <select name="moduleId" required class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-500 outline-none bg-white transition">
                        <option value="">-- Pilih Modul --</option>
                        <% (modules || []).forEach(m => { %>
                            <option value="<%= m._id %>" <%= (lesson && lesson.moduleId && lesson.moduleId._id.toString() === m._id.toString()) ? 'selected' : '' %>><%= m.title %></option>
                        <% }) %>
                    </select>
                </div>

                <!-- Peringkat (Level) Dropdown -->
                <div id="levelSelectContainer" class="hidden">
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Peringkat (Level)</label>
                    <select name="levelId" id="levelId" class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-500 outline-none bg-white transition">
                        <option value="">-- Tiada (Standalone Lesson) --</option>
                        <% (levels || []).forEach(lvl => { %>
                            <option value="<%= lvl._id %>" <%= (lesson && lesson.levelId && lesson.levelId.toString() === lvl._id.toString()) ? 'selected' : '' %>><%= lvl.name %></option>
                        <% }) %>
                    </select>
                </div>

                <!-- Tajuk Pelajaran -->
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Tajuk Pelajaran *</label>
                    <input type="text" name="title" value="<%= lesson ? lesson.title : '' %>" required 
                        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition"
                        placeholder="Contoh: Pengenalan Sukan Prestasi Tinggi">
                </div>
            </div>

            <!-- Video Upload & Preview Section (Di Bawah Tajuk) -->
            <div class="bg-gray-50 border border-gray-200 rounded-xl p-6 space-y-4">
                <h3 class="text-sm font-semibold text-gray-800 flex items-center gap-2">
                    🎥 Video Pembelajaran (Maksimum 50MB, Sasaran ~30MB)
                </h3>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <!-- Muat Naik Fail Video -->
                    <div>
                        <label class="block text-xs font-semibold text-gray-500 mb-1">Pilihan A: Muat Naik Fail Video (.mp4, .webm, dll.)</label>
                        <input type="file" id="videoFile" accept="video/*" 
                            class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 transition cursor-pointer border border-gray-300 rounded-lg p-1 bg-white">
                        <div id="video-upload-status" class="text-xs mt-1 hidden font-semibold"></div>
                        <div id="video-progress-container" class="w-full bg-gray-200 rounded-full h-2 mt-2 hidden">
                            <div id="video-progress-bar" class="bg-blue-600 h-2 rounded-full transition-all" style="width: 0%"></div>
                        </div>
                    </div>

                    <!-- Input Nama Fail atau URL manual -->
                    <div>
                        <label class="block text-xs font-semibold text-gray-500 mb-1">Pilihan B: Nama Fail R2 / URL Video Luaran</label>
                        <input type="text" name="videoUrl" id="videoUrl" value="<%= lesson ? lesson.videoUrl : '' %>" 
                            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none transition text-sm font-mono"
                            placeholder="Cth: video_videos_1pengenalan.mp4 atau https://...">
                        <p class="text-[10px] text-gray-400 mt-1">Masukkan jika tidak mahu memuat naik fail baru secara terus.</p>
                    </div>
                </div>

                <!-- Preview Pemain Video -->
                <div id="video-preview-container" class="mt-4 <%= secureVideoUrl ? '' : 'hidden' %>">
                    <span class="block text-xs font-semibold text-gray-500 mb-1">Preview Video Aktif:</span>
                    <div class="max-w-md bg-black rounded-lg overflow-hidden shadow border border-gray-300 relative">
                        <video id="video-preview" controls controlsList="nodownload" oncontextmenu="return false;" class="w-full max-h-60 object-contain">
                            <% if (secureVideoUrl) { %>
                                <source src="<%= secureVideoUrl %>" type="video/mp4">
                            <% } %>
                            Pelayar anda tidak menyokong preview video.
                        </video>
                    </div>
                </div>
            </div>

            <!-- Kandungan Utama (TinyMCE) -->
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Kandungan Pelajaran *</label>
                <textarea id="contentHtml" name="contentHtml"><%= lesson ? lesson.contentHtml : '' %></textarea>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-4 gap-6 p-4 bg-blue-50/50 rounded-xl border border-blue-100">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Had Kelulusan Kuiz (%)</label>
                    <input type="number" name="passMark" value="<%= lesson ? lesson.passMark : 80 %>" min="0" max="100"
                        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition bg-white">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Order (Susunan)</label>
                    <input type="number" name="order" value="<%= lesson ? lesson.order : 0 %>" min="0"
                        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition bg-white">
                </div>
                <div class="flex items-center mt-8">
                    <input type="checkbox" name="isActive" id="isActive" value="on" <%= (lesson === null || lesson.isActive) ? 'checked' : '' %>
                        class="h-5 w-5 text-blue-600 border-gray-300 rounded focus:ring-blue-500">
                    <label for="isActive" class="ml-3 block text-sm font-medium text-gray-700">Pelajaran Aktif</label>
                </div>
                <div class="flex items-center mt-8">
                    <input type="checkbox" name="showPoints" id="showPoints" value="on" <%= (lesson === null || lesson.showPoints !== false) ? 'checked' : '' %>
                        class="h-5 w-5 text-blue-600 border-gray-300 rounded focus:ring-blue-500">
                    <label for="showPoints" class="ml-3 block text-sm font-medium text-gray-700">Tunjukkan Markah Kuiz</label>
                </div>
            </div>

            <!-- Pengurusan Kuiz Dinamik -->
            <div class="border-t border-gray-200 pt-6">
                <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center mb-4 gap-4">
                    <div>
                        <h3 class="text-lg font-bold text-gray-900">📝 Pengurusan Kuiz & Soalan</h3>
                        <p class="text-xs text-gray-500">Bina soalan kuiz secara dinamik mengikut pelbagai jenis format.</p>
                    </div>
                    <div class="flex items-center gap-4">
                        <label class="flex items-center gap-2 cursor-pointer bg-gray-100 px-3 py-2 rounded-lg border border-gray-200">
                            <input type="checkbox" id="toggleMarkah" onchange="toggleCustomMarkah(this.checked)" class="accent-blue-600 h-4 w-4">
                            <span class="text-xs font-semibold text-gray-700">Set Markah Khusus</span>
                        </label>
                        <button type="button" onclick="addQuestion()" 
                            class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition shadow-sm flex items-center gap-1">
                            + Tambah Soalan
                        </button>
                    </div>
                </div>
                
                <div id="quiz-editor" class="space-y-6"></div>
                <input type="hidden" name="questionsJson" id="questionsJson">
            </div>

            <!-- Butang Simpan / Batal -->
            <div class="pt-6 border-t border-gray-200 flex gap-3">
                <button type="submit" class="bg-blue-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-blue-700 transition shadow-sm">
                    💾 Simpan Pelajaran
                </button>
                <a href="/admin-mace/lessons?moduleId=<%= lesson && lesson.moduleId ? (lesson.moduleId._id || lesson.moduleId) : (modules[0] ? modules[0]._id : '') %>" 
                    class="bg-gray-100 text-gray-700 px-6 py-3 rounded-lg font-semibold hover:bg-gray-200 transition">
                    Batal
                </a>
            </div>
        </form>
    </div>

    <!-- TinyMCE Initialization -->
    <script>
        tinymce.init({
            selector: '#contentHtml',
            height: 400,
            plugins: 'anchor autolink charmap codesample emoticons image link lists media searchreplace table visualblocks wordcount',
            toolbar: 'undo redo | blocks fontfamily fontsize | bold italic underline strikethrough | link image media table | align lineheight | numlist bullist indent outdent | emoticons charmap | removeformat',
            content_style: 'body { font-family: Inter, sans-serif; font-size: 16px }',
            language: 'ms',
            menubar: true,
            branding: false,
            promotion: false
        });
    </script>

    <!-- Dynamic Quiz Logic -->
    <script>
        let questions = <%- JSON.stringify((typeof lesson !== 'undefined' && lesson && lesson.quizQuestions) ? lesson.quizQuestions : []) %>;
        let isCustomMarkah = questions.length > 0 ? questions.some(q => q.points !== 1) : false;

        document.addEventListener('DOMContentLoaded', () => {
            const toggle = document.getElementById('toggleMarkah');
            if (toggle) toggle.checked = isCustomMarkah;
        });

        function toggleCustomMarkah(checked) {
            isCustomMarkah = checked;
            if (!checked) {
                questions.forEach(q => q.points = 1);
                saveJson();
            }
            renderQuizEditor();
        }

        function renderQuizEditor() {
            const container = document.getElementById('quiz-editor');
            container.innerHTML = '';
            
            if (questions.length === 0) {
                container.innerHTML = `
                    <div class="p-8 text-center bg-gray-50 rounded-xl border border-dashed border-gray-300 text-gray-500 text-sm">
                        Belum ada soalan dicipta. Klik butang "+ Tambah Soalan" untuk bermula.
                    </div>
                `;
                document.getElementById('questionsJson').value = JSON.stringify([]);
                return;
            }

            questions.forEach((q, idx) => {
                // Default fallback values
                q.type = q.type || 'multiple-choice';
                q.points = q.points !== undefined ? q.points : 1;
                q.options = q.options || [];
                q.correctIndex = q.correctIndex !== undefined ? q.correctIndex : 0;
                q.correctAnswerText = q.correctAnswerText || '';

                let answerSection = '';

                if (q.type === 'multiple-choice') {
                    answerSection = `
                        <div class="space-y-2 mt-2">
                            <span class="block text-xs font-semibold text-gray-500">Pilihan Jawapan (Tandakan jawapan betul):</span>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
                                ${q.options.map((opt, oIdx) => `
                                    <div class="flex items-center gap-2 bg-white p-2 rounded-lg border border-gray-200">
                                        <input type="radio" name="correct_${idx}" ${q.correctIndex === oIdx ? 'checked' : ''} 
                                            onchange="updateQ(${idx}, 'correctIndex', ${oIdx})" class="accent-blue-600 h-4 w-4">
                                        <input type="text" class="w-full text-sm outline-none bg-transparent" value="${escapeHtml(opt)}" 
                                            onchange="updateOpt(${idx}, ${oIdx}, this.value)" placeholder="Pilihan ${oIdx+1}">
                                        <button type="button" onclick="removeOpt(${idx}, ${oIdx})" class="text-red-400 hover:text-red-600 text-xs">✕</button>
                                    </div>
                                `).join('')}
                            </div>
                            <button type="button" onclick="addOption(${idx})" class="mt-2 text-xs text-blue-600 hover:text-blue-800 underline font-medium">+ Tambah Pilihan</button>
                        </div>
                    `;
                } else if (q.type === 'true-false') {
                    // Set default options for true/false if empty
                    if (q.options.length !== 2 || q.options[0] !== 'Betul') {
                        q.options = ['Betul', 'Salah'];
                    }
                    answerSection = `
                        <div class="mt-2 space-y-2">
                            <span class="block text-xs font-semibold text-gray-500">Tandakan Jawapan Betul:</span>
                            <div class="flex gap-4">
                                <label class="flex items-center gap-2 bg-white px-4 py-2 rounded-lg border border-gray-200 cursor-pointer">
                                    <input type="radio" name="correct_${idx}" ${q.correctIndex === 0 ? 'checked' : ''} 
                                        onchange="updateQ(${idx}, 'correctIndex', 0)" class="accent-blue-600 h-4 w-4">
                                    <span class="text-sm font-medium">Betul</span>
                                </label>
                                <label class="flex items-center gap-2 bg-white px-4 py-2 rounded-lg border border-gray-200 cursor-pointer">
                                    <input type="radio" name="correct_${idx}" ${q.correctIndex === 1 ? 'checked' : ''} 
                                        onchange="updateQ(${idx}, 'correctIndex', 1)" class="accent-blue-600 h-4 w-4">
                                    <span class="text-sm font-medium">Salah</span>
                                </label>
                            </div>
                        </div>
                    `;
                } else if (q.type === 'short-answer') {
                    answerSection = `
                        <div class="mt-2 space-y-1">
                            <label class="block text-xs font-semibold text-gray-500">Teks Jawapan Betul (Case-Insensitive):</label>
                            <input type="text" class="w-full border p-2.5 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 outline-none" 
                                value="${escapeHtml(q.correctAnswerText)}" onchange="updateQ(${idx}, 'correctAnswerText', this.value)" 
                                placeholder="Cth: Kuala Lumpur">
                            <p class="text-[10px] text-gray-400">Atlit mesti menaip jawapan yang hampir tepat dengan teks ini untuk mendapat markah.</p>
                        </div>
                    `;
                }

                container.innerHTML += `
                    <div class="border border-gray-200 p-5 rounded-xl bg-gray-50/50 relative group shadow-sm">
                        <div class="flex flex-wrap items-center gap-3 mb-4 pr-1">
                            <span class="text-xs font-bold text-blue-700 bg-blue-50 px-2.5 py-1 rounded-full uppercase tracking-wider">Soalan ${idx+1}</span>
                            
                            <!-- Jenis Soalan -->
                            <select onchange="updateQType(${idx}, this.value)" 
                                class="border border-gray-300 p-1.5 rounded-lg text-xs bg-white focus:ring-2 focus:ring-blue-500 outline-none">
                                <option value="multiple-choice" ${q.type === 'multiple-choice' ? 'selected' : ''}>Pilihan Ganda</option>
                                <option value="true-false" ${q.type === 'true-false' ? 'selected' : ''}>Betul / Salah</option>
                                <option value="short-answer" ${q.type === 'short-answer' ? 'selected' : ''}>Jawapan Pendek</option>
                            </select>

                            <!-- Mata/Markah -->
                            <div class="flex items-center gap-2 ${isCustomMarkah ? '' : 'hidden'}">
                                <label class="text-xs text-gray-500 font-semibold">Markah/Mata:</label>
                                <input type="number" min="0" class="w-14 border border-gray-300 p-1 rounded-lg text-center text-xs focus:ring-2 focus:ring-blue-500 outline-none bg-white font-semibold" 
                                    value="${q.points}" onchange="updateQ(${idx}, 'points', parseInt(this.value) || 0)">
                            </div>
                            
                            <!-- Padam Butang -->
                            <button type="button" onclick="removeQuestion(${idx})" 
                                class="ml-auto bg-red-50 text-red-600 hover:bg-red-100 p-1.5 rounded-lg text-xs transition whitespace-nowrap">
                                ✕ Padam Soalan
                            </button>
                        </div>

                        <!-- Teks Soalan -->
                        <div class="mb-3">
                            <input type="text" class="w-full border border-gray-300 p-3 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 outline-none bg-white" 
                                value="${escapeHtml(q.text)}" onchange="updateQ(${idx}, 'text', this.value)" placeholder="Masukkan soalan...">
                        </div>

                        <!-- Kawasan Pilihan Jawapan -->
                        ${answerSection}
                    </div>
                `;
            });
            
            document.getElementById('questionsJson').value = JSON.stringify(questions);
        }

        function updateQ(idx, field, val) { 
            questions[idx][field] = val; 
            saveJson(); 
        }

        function updateOpt(qIdx, oIdx, val) { 
            questions[qIdx].options[oIdx] = val; 
            saveJson(); 
        }

        function removeOpt(qIdx, oIdx) {
            if (questions[qIdx].options.length <= 2) {
                alert('Pilihan jawapan minimum adalah 2 pilihan.');
                return;
            }
            questions[qIdx].options.splice(oIdx, 1);
            if (questions[qIdx].correctIndex >= questions[qIdx].options.length) {
                questions[qIdx].correctIndex = 0;
            }
            renderQuizEditor();
        }

        function addOption(qIdx) { 
            questions[qIdx].options.push('Pilihan Baru'); 
            renderQuizEditor(); 
        }

        function addQuestion() { 
            questions.push({ 
                text: '', 
                type: 'multiple-choice',
                options: ['A', 'B', 'C', 'D'], 
                correctIndex: 0,
                correctAnswerText: '',
                points: 1
            }); 
            renderQuizEditor(); 
        }

        function updateQType(idx, newType) {
            questions[idx].type = newType;
            if (newType === 'true-false') {
                questions[idx].options = ['Betul', 'Salah'];
                questions[idx].correctIndex = 0;
                questions[idx].correctAnswerText = '';
            } else if (newType === 'short-answer') {
                questions[idx].options = [];
                questions[idx].correctIndex = 0;
                questions[idx].correctAnswerText = '';
            } else {
                questions[idx].options = ['Pilihan A', 'Pilihan B', 'Pilihan C', 'Pilihan D'];
                questions[idx].correctIndex = 0;
                questions[idx].correctAnswerText = '';
            }
            renderQuizEditor();
        }

        function removeQuestion(idx) { 
            if(confirm('Buang soalan ini dari kuiz?')) { 
                questions.splice(idx, 1); 
                renderQuizEditor(); 
            }
        }

        function saveJson() { 
            document.getElementById('questionsJson').value = JSON.stringify(questions); 
        }

        function escapeHtml(text) {
            if (!text) return '';
            return text
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }

        // Initialize editor
        renderQuizEditor();

        // Video preview and upload progress logic
        const videoFileInput = document.getElementById('videoFile');
        const videoUrlInput = document.getElementById('videoUrl');
        const videoPreview = document.getElementById('video-preview');
        const videoPreviewContainer = document.getElementById('video-preview-container');
        const uploadStatusDiv = document.getElementById('video-upload-status');
        const progressContainer = document.getElementById('video-progress-container');
        const progressBar = document.getElementById('video-progress-bar');
        const submitBtn = document.querySelector('button[type="submit"]');

        videoFileInput.addEventListener('change', async function() {
            const file = this.files[0];
            if (!file) return;

            if (file.size > 50 * 1024 * 1024) {
                alert('Amaran: Saiz video melebihi had 50MB. Sila mampatkan video anda terlebih dahulu.');
                this.value = '';
                return;
            }

            // Set local preview instantly
            const localUrl = URL.createObjectURL(file);
            videoPreview.innerHTML = '';
            const source = document.createElement('source');
            source.src = localUrl;
            source.type = file.type || 'video/mp4';
            videoPreview.appendChild(source);
            videoPreview.load();
            videoPreviewContainer.classList.remove('hidden');

            // Start uploading in background
            uploadStatusDiv.classList.remove('hidden');
            uploadStatusDiv.className = 'text-xs mt-1 font-semibold text-blue-600';
            uploadStatusDiv.innerText = 'Menyediakan saluran muat naik video...';
            
            progressContainer.classList.remove('hidden');
            progressBar.style.width = '0%';
            submitBtn.disabled = true;

            try {
                // Request presigned URL from server
                const res = await fetch(`/admin-mace/api/presigned-url?filename=${encodeURIComponent(file.name)}&contentType=${encodeURIComponent(file.type)}`);
                const data = await res.json();

                if (!res.ok || !data.uploadUrl) {
                    throw new Error(data.error || 'Gagal menjana saluran muat naik');
                }

                uploadStatusDiv.innerText = 'Memuat naik video... 0%';

                const xhr = new XMLHttpRequest();
                
                if (data.isR2) {
                    // PUT to Cloudflare R2 directly
                    xhr.open('PUT', data.uploadUrl, true);
                    xhr.setRequestHeader('Content-Type', file.type);
                    
                    xhr.upload.onprogress = (e) => {
                        if (e.lengthComputable) {
                            const percent = Math.round((e.loaded / e.total) * 100);
                            progressBar.style.width = `${percent}%`;
                            uploadStatusDiv.innerText = `Memuat naik video terus ke awan... ${percent}%`;
                        }
                    };

                    xhr.onload = () => {
                        if (xhr.status === 200) {
                            // Save the key in the videoUrl text input
                            videoUrlInput.value = data.fileKey;

                            uploadStatusDiv.className = 'text-xs mt-1 font-semibold text-green-600';
                            uploadStatusDiv.innerText = '✓ Video berjaya dimuat naik ke awan!';
                            submitBtn.disabled = false;
                        } else {
                            uploadStatusDiv.className = 'text-xs mt-1 font-semibold text-red-600';
                            uploadStatusDiv.innerText = '✗ Gagal memuat naik video ke awan.';
                            submitBtn.disabled = false;
                        }
                    };
                    
                    xhr.send(file);
                } else {
                    // Local fallback POST
                    const formData = new FormData();
                    formData.append('file', file);
                    formData.append('fileKey', data.fileKey);

                    xhr.open('POST', data.uploadUrl, true);
                    
                    xhr.upload.onprogress = (e) => {
                        if (e.lengthComputable) {
                            const percent = Math.round((e.loaded / e.total) * 100);
                            progressBar.style.width = `${percent}%`;
                            uploadStatusDiv.innerText = `Memuat naik video... ${percent}%`;
                        }
                    };

                    xhr.onload = () => {
                        const response = JSON.parse(xhr.responseText || '{}');
                        if (xhr.status === 200 && response.success) {
                            videoUrlInput.value = response.url;

                            uploadStatusDiv.className = 'text-xs mt-1 font-semibold text-green-600';
                            uploadStatusDiv.innerText = '✓ Video disimpan secara lokal!';
                            submitBtn.disabled = false;
                        } else {
                            uploadStatusDiv.className = 'text-xs mt-1 font-semibold text-red-600';
                            uploadStatusDiv.innerText = '✗ Gagal menyimpan video lokal.';
                            submitBtn.disabled = false;
                        }
                    };

                    xhr.send(formData);
                }

            } catch (err) {
                console.error(err);
                uploadStatusDiv.className = 'text-xs mt-1 font-semibold text-red-600';
                uploadStatusDiv.innerText = `✗ Ralat: ${err.message}`;
                submitBtn.disabled = false;
            }
        });

        videoUrlInput.addEventListener('change', async function() {
            const val = this.value.trim();
            if (val) {
                if (val.startsWith('http')) {
                    videoPreview.innerHTML = '';
                    const source = document.createElement('source');
                    source.src = val;
                    source.type = 'video/mp4';
                    videoPreview.appendChild(source);
                    videoPreview.load();
                    videoPreviewContainer.classList.remove('hidden');
                    videoFileInput.value = '';
                } else if (val.length > 3) {
                    // Fetch signed URL from backend
                    try {
                        const uploadStatusDiv = document.getElementById('upload-status');
                        if (uploadStatusDiv) {
                            uploadStatusDiv.className = 'text-xs mt-1 font-semibold text-gray-500';
                            uploadStatusDiv.innerText = 'Menjana pautan R2 yang sah...';
                        }
                        
                        const response = await fetch(`/admin-mace/api/sign-video-url?filename=${encodeURIComponent(val)}`);
                        const data = await response.json();
                        
                        if (data.url) {
                            videoPreview.innerHTML = '';
                            const source = document.createElement('source');
                            source.src = data.url;
                            source.type = 'video/mp4';
                            videoPreview.appendChild(source);
                            videoPreview.load();
                            videoPreviewContainer.classList.remove('hidden');
                            videoFileInput.value = '';
                            
                            if (uploadStatusDiv) {
                                uploadStatusDiv.className = 'text-xs mt-1 font-semibold text-blue-600';
                                uploadStatusDiv.innerText = 'Pautan R2 berjaya dihubungkan!';
                            }
                        }
                    } catch (err) {
                        console.error('Failed to fetch signed url:', err);
                    }
                }
            } else {
                if (!videoFileInput.files[0]) {
                    videoPreviewContainer.classList.add('hidden');
                    videoPreview.pause();
                }
            }
        });

        // Dynamic Level dropdown handler
        const moduleSelect = document.querySelector('select[name="moduleId"]');
        const levelSelectContainer = document.getElementById('levelSelectContainer');
        const levelSelect = document.getElementById('levelId');

        async function updateLevelsDropdown(moduleId, selectedLevelId = null) {
            if (!moduleId) {
                levelSelectContainer.classList.add('hidden');
                levelSelect.innerHTML = '<option value="">-- Tiada (Standalone Lesson) --</option>';
                return;
            }

            try {
                const res = await fetch(`/api/levels/module/${moduleId}`);
                const result = await res.json();
                
                if (result.success && result.data && result.data.length > 0) {
                    levelSelectContainer.classList.remove('hidden');
                    let html = '<option value="">-- Tiada (Standalone Lesson) --</option>';
                    result.data.forEach(lvl => {
                        const isSel = selectedLevelId && selectedLevelId.toString() === lvl._id.toString() ? 'selected' : '';
                        html += `<option value="${lvl._id}" ${isSel}>${lvl.name}</option>`;
                    });
                    levelSelect.innerHTML = html;
                } else {
                    levelSelectContainer.classList.add('hidden');
                    levelSelect.innerHTML = '<option value="">-- Tiada (Standalone Lesson) --</option>';
                }
            } catch (err) {
                console.error('Error fetching levels:', err);
                levelSelectContainer.classList.add('hidden');
            }
        }

        if (moduleSelect) {
            moduleSelect.addEventListener('change', function() {
                updateLevelsDropdown(this.value);
            });
            
            // Initial load on page mount
            const initialModuleId = moduleSelect.value;
            const initialLevelId = '<%= lesson && lesson.levelId ? lesson.levelId.toString() : "" %>';
            if (initialModuleId) {
                updateLevelsDropdown(initialModuleId, initialLevelId);
            }
        }

        // Form submit overlay for saving status
        document.querySelector('form').addEventListener('submit', function(e) {
            saveJson(); // Make sure quiz questions JSON is updated
            
            const btn = this.querySelector('button[type="submit"]');
            btn.classList.add('pointer-events-none', 'opacity-80');
            btn.innerHTML = `
                <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-white inline-block" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                Menyimpan Pelajaran...
            `;
        });
    </script>
</body>
</html>