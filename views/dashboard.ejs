<!DOCTYPE html>
<html lang="<%= lang || 'ms' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= (locals.branding && locals.branding.siteName) ? locals.branding.siteName : 'Dashboard' %> - <%= athlete.fullName %></title>
    <% if (locals.branding && locals.branding.faviconUrl) { %>
    <link rel="icon" href="<%= branding.faviconUrl %>">
    <% } %>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { font-family: 'Plus Jakarta Sans', 'Inter', sans-serif; }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(24px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @keyframes shimmer {
            0% { background-position: -200% center; }
            100% { background-position: 200% center; }
        }
        @keyframes pulse-glow {
            0%, 100% { box-shadow: 0 0 0 0 rgba(99,102,241,0.3); }
            50% { box-shadow: 0 0 0 12px rgba(99,102,241,0); }
        }
        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-6px); }
        }
        @keyframes progressFill {
            from { width: 0%; }
            to { width: var(--target-width); }
        }

        .fade-up { animation: fadeInUp 0.5s ease-out forwards; opacity: 0; }
        .delay-1 { animation-delay: 0.1s; }
        .delay-2 { animation-delay: 0.2s; }
        .delay-3 { animation-delay: 0.3s; }
        .delay-4 { animation-delay: 0.4s; }
        .delay-5 { animation-delay: 0.5s; }

        :root {
            --primary-color: <%= locals.branding?.primaryColor || '#0f0c29' %>;
        }

        .hero-gradient {
            background: linear-gradient(135deg, var(--primary-color) 0%, #302b63 50%, #24243e 100%);
        }
        .card-glass {
            background: rgba(255,255,255,0.03);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255,255,255,0.1);
        }
        .shimmer-text {
            background: linear-gradient(90deg, #a78bfa, #60a5fa, #34d399, #a78bfa);
            background-size: 200% auto;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: shimmer 3s linear infinite;
        }
        .module-card {
            position: relative;
            overflow: hidden;
            transition: all 0.4s cubic-bezier(0.4,0,0.2,1);
        }
        .module-card::before {
            content: '';
            position: absolute;
            inset: 0;
            opacity: 0;
            transition: opacity 0.3s;
            border-radius: inherit;
            pointer-events: none; /* Fix: allow clicking buttons inside */
        }
        .module-card:hover { transform: translateY(-6px); }
        .module-card:hover::before { opacity: 1; }
        .module-card.active::before { background: linear-gradient(135deg, rgba(99,102,241,0.08), rgba(59,130,246,0.08)); }
        .module-card.done::before { background: linear-gradient(135deg, rgba(16,185,129,0.08), rgba(5,150,105,0.08)); }
        .module-card.locked::before { background: linear-gradient(135deg, rgba(100,116,139,0.04), rgba(71,85,105,0.04)); }

        .progress-bar {
            height: 8px;
            border-radius: 99px;
            overflow: hidden;
            background: rgba(255,255,255,0.08);
        }
        .progress-fill {
            height: 100%;
            border-radius: 99px;
            width: var(--target-width, 0%);
            animation: progressFill 1.2s ease-out forwards;
            animation-delay: 0.6s;
            width: 0;
        }

        .step-badge {
            width: 36px; height: 36px;
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-weight: 800; font-size: 14px;
            flex-shrink: 0;
        }
        .trophy-float { animation: float 3s ease-in-out infinite; }

        @media print { .no-print { display: none !important; } }
    </style>
</head>
<body class="hero-gradient min-h-screen text-white">
    
    <!-- TOP NAV BAR -->
    <nav class="no-print sticky top-0 z-50 border-b border-white/10 backdrop-blur-xl bg-black/20">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between gap-2">
            <div class="flex items-center gap-2 sm:gap-3 min-w-0">
                <% if (locals.branding && locals.branding.logoUrl) { %>
                    <img src="<%= branding.logoUrl %>" alt="Logo" class="h-7 sm:h-8 w-auto object-contain filter drop-shadow-md shrink-0">
                <% } else { %>
                    <span class="text-xl sm:text-2xl shrink-0">🏅</span>
                    <span class="font-bold text-white text-xs sm:text-base truncate"><%= (locals.branding && locals.branding.siteName) ? locals.branding.siteName : 'MACE eLearning' %></span>
                <% } %>
            </div>
            <div class="flex items-center gap-1.5 sm:gap-3 shrink-0">
                <!-- Language Toggle -->
                <div class="flex gap-0.5 bg-white/10 rounded-lg p-0.5 sm:p-1 shrink-0">
                    <a href="?lang=ms" class="text-[10px] sm:text-xs px-2 sm:px-2.5 py-0.5 sm:py-1 rounded font-semibold transition-all <%= lang === 'ms' ? 'bg-white text-indigo-900' : 'text-white/60 hover:text-white' %>">BM</a>
                    <a href="?lang=en" class="text-[10px] sm:text-xs px-2 sm:px-2.5 py-0.5 sm:py-1 rounded font-semibold transition-all <%= lang === 'en' ? 'bg-white text-indigo-900' : 'text-white/60 hover:text-white' %>">EN</a>
                </div>
                <a href="/logout" class="flex items-center gap-1 sm:gap-1.5 text-xs sm:text-sm text-white/60 hover:text-red-400 transition-colors font-medium px-2 sm:px-3 py-1 sm:py-1.5 rounded-lg hover:bg-red-500/10 whitespace-nowrap shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 sm:h-4 w-3.5 sm:w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
                    <span class="whitespace-nowrap"><%= __('nav_logout') %></span>
                </a>
            </div>
        </div>
    </nav>

    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8 sm:py-10">
        <% 
        // Define lesson list inside dashboard scope to calculate progress
        const preLessonList = (typeof lessons !== 'undefined' && lessons && lessons.length > 0)
            ? lessons
            : [
                { title: 'Jom kuasai asas dulu sebelum jadi pro!', order: 1 }, 
                { title: 'Kenali kesalahan, elak jadi pelaku!', order: 2 }, 
                { title: 'Ambil tindakan yang betul, laporkan tanpa ragu!', order: 3 }
              ];
        
        // Group lessons by Module to check completion dynamically
        const preModulesMap = {};
        preLessonList.forEach((lesson, idx) => {
            const moduleObj = lesson.moduleId;
            const moduleName = (moduleObj && moduleObj.title) ? moduleObj.title : 'MODUL 1 : PLAY SAFE WIN STRONG';
            if (!preModulesMap[moduleName]) {
                preModulesMap[moduleName] = [];
            }
            preModulesMap[moduleName].push({ ...lesson, idx });
        });

        // Calculate completed modules
        let completedModulesCount = 0;
        Object.keys(preModulesMap).forEach(mName => {
            const isCompleted = preModulesMap[mName].every(item => athlete.currentStage > (item.order || (item.idx + 1)));
            if (isCompleted) {
                completedModulesCount++;
            }
        });

        // Find completed modules that have certificates dynamically
        const completedCertModules = [];
        if (typeof allModules !== 'undefined' && allModules && Array.isArray(allModules)) {
            allModules.forEach(m => {
                const mLessons = preLessonList.filter(l => l.moduleId && l.moduleId._id.toString() === m._id.toString());
                const isCompleted = mLessons.length > 0 && mLessons.every(l => athlete.currentStage > l.order);
                if (isCompleted && m.hasCertificate) {
                    completedCertModules.push(m);
                }
            });
        }

        // Fallback for legacy database or Module 1
        if (completedCertModules.length === 0 && athlete.currentStage >= 4) {
            completedCertModules.push({
                _id: 'legacy',
                title: 'MODUL 1 : PLAY SAFE WIN STRONG',
                hasCertificate: true
            });
        }

        const totalModulesCount = Object.keys(preModulesMap).length || 1;
        const overallPercent = Math.round((completedModulesCount / totalModulesCount) * 100);

        // Set stage label dynamically
        let stageLabel = "";
        if (completedModulesCount > 0) {
            stageLabel = lang === 'en' ? `🏆 Completed: Module ${completedModulesCount}` : `🏆 Tamat: Modul ${completedModulesCount}`;
        } else {
            stageLabel = lang === 'en' ? `Stage ${athlete.currentStage}` : `Peringkat ${athlete.currentStage}`;
        }
        const stageBg = completedModulesCount > 0 ? 'bg-emerald-500/20 border-emerald-400/30 text-emerald-300' : 'bg-indigo-500/20 border-indigo-400/30 text-indigo-300';
        
        const circumference = 2 * Math.PI * 38;
        const strokeDash = circumference - (overallPercent / 100) * circumference;
        %>

        <!-- HERO GREETING -->
        <div class="fade-up delay-1 mb-8 sm:mb-10">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
                <div>
                    <p class="text-white/50 text-sm font-medium mb-1 uppercase tracking-widest">
                        <%= lang === 'en' ? 'Welcome back' : 'Selamat kembali' %> 👋
                    </p>
                    <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold mb-3">
                        <span class="shimmer-text"><%= athlete.fullName %></span>
                    </h1>
                    <div class="flex flex-wrap items-center gap-2 text-sm">
                        <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-white/10 border border-white/10 rounded-full text-white/80">
                            📍 <%= athlete.negeriWakil %>
                        </span>
                        <% if (athlete.sukan) { %>
                        <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-white/10 border border-white/10 rounded-full text-white/80">
                            ⚡ <%= athlete.sukan %>
                        </span>
                        <% } %>
                        <span class="inline-flex items-center gap-1.5 px-3 py-1 border rounded-full font-semibold <%= stageBg %>">
                            <%= stageLabel %>
                        </span>
                    </div>
                </div>
                    <div class="flex flex-col items-center">
                        <div class="relative w-28 h-28">
                            <svg class="w-28 h-28 -rotate-90" viewBox="0 0 90 90">
                                <circle cx="45" cy="45" r="38" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="8"/>
                                <circle cx="45" cy="45" r="38" fill="none" 
                                    stroke="url(#progressGrad)" stroke-width="8"
                                    stroke-linecap="round"
                                    stroke-dasharray="<%= circumference %>"
                                    stroke-dashoffset="<%= strokeDash %>"
                                    style="transition: stroke-dashoffset 1.5s ease-out;"/>
                                <defs>
                                    <linearGradient id="progressGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                                        <stop offset="0%" stop-color="#818cf8"/>
                                        <stop offset="100%" stop-color="#34d399"/>
                                    </linearGradient>
                                </defs>
                            </svg>
                            <div class="absolute inset-0 flex flex-col items-center justify-center">
                                <span class="text-2xl font-extrabold text-white"><%= overallPercent %>%</span>
                            </div>
                        </div>
                        <p class="text-white/50 text-xs mt-1 font-medium text-center">
                            <%= lang === 'en' ? 'Overall Progress' : 'Kemajuan Keseluruhan' %>
                        </p>
                    </div>
                </div>
            </div>

        <!-- MODULE CARDS -->
        <h2 class="fade-up delay-2 text-white/60 text-xs uppercase tracking-widest font-semibold mb-4">
            <%= __('dashboard_modules') || 'LEARNING MODULES' %>
        </h2>
        <%
        // Gunakan lessons dari DB jika ada, jika tidak fallback ke 3 modul dummy
        const lessonList = (typeof lessons !== 'undefined' && lessons && lessons.length > 0)
            ? lessons
            : [
                { title: 'Jom kuasai asas dulu sebelum jadi pro!', order: 1 }, 
                { title: 'Kenali kesalahan, elak jadi pelaku!', order: 2 }, 
                { title: 'Ambil tindakan yang betul, laporkan tanpa ragu!', order: 3 }
              ];
        
        // Group lessons by Module
        const modulesMap = {};
        const modulesDataMap = {};
        lessonList.forEach((lesson, idx) => {
            const moduleObj = lesson.moduleId;
            const moduleName = (moduleObj && moduleObj.title) ? moduleObj.title : 'MODUL 1 : PLAY SAFE WIN STRONG';
            if (!modulesMap[moduleName]) {
                modulesMap[moduleName] = [];
                modulesDataMap[moduleName] = moduleObj;
            }
            modulesMap[moduleName].push({ ...lesson, idx });
        });
        %>
        <% Object.keys(modulesMap).forEach(moduleName => { %>
            <div class="mb-8">
                <h3 class="text-white font-bold text-lg mb-4 flex items-center justify-between gap-2 flex-wrap">
                    <div class="flex items-center gap-2">
                        <span class="w-1.5 h-6 bg-emerald-400 rounded-full"></span>
                        <%= moduleName %>
                    </div>
                    <% const moduleObj = modulesDataMap[moduleName]; %>
                    <% if (moduleObj && moduleObj.hasCertificate) { %>
                        <% const isModuleCompleted = modulesMap[moduleName].every(item => athlete.currentStage > (item.order || (item.idx + 1))); %>
                        <% if (isModuleCompleted) { %>
                            <a href="/certificate/module/<%= moduleObj._id %>" target="_blank" class="text-xs bg-yellow-500 hover:bg-yellow-400 text-blue-900 font-bold px-3 py-1.5 rounded-lg flex items-center gap-1.5 transition-colors shadow-sm no-print">
                                🎓 <%= lang === 'en' ? 'Print Certificate' : 'Cetak Sijil' %>
                            </a>
                        <% } else { %>
                            <span class="text-xs text-white/40 border border-white/10 px-3 py-1.5 rounded-lg flex items-center gap-1.5 no-print">
                                🔒 <%= lang === 'en' ? 'Certificate Locked' : 'Sijil Dikunci' %>
                            </span>
                        <% } %>
                    <% } %>
                </h3>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5">
                    <% modulesMap[moduleName].forEach(item => {
                        const lesson = item;
                        const idx = item.idx;
                        const i = lesson.order || (idx + 1);
                        const isLocked = athlete.currentStage < i;
                        const isCompleted = athlete.currentStage > i;
                        const isCurrent = athlete.currentStage === i;
                        const quizScore = athlete.quizScores && athlete.quizScores['quiz'+i] ? athlete.quizScores['quiz'+i] : 0;
                        const cardClass = isLocked ? 'locked' : (isCompleted ? 'done' : 'active');
                        const borderGrad = isLocked 
                            ? 'border-white/5' 
                            : (isCompleted ? 'border-emerald-500/30' : 'border-indigo-500/40');
                        const bgGrad = isLocked 
                            ? 'bg-white/3' 
                            : (isCompleted ? 'bg-emerald-950/40' : 'bg-indigo-950/50');
                        const delayNum = Math.min(idx + 2, 5);
                    %>
                    <div class="fade-up delay-<%= delayNum %> module-card <%= cardClass %> rounded-2xl p-5 sm:p-6 border <%= borderGrad %> <%= bgGrad %>">
                        
                        <!-- Card Header -->
                        <div class="flex items-start justify-between mb-4">
                            <div>
                                <p class="text-xs font-semibold uppercase tracking-widest mb-1 <%= isLocked ? 'text-white/30' : (isCompleted ? 'text-emerald-400' : 'text-indigo-400') %>">
                                    <%= lang === 'en' ? 'Lesson' : 'Pelajaran' %> <%= i %>
                                </p>
                                <h3 class="font-bold text-base leading-snug <%= isLocked ? 'text-white/40' : 'text-white' %>">
                                    <%= lesson.title %>
                                </h3>
                            </div>
                            <div class="text-3xl flex-shrink-0 ml-2">
                                <% if (isLocked) { %>🔒
                                <% } else if (isCompleted) { %>✅
                                <% } else { %>📖
                                <% } %>
                            </div>
                        </div>

                        <!-- Progress Bar -->
                        <% if (!isLocked) { %>
                        <div class="mb-4">
                            <div class="flex justify-between text-xs font-medium mb-1.5">
                                <span class="<%= isCompleted ? 'text-emerald-400' : 'text-white/60' %>">
                                    <%= isCompleted ? __('progress_completed') : __('progress_in_progress') %>
                                </span>
                                <span class="<%= isCompleted ? 'text-emerald-300 font-bold' : 'text-white/60' %>">
                                    <%= isCompleted ? quizScore + '%' : '—' %>
                                </span>
                            </div>
                            <div class="progress-bar">
                                <div class="progress-fill <%= isCompleted ? 'bg-gradient-to-r from-emerald-500 to-teal-400' : 'bg-gradient-to-r from-indigo-500 to-blue-400' %>"
                                     style="--target-width: <%= isCompleted ? quizScore + '%' : '0%' %>">
                                </div>
                            </div>
                        </div>
                        <% } %>

                        <!-- Status Text -->
                        <p class="text-xs mb-4 <%= isLocked ? 'text-white/25' : (isCompleted ? 'text-emerald-400/80' : 'text-white/50') %>">
                            <% if (isLocked) { %>
                                🔐 <%= __('dashboard_locked_hint') %>
                            <% } else if (isCompleted) { %>
                                🎯 <%= lang === 'en' ? 'Score: ' + quizScore + '%' : 'Skor: ' + quizScore + '%' %>
                            <% } else { %>
                                ▶ <%= __('dashboard_active_hint') %>
                            <% } %>
                        </p>

                        <!-- Action Button -->
                        <% if (!isLocked) { %>
                            <a href="/lesson/<%= i %>" 
                               class="block text-center py-2.5 rounded-xl text-sm font-bold transition-all duration-300 <%= isCompleted ? 'bg-emerald-500/20 hover:bg-emerald-500/30 text-emerald-300 border border-emerald-500/30 hover:border-emerald-400' : 'bg-indigo-600 hover:bg-indigo-500 text-white shadow-lg shadow-indigo-900/50 hover:shadow-indigo-800/50' %>"
                               style="z-index: 10; position: relative;">
                                <%= isCompleted ? __('dashboard_btn_review') : __('dashboard_btn_start') %>
                            </a>
                        <% } else { %>
                            <button disabled class="block w-full text-center py-2.5 rounded-xl text-sm font-bold bg-white/3 text-white/20 cursor-not-allowed border border-white/5">
                                <%= __('dashboard_btn_locked') %>
                            </button>
                        <% } %>
                    </div>
                    <% }) %>
                </div>
            </div>
        <% }) %>

        <!-- CERTIFICATE SECTION (if completed) -->
        <% if (completedCertModules.length > 0) { %>
            <% completedCertModules.forEach(m => { %>
                <% 
                    const certUrl = m._id === 'legacy' ? `/certificate/${athlete._id}` : `/certificate/module/${m._id}`;
                %>
                <div class="fade-up delay-5 relative overflow-hidden rounded-3xl p-6 sm:p-10 mb-8 text-center bg-slate-900/60 backdrop-blur-xl border border-amber-500/20 shadow-[0_8px_30px_rgba(245,158,11,0.05)]">
                    <!-- Subtle Golden Glow Behind -->
                    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-80 h-80 bg-amber-500/5 rounded-full blur-[100px] pointer-events-none"></div>
                    
                    <div class="relative z-10">
                        <!-- Premium Gold Award Icon (SVG) -->
                        <svg class="w-16 h-16 mx-auto mb-4 drop-shadow-[0_0_15px_rgba(245,158,11,0.5)]" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M32 4C24.268 4 18 10.268 18 18C18 24.363 22.242 29.743 28 31.4V48L32 52L36 48V31.4C41.758 29.743 46 24.363 46 18C46 10.268 39.732 4 32 4Z" fill="url(#goldGrad)" />
                            <circle cx="32" cy="18" r="8" fill="#FFF" fill-opacity="0.2" />
                            <path d="M26 18L30 22L38 14" stroke="#FFF" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
                            <path d="M22 50L14 58H50L42 50" stroke="url(#goldGrad)" stroke-width="2" stroke-linecap="round" />
                            <defs>
                                <linearGradient id="goldGrad" x1="18" y1="4" x2="46" y2="48" gradientUnits="userSpaceOnUse">
                                    <stop offset="0%" stop-color="#FBBF24" />
                                    <stop offset="50%" stop-color="#F59E0B" />
                                    <stop offset="100%" stop-color="#D97706" />
                                </linearGradient>
                            </defs>
                        </svg>

                        <h2 class="text-2xl sm:text-3xl font-extrabold text-white mb-3 tracking-wide">
                            <%= lang === 'en' ? 'Congratulations! You Have Succeeded!' : 'Tahniah! Anda Telah Berjaya!' %>
                        </h2>
                        
                        <p class="text-white/80 text-sm sm:text-base max-w-xl mx-auto mb-6 leading-relaxed">
                            <%= lang === 'en' 
                                ? `You have successfully completed all requirements for `
                                : `Anda telah berjaya menyelesaikan semua pembelajaran bagi ` %><strong><%= m.title %></strong>. 
                            <%= lang === 'en'
                                ? 'Your official certificate of achievement is now ready.'
                                : 'Sijil pencapaian rasmi anda kini sedia untuk dimuat turun.' %>
                        </p>
                        
                        <div class="flex flex-col sm:flex-row gap-3 justify-center">
                            <a href="<%= certUrl %>" target="_blank"
                               class="inline-flex items-center justify-center gap-2 bg-gradient-to-r from-amber-500 to-yellow-400 hover:from-amber-600 hover:to-yellow-500 text-slate-900 font-extrabold px-8 py-3.5 rounded-xl transition-all shadow-[0_4px_20px_rgba(245,158,11,0.25)] hover:shadow-[0_4px_25px_rgba(245,158,11,0.45)] transform hover:-translate-y-0.5">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                                <%= lang === 'en' ? 'Download Certificate' : 'Muat Turun Sijil' %>
                            </a>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } %>

        <!-- LEARNING GUIDE -->
        <div class="fade-up delay-5">
            <div class="card-glass rounded-2xl p-5 sm:p-6">
                <h3 class="font-bold text-white/80 mb-4 flex items-center gap-2 text-sm uppercase tracking-widest">
                    💡 <%= lang === 'en' ? 'How It Works' : 'Cara Pembelajaran' %>
                </h3>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-sm">
                    <div class="flex items-start gap-3">
                        <div class="step-badge bg-indigo-500/20 text-indigo-400 border border-indigo-500/30">1</div>
                        <p class="text-white/60 pt-1 leading-relaxed">
                            <%= lang === 'en' ? 'Watch the full video lessons to activate the module evaluation' : 'Tonton video pelajaran secara keseluruhan untuk mengaktifkan sesi penilaian' %>
                        </p>
                    </div>
                    <div class="flex items-start gap-3">
                        <div class="step-badge bg-emerald-500/20 text-emerald-400 border border-emerald-500/30">2</div>
                        <p class="text-white/60 pt-1 leading-relaxed">
                            <%= lang === 'en' ? 'Complete the evaluation quiz with a minimum score of 80% to pass' : 'Jawab kuiz dengan mencapai markah minimum 80% untuk kelayakan lulus' %>
                        </p>
                    </div>
                    <div class="flex items-start gap-3">
                        <div class="step-badge bg-amber-500/20 text-amber-400 border border-amber-500/30">3</div>
                        <p class="text-white/60 pt-1 leading-relaxed">
                            <%= lang === 'en' ? 'Complete all lessons within the module to be awarded your certificate of achievement' : 'Sempurnakan semua pembelajaran dalam modul untuk dianugerahkan sijil pencapaian' %>
                        </p>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- First Time Welcome Modal -->
    <% if (athlete.currentStage === 1 && lessons && lessons.length > 0 && lessons[0].moduleId) { %>
        <div id="welcomeModal" class="fixed inset-0 bg-black/80 z-[100] flex items-center justify-center p-4 transition-opacity duration-300 opacity-0 pointer-events-none" style="backdrop-filter: blur(5px);">
            <div class="bg-white rounded-2xl max-w-2xl w-full overflow-hidden shadow-2xl relative transform transition-transform duration-300 scale-95 max-h-[85vh] md:max-h-[90vh] flex flex-col" id="welcomeModalContent">
                
                <!-- Scrollable Content Container -->
                <div class="overflow-y-auto flex-1">
                    <% if (lessons[0].moduleId.thumbnail) { %>
                        <img src="<%= lessons[0].moduleId.thumbnail %>" alt="Cover" class="w-full h-48 sm:h-64 object-cover">
                    <% } else { %>
                        <div class="w-full h-48 bg-gradient-to-r from-blue-600 to-indigo-700"></div>
                    <% } %>
                    
                    <div class="p-6 sm:p-8 text-gray-900">
                        <h2 class="text-xl sm:text-2xl font-black mb-4 uppercase text-gray-900 leading-tight">
                            <%= lessons[0].moduleId.title || lessons[0].title || '' %>
                        </h2>
                        
                        <div class="prose max-w-none text-gray-700 leading-relaxed text-sm sm:text-base">
                            <%- lessons[0].moduleId.description || (lang === 'en' ? 'Please start your learning...' : 'Sila mulakan pembelajaran anda...') %>
                        </div>
                    </div>
                </div>
                
                <!-- Fixed Footer at the bottom -->
                <div class="p-4 sm:p-6 border-t border-gray-100 bg-gray-50 flex justify-end">
                    <button onclick="closeWelcomeModal()" class="w-full sm:w-auto px-10 py-3 bg-[#e87a14] hover:bg-[#d66c11] text-white text-base sm:text-lg font-bold rounded-xl transition-all duration-300 shadow-md hover:shadow-lg active:scale-95">
                        <%= lang === 'en' ? 'Start Module' : 'Mulakan Modul' %>
                    </button>
                </div>
            </div>
        </div>
    <% } %>
    </div>

    <script>
        // Welcome Modal Logic
        document.addEventListener('DOMContentLoaded', () => {
            const modal = document.getElementById('welcomeModal');
            if (modal) {
                const athleteId = '<%= athlete._id %>';
                if (!localStorage.getItem('hasSeenWelcome_' + athleteId)) {
                    // Show modal
                    modal.classList.remove('opacity-0', 'pointer-events-none');
                    document.getElementById('welcomeModalContent').classList.remove('scale-95');
                    document.getElementById('welcomeModalContent').classList.add('scale-100');
                    document.body.style.overflow = 'hidden';
                }
            }
        });

        function closeWelcomeModal() {
            const modal = document.getElementById('welcomeModal');
            const athleteId = '<%= athlete._id %>';
            localStorage.setItem('hasSeenWelcome_' + athleteId, 'true');
            
            modal.classList.add('opacity-0', 'pointer-events-none');
            document.getElementById('welcomeModalContent').classList.remove('scale-100');
            document.getElementById('welcomeModalContent').classList.add('scale-95');
            document.body.style.overflow = '';
        }

        // Animate progress bars on load
        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('.progress-fill').forEach(bar => {
                const target = bar.style.getPropertyValue('--target-width');
                setTimeout(() => {
                    bar.style.width = target;
                }, 600);
            });
        });
    </script>
</body>
</html>