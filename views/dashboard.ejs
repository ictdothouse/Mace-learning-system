<!DOCTYPE html>
<html lang="<%= lang || 'ms' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - <%= athlete.fullName %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        @media print {
            .no-print { display: none !important; }
        }
    </style>
</head>
<body class="bg-gradient-to-br from-gray-50 to-blue-50 min-h-screen p-4 sm:p-6 lg:p-8">
    <div class="max-w-6xl mx-auto">
        <!-- Header -->
        <div class="bg-white rounded-2xl shadow-lg p-6 sm:p-8 mb-6 sm:mb-8 border border-gray-100">
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
                <div>
                    <h1 class="text-2xl sm:text-3xl font-bold text-gray-800 mb-2">Tahniah, <%= athlete.fullName.split(' ')[0] %>! 👋</h1>
                    <div class="flex flex-wrap items-center gap-2 sm:gap-4 text-sm sm:text-base">
                        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-blue-100 text-blue-700 rounded-full font-medium">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                            <%= athlete.negeriWakil %>
                        </span>
                        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-purple-100 text-purple-700 rounded-full font-medium">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                            </svg>
                            Stage <%= athlete.currentStage %>
                        </span>
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    <!-- Toggle Bahasa -->
                    <div class="flex gap-1 bg-gray-100 rounded-lg p-1">
                        <form method="POST" action="/set-language" class="inline">
                            <input type="hidden" name="lang" value="ms">
                            <button type="submit" class="text-xs px-2 py-1 rounded font-semibold transition <%= lang === 'ms' ? 'bg-white shadow text-blue-700' : 'text-gray-500 hover:text-gray-700' %>">🇲🇾 BM</button>
                        </form>
                        <form method="POST" action="/set-language" class="inline">
                            <input type="hidden" name="lang" value="en">
                            <button type="submit" class="text-xs px-2 py-1 rounded font-semibold transition <%= lang === 'en' ? 'bg-white shadow text-blue-700' : 'text-gray-500 hover:text-gray-700' %>">🇬🇧 EN</button>
                        </form>
                    </div>
                    <a href="/logout" class="inline-flex items-center gap-2 text-red-600 hover:text-red-700 hover:bg-red-50 px-4 py-2 rounded-lg transition-all font-medium">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                        </svg>
                        <%= __('nav_logout') %>
                    </a>
                </div>
            </div>
        </div>

        <!-- Modul Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 mb-6 sm:mb-8">
            <% for(let i=1; i<=3; i++) { 
                const isLocked = athlete.currentStage < i;
                const isCompleted = athlete.currentStage > i;
            %>
                <div class="bg-white p-6 rounded-xl shadow-md border-l-4 <%= isLocked ? 'border-gray-300' : (isCompleted ? 'border-green-500' : 'border-blue-500') %> hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1">
                    <div class="flex justify-between items-center mb-3">
                        <h3 class="text-lg sm:text-xl font-bold text-gray-800">Modul <%= i %></h3>
                        <% if(isLocked) { %>
                            <span class="text-2xl" title="Terkunci">🔒</span>
                        <% } else if(isCompleted) { %>
                            <span class="text-2xl" title="Selesai">✅</span>
                        <% } else { %>
                            <span class="text-2xl" title="Sedang belajar">📖</span>
                        <% } %>
                    </div>
                    <p class="text-sm text-gray-500 mb-4 min-h-[40px]">
                        <%= isLocked ? 'Sila lulus kuiz sebelumnya.' : (isCompleted ? 'Modul selesai' : 'Klik untuk mula belajar') %>
                    </p>
                    <% if(!isLocked) { %>
                        <a href="/lesson/<%= i %>" class="block text-center <%= isCompleted ? 'bg-green-600 hover:bg-green-700' : 'bg-blue-600 hover:bg-blue-700' %> text-white py-3 rounded-lg font-semibold transition-all transform hover:scale-[1.02] active:scale-[0.98]">
                            <%= isCompleted ? '🔄 Ulang Kaji' : '▶️ Mulakan' %>
                        </a>
                    <% } else { %>
                        <button disabled class="block w-full text-center bg-gray-100 text-gray-400 py-3 rounded-lg font-semibold cursor-not-allowed">
                            🔒 Terkunci
                        </button>
                    <% } %>
                </div>
            <% } %>
        </div>

        <!-- Certificate Section -->
        <% if(athlete.currentStage >= 4) { %>
            <div class="bg-gradient-to-r from-yellow-400 via-orange-400 to-red-400 p-6 sm:p-8 rounded-2xl text-center text-white shadow-xl border border-yellow-300">
                <div class="flex justify-center mb-4">
                    <div class="bg-white/20 backdrop-blur-sm p-4 rounded-full">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
                        </svg>
                    </div>
                </div>
                <h2 class="text-2xl sm:text-3xl font-bold mb-3">🏆 Tahniah! Anda Lulus!</h2>
                <p class="mb-6 text-white/90 text-sm sm:text-base max-w-xl mx-auto">Anda telah berjaya menyelesaikan semua modul pembelajaran eLearning Atlit SUKMA. Sila muat turun sijil penyertaan anda.</p>
                <div class="flex flex-col sm:flex-row gap-3 justify-center">
                    <a href="/certificate/<%= athlete._id %>?print=1" target="_blank" 
                        class="inline-flex items-center justify-center gap-2 bg-white text-blue-600 px-6 py-3 rounded-lg font-bold hover:bg-blue-50 transition-all transform hover:scale-[1.02] active:scale-[0.98] shadow-lg">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                        📜 Muat Turun Sijil
                    </a>
                    <a href="/dashboard" class="inline-flex items-center justify-center gap-2 bg-blue-600 text-white px-6 py-3 rounded-lg font-bold hover:bg-blue-700 transition-all transform hover:scale-[1.02] active:scale-[0.98] shadow-lg">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                        </svg>
                        Segar Semula
                    </a>
                </div>
            </div>
        <% } %>

        <!-- Progress Info -->
        <div class="mt-6 sm:mt-8 bg-white rounded-xl shadow-md p-6 border border-gray-100">
            <h3 class="text-lg font-bold text-gray-800 mb-4 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                Panduan Pembelajaran
            </h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 text-sm text-gray-600">
                <div class="flex items-start gap-3">
                    <span class="bg-blue-100 text-blue-600 w-8 h-8 rounded-full flex items-center justify-center font-bold flex-shrink-0">1</span>
                    <p>Tonton video pembelajaran sehingga tamat untuk membuka kuiz</p>
                </div>
                <div class="flex items-start gap-3">
                    <span class="bg-green-100 text-green-600 w-8 h-8 rounded-full flex items-center justify-center font-bold flex-shrink-0">2</span>
                    <p>Jawab kuiz dengan minimum 80% untuk lulus</p>
                </div>
                <div class="flex items-start gap-3">
                    <span class="bg-purple-100 text-purple-600 w-8 h-8 rounded-full flex items-center justify-center font-bold flex-shrink-0">3</span>
                    <p>Lengkapkan ketiga-tiga modul untuk mendapat sijil</p>
                </div>
            </div>
        </div>
    </div>
</body>
</html>